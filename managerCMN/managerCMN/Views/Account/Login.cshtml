@{
    ViewData["Title"] = "Đăng nhập";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - Quản lý Công ty</title>
    <link rel="icon" type="image/png" href="/images/cmnLOGO.png" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        :root {
            --cmn-primary: #c83200;
            --cmn-primary-soft: #f07300;
            --cmn-ink: #17212f;
            --cmn-muted: #6b7280;
            --cmn-paper: #f7f7f3;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
            background:
                radial-gradient(circle at 15% 20%, rgba(240, 115, 0, 0.2), transparent 40%),
                radial-gradient(circle at 85% 80%, rgba(200, 50, 0, 0.18), transparent 45%),
                linear-gradient(140deg, #fffdf8 0%, #fff5e8 45%, #ffe7cf 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
        }

        .login-shell {
            width: 100%;
            max-width: 1080px;
            border-radius: 24px;
            overflow: hidden;
            background: #fff;
            box-shadow: 0 28px 80px rgba(23, 33, 47, 0.16);
            display: grid;
            grid-template-columns: 1.1fr 1fr;
        }

        .login-brand {
            position: relative;
            color: #fff;
            padding: 44px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            background: linear-gradient(155deg, #8f2300 0%, var(--cmn-primary) 45%, var(--cmn-primary-soft) 100%);
        }

        .brand-top {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 14px;
        }

        .brand-top img {
            width: 72px;
            height: 72px;
            object-fit: contain;
            background: rgba(255, 255, 255, 0.92);
            border-radius: 18px;
            padding: 9px;
        }

        .brand-title {
            line-height: 1.2;
            text-align: center;
        }

        .brand-title h1 {
            margin: 0;
            font-size: 1.45rem;
            font-weight: 700;
            letter-spacing: 0.3px;
        }

        .brand-title p {
            margin: 4px 0 0;
            font-size: 0.92rem;
            opacity: 0.86;
        }


        .login-panel {
            background: #fff;
            padding: 44px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .panel-title {
            margin-bottom: 22px;
        }

        .panel-title h3 {
            margin: 0;
            color: var(--cmn-ink);
            font-size: 1.4rem;
            font-weight: 700;
        }

        .panel-title p {
            margin: 6px 0 0;
            color: var(--cmn-muted);
            font-size: 0.95rem;
        }

        .btn-google {
            border: 1px solid #d9dee7;
            border-radius: 12px;
            background: #fff;
            color: #1f2937;
            font-weight: 600;
            padding: 0.85rem 1rem;
            transition: all 0.22s ease;
        }

        .btn-google:hover {
            border-color: #c0c9d8;
            background: #f8fafc;
            transform: translateY(-1px);
        }

        .google-icon {
            width: 20px;
            height: 20px;
            margin-right: 8px;
        }

        .dev-box {
            margin-top: 18px;
            padding: 14px;
            border: 1px dashed #d9dee7;
            border-radius: 12px;
            background: var(--cmn-paper);
        }

        details summary {
            list-style: none;
        }

        details summary::-webkit-details-marker {
            display: none;
        }

        @@media (max-width: 992px) {
            .login-shell {
                grid-template-columns: 1fr;
                max-width: 560px;
            }

            .login-brand {
                padding: 30px;
                min-height: 200px;
            }

            .login-panel {
                padding: 30px;
            }
        }

        @@media (max-width: 576px) {
            body {
                padding: 14px;
            }

            .login-shell {
                border-radius: 18px;
            }

            .brand-top img {
                width: 60px;
                height: 60px;
            }

            .brand-title h1 {
                font-size: 1.2rem;
            }

            .login-panel {
                padding: 24px 20px;
            }
        }
    </style>
</head>
<body>
    <div class="login-shell">
        <aside class="login-brand">
            <div class="brand-top">
                <img src="/images/cmnLOGO.png" alt="CMN Logo" />
                <div class="brand-title">
                    <h1>CMN Management</h1>
                    <p>Cổng vận hành nội bộ doanh nghiệp</p>
                </div>
            </div>

        </aside>

        <main class="login-panel">
            <div class="panel-title">
                <h3>Đăng nhập hệ thống</h3>
                <p>Sử dụng tài khoản Google thuộc miền công ty để tiếp tục.</p>
            </div>

            @if (TempData["LoginError"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show text-start" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    @TempData["LoginError"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <form asp-controller="Account" asp-action="ExternalLogin" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                <button type="submit" class="btn btn-google w-100 d-flex align-items-center justify-content-center">
                    <svg class="google-icon" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
                    Đăng nhập với Google
                </button>
            </form>

            @* @if ((bool?)ViewData["IsDevelopment"] == true)
            {
                <div class="dev-box">
                    <p class="text-muted small mb-2">Chế độ Development</p>
                    <form asp-controller="Account" asp-action="DevLogin" method="post" class="mb-2">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                        <button type="submit" class="btn btn-outline-primary w-100">
                            <i class="bi bi-shield-lock"></i> Đăng nhập Admin (NV001)
                        </button>
                    </form>
                    <details class="text-start">
                        <summary class="btn btn-outline-secondary w-100 mb-2"><i class="bi bi-people"></i> Đăng nhập nhân viên khác</summary>
                        <form asp-controller="Account" asp-action="DevLogin" method="post" class="mt-2">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                            <select name="employeeId" class="form-select form-select-sm mb-2">
                                @if (ViewBag.DevEmployees != null)
                                {
                                    @foreach (var emp in ViewBag.DevEmployees)
                                    {
                                        <option value="@emp.EmployeeId">@emp.EmployeeCode - @emp.FullName [@emp.Department]</option>
                                    }
                                }
                            </select>
                            <button type="submit" class="btn btn-outline-info w-100 btn-sm">
                                <i class="bi bi-box-arrow-in-right"></i> Đăng nhập
                            </button>
                        </form>
                    </details>
                </div>
            } *@
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
