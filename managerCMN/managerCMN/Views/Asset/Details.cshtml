@model Asset
@{
    ViewData["Title"] = "Chi tiết Tài sản";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-laptop"></i> @Model.AssetName</h4>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.AssetId" class="btn btn-warning"><i class="bi bi-pencil"></i> Sửa</a>
        @if (Model.Status == AssetStatus.Available)
        {
            <a asp-action="Assign" asp-route-id="@Model.AssetId" class="btn btn-success"><i class="bi bi-person-plus"></i> Cấp phát</a>
        }
        <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">Thông tin tài sản</div>
            <div class="card-body">
                <div class="row g-2">
                    <div class="col-4"><strong>Mã TS:</strong></div><div class="col-8">@Model.AssetCode</div>
                    <div class="col-4"><strong>Tên:</strong></div><div class="col-8">@Model.AssetName</div>
                    <div class="col-4"><strong>Danh mục:</strong></div><div class="col-8">@Model.AssetCategory?.CategoryName</div>
                    <div class="col-4"><strong>Hãng:</strong></div><div class="col-8">@Model.Brand?.BrandName</div>
                    <div class="col-4"><strong>NCC:</strong></div><div class="col-8">@Model.Supplier?.SupplierName</div>
                    <div class="col-4"><strong>Ngày mua:</strong></div><div class="col-8">@Model.PurchaseDate?.ToString("dd/MM/yyyy")</div>
                    <div class="col-4"><strong>Giá mua:</strong></div><div class="col-8">@Model.PurchasePrice?.ToString("N0") ₫</div>
                    <div class="col-4"><strong>Trạng thái:</strong></div>
                    <div class="col-8">
                        @switch (Model.Status)
                        {
                            case AssetStatus.Available: <span class="badge bg-success">Sẵn sàng</span> break;
                            case AssetStatus.Assigned: <span class="badge bg-primary">Đang dùng</span> break;
                            case AssetStatus.UnderRepair: <span class="badge bg-warning">Bảo trì</span> break;
                            case AssetStatus.Disposed: <span class="badge bg-secondary">Thanh lý</span> break;
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (Model.Configuration != null)
    {
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">Cấu hình</div>
            <div class="card-body">
                <div class="row g-2">
                    <div class="col-4"><strong>CPU:</strong></div><div class="col-8">@Model.Configuration.CPU</div>
                    <div class="col-4"><strong>Mainboard:</strong></div><div class="col-8">@Model.Configuration.Mainboard</div>
                    <div class="col-4"><strong>RAM:</strong></div><div class="col-8">@Model.Configuration.RAM</div>
                    <div class="col-4"><strong>SSD:</strong></div><div class="col-8">@Model.Configuration.SSD</div>
                    <div class="col-4"><strong>HDD:</strong></div><div class="col-8">@Model.Configuration.HDD</div>
                    <div class="col-4"><strong>VGA:</strong></div><div class="col-8">@Model.Configuration.VGA</div>
                    <div class="col-4"><strong>OS:</strong></div><div class="col-8">@Model.Configuration.OS</div>
                </div>
            </div>
        </div>
    </div>
    }
</div>

@if (Model.Assignments?.Any() == true)
{
<div class="card mt-3">
    <div class="card-header">Lịch sử cấp phát</div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr><th>Nhân viên</th><th>Ngày cấp</th><th>Ngày trả</th><th>Trạng thái</th><th>Tình trạng trả</th></tr>
            </thead>
            <tbody>
                @foreach (var a in Model.Assignments)
                {
                <tr>
                    <td>@a.Employee?.FullName</td>
                    <td>@a.AssignedDate.ToString("dd/MM/yyyy")</td>
                    <td>@a.ReturnDate?.ToString("dd/MM/yyyy")</td>
                    <td><span class="badge bg-@(a.Status == AssetAssignmentStatus.Assigned ? "primary" : "secondary")">@a.Status</span></td>
                    <td>@a.Condition</td>
                </tr>
                }
            </tbody>
        </table>
    </div>
</div>
}
