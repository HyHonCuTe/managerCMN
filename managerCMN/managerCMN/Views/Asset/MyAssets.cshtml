@model IEnumerable<Asset>
@{
    ViewData["Title"] = "Tài sản của tôi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1"><i class="bi bi-laptop text-primary"></i> Tài sản của tôi</h4>
        <small class="text-muted">Danh sách tài sản đang được cấp phát</small>
    </div>
    <div class="badge bg-info fs-6">
        @Model.Count() tài sản
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-laptop-fill text-muted" style="font-size: 4rem;"></i>
        <h5 class="text-muted mt-3">Chưa có tài sản nào được cấp phát</h5>
        <p class="text-muted">Liên hệ với quản trị viên để được cấp phát tài sản.</p>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var asset in Model)
        {
            var assignment = asset.Assignments?.LastOrDefault(a => a.Status == AssetAssignmentStatus.Assigned);
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h6 class="card-title text-primary fw-bold mb-0">@asset.AssetName</h6>
                            <span class="badge bg-success">Đang sử dụng</span>
                        </div>

                        <p class="text-muted small mb-2">
                            <i class="bi bi-qr-code"></i> @asset.AssetCode
                        </p>

                        <div class="row text-center g-2 mb-3">
                            <div class="col">
                                <div class="border rounded p-2">
                                    <small class="text-muted d-block">Danh mục</small>
                                    <strong class="small">@(asset.AssetCategory?.CategoryName ?? "N/A")</strong>
                                </div>
                            </div>
                            <div class="col">
                                <div class="border rounded p-2">
                                    <small class="text-muted d-block">Hãng</small>
                                    <strong class="small">@(asset.Brand?.BrandName ?? "N/A")</strong>
                                </div>
                            </div>
                        </div>

                        @if (asset.Configuration != null)
                        {
                            <div class="mb-3">
                                <h6 class="small text-muted mb-2"><i class="bi bi-gear"></i> Cấu hình</h6>
                                <div class="small">
                                    @if (!string.IsNullOrEmpty(asset.Configuration.CPU))
                                    {
                                        <div><strong>CPU:</strong> @asset.Configuration.CPU</div>
                                    }
                                    @if (!string.IsNullOrEmpty(asset.Configuration.RAM))
                                    {
                                        <div><strong>RAM:</strong> @asset.Configuration.RAM</div>
                                    }
                                    @if (!string.IsNullOrEmpty(asset.Configuration.SSD))
                                    {
                                        <div><strong>SSD:</strong> @asset.Configuration.SSD</div>
                                    }
                                </div>
                            </div>
                        }

                        @if (assignment != null)
                        {
                            <div class="border-top pt-2">
                                <small class="text-muted">
                                    <i class="bi bi-calendar-event"></i>
                                    Cấp phát: @assignment.AssignedDate.ToString("dd/MM/yyyy")
                                </small>
                                @if (!string.IsNullOrEmpty(assignment.Note))
                                {
                                    <div class="small text-muted mt-1">
                                        <i class="bi bi-chat-text"></i> @assignment.Note
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <div class="card-footer bg-light border-0">
                        <div class="d-flex justify-content-between align-items-center">
                            <small class="text-muted">
                                @if (assignment?.AssignmentReason != null)
                                {
                                    @switch (assignment.AssignmentReason)
                                    {
                                        case AssetAssignmentReason.NewEmployee:
                                            <span class="badge bg-info">Nhân viên mới</span>
                                            break;
                                        case AssetAssignmentReason.ProjectNeeds:
                                            <span class="badge bg-primary">Dự án</span>
                                            break;
                                        case AssetAssignmentReason.Replacement:
                                            <span class="badge bg-warning text-dark">Thay thế</span>
                                            break;
                                        case AssetAssignmentReason.Upgrade:
                                            <span class="badge bg-success">Nâng cấp</span>
                                            break;
                                        case AssetAssignmentReason.Temporary:
                                            <span class="badge bg-secondary">Tạm thời</span>
                                            break;
                                    }
                                }
                            </small>
                            <button type="button" class="btn btn-outline-primary btn-sm"
                                    onclick="showAssetDetails(@asset.AssetId)">
                                <i class="bi bi-eye"></i> Chi tiết
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<!-- Asset Details Modal -->
<div class="modal fade" id="assetDetailsModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" id="assetDetailsContent">
            <div class="modal-header">
                <h5 class="modal-title">Chi tiết tài sản</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-muted">
                Chọn tài sản để xem chi tiết.
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openAssetDetailsModal() {
            const modalElement = document.getElementById('assetDetailsModal');

            if (window.bootstrap && window.bootstrap.Modal) {
                const modal = window.bootstrap.Modal.getOrCreateInstance(modalElement);
                modal.show();
                return;
            }

            if (window.$ && typeof window.$.fn.modal === 'function') {
                window.$('#assetDetailsModal').modal('show');
            }
        }

        function setAssetDetailsError(message) {
            const content = document.getElementById('assetDetailsContent');
            content.innerHTML = `
                <div class="modal-header">
                    <h5 class="modal-title">Chi tiết tài sản</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-danger mb-0">${message}</div>
                </div>`;
        }

        async function showAssetDetails(assetId) {
            try {
                const response = await fetch(`/Asset/MyAssetDetails/${assetId}`, {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });

                if (!response.ok) {
                    if (response.status === 403) {
                        throw new Error('Bạn không có quyền xem chi tiết tài sản này.');
                    }
                    if (response.status === 404) {
                        throw new Error('Không tìm thấy thông tin tài sản.');
                    }
                    throw new Error('Không thể tải chi tiết tài sản lúc này.');
                }

                const data = await response.text();
                document.getElementById('assetDetailsContent').innerHTML = data;
                openAssetDetailsModal();
            } catch (error) {
                setAssetDetailsError(error.message || 'Đã xảy ra lỗi không xác định.');
                openAssetDetailsModal();
            }
        }

        // Auto-refresh every 5 minutes to show updated assignments
        setInterval(function() {
            location.reload();
        }, 300000);
    </script>
}