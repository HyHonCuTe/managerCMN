@model AttendanceImportViewModel
@{
    ViewData["Title"] = "Import chấm công";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h4 class="mb-0"><i class="bi bi-upload"></i> Import chấm công</h4>
        <small class="text-muted">Nhập dữ liệu chấm công từ file Excel</small>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
</div>

<div class="row g-3">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header bg-white fw-semibold">
                <i class="bi bi-file-earmark-spreadsheet text-primary"></i> Chọn file Excel
            </div>
            <div class="card-body">
                <form asp-action="Import" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="ExcelFile" class="form-label fw-semibold">File Excel (.xlsx, .xls)</label>
                        <input asp-for="ExcelFile" class="form-control" type="file" accept=".xlsx,.xls" />
                        <span asp-validation-for="ExcelFile" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-upload"></i> Import
                        </button>
                        <a asp-action="Index" class="btn btn-light">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card mb-3">
            <div class="card-header bg-white fw-semibold">
                <i class="bi bi-table text-primary"></i> Định dạng file
            </div>
            <div class="card-body">
                <p class="mb-2 small text-muted">File Excel cần có 2 cột với header ở dòng đầu tiên:</p>
                <table class="table table-sm table-bordered mb-3">
                    <thead class="table-light">
                        <tr>
                            <th>Cột</th>
                            <th>Tên</th>
                            <th>Ví dụ</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><strong>A</strong></td>
                            <td>UserID <small class="text-muted">(Mã chấm công)</small></td>
                            <td><code>574</code></td>
                        </tr>
                        <tr>
                            <td><strong>B</strong></td>
                            <td>Time <small class="text-muted">(Ngày giờ quẹt thẻ)</small></td>
                            <td><code>2026-03-16 08:56:20</code></td>
                        </tr>
                    </tbody>
                </table>
                <div class="bg-light rounded p-2 small">
                    <div class="fw-semibold mb-1"><i class="bi bi-file-spreadsheet text-success"></i> Ví dụ dữ liệu:</div>
                    <table class="table table-sm table-borderless mb-0" style="font-family: monospace; font-size: 0.8rem">
                        <tr class="border-bottom"><td>UserID</td><td>Time</td></tr>
                        <tr><td>574</td><td>2026-03-16 08:56:20</td></tr>
                        <tr><td>602</td><td>2026-03-16 10:02:40</td></tr>
                        <tr><td>574</td><td>2026-03-16 17:30:15</td></tr>
                    </table>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header bg-white fw-semibold">
                <i class="bi bi-lightbulb text-warning"></i> Lưu ý
            </div>
            <div class="card-body">
                <ul class="small mb-0">
                    <li class="mb-1"><strong>UserID</strong> phải trùng với <strong>Mã chấm công</strong> (AttendanceCode) của nhân viên trong hệ thống.</li>
                    <li class="mb-1">Hệ thống tự động nhóm theo ngày: lần quẹt <strong>sớm nhất</strong> = Check-in, <strong>muộn nhất</strong> = Check-out.</li>
                    <li class="mb-1">Nếu nhân viên đã có dữ liệu chấm công ngày đó, dòng sẽ bị <strong>bỏ qua</strong> (không ghi đè).</li>
                    <li>Trễ giờ được tính khi Check-in sau <strong>8:30</strong>.</li>
                </ul>
            </div>
        </div>
    </div>
</div>
