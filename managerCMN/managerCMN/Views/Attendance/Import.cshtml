@model AttendanceImportViewModel
@{
    ViewData["Title"] = "Import chấm công";
}

<div class="card">
    <div class="card-header"><i class="bi bi-upload"></i> Import chấm công từ Excel</div>
    <div class="card-body">
        <form asp-action="Import" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="ExcelFile" class="form-label">Chọn file Excel</label>
                <input asp-for="ExcelFile" class="form-control" type="file" accept=".xlsx,.xls" />
                <span asp-validation-for="ExcelFile" class="text-danger"></span>
            </div>

            <div class="alert alert-info">
                <h6><i class="bi bi-info-circle"></i> &#272;&#7883;nh d&#7841;ng file (xu&#7845;t t&#7915; m&#225;y ch&#7845;m c&#244;ng):</h6>
                <ul class="mb-0">
                    <li><strong>C&#7897;t A:</strong> Department (t&#234;n c&#244;ng ty/b&#7897; ph&#7853;n)</li>
                    <li><strong>C&#7897;t B:</strong> Name (t&#234;n nh&#226;n vi&#234;n)</li>
                    <li><strong>C&#7897;t C:</strong> No. (m&#227; ch&#7845;m c&#244;ng - t&#432;&#417;ng &#7913;ng AttendanceCode)</li>
                    <li><strong>C&#7897;t D:</strong> Date/Time (ng&#224;y gi&#7901; qu&#7865;t th&#7867;)</li>
                    <li><strong>C&#7897;t E-K:</strong> C&#225;c c&#7897;t kh&#225;c (Status, Location ID, ID Number, Workcode, VerifyCode, CardNo) - b&#7887; qua</li>
                </ul>
                <hr class="my-2" />
                <small class="text-muted">
                    <i class="bi bi-lightbulb"></i> H&#7879; th&#7889;ng s&#7869; t&#7921; &#273;&#7897;ng nh&#243;m c&#225;c l&#7847;n qu&#7865;t th&#7867; theo ng&#224;y, l&#7845;y l&#7847;n s&#7899;m nh&#7845;t l&#224;m check-in v&#224; mu&#7897;n nh&#7845;t l&#224;m check-out.
                    N&#7871;u nh&#226;n vi&#234;n &#273;&#227; c&#243; d&#7919; li&#7879;u ch&#7845;m c&#244;ng ng&#224;y &#273;&#243;, d&#242;ng s&#7869; b&#7883; b&#7887; qua.
                </small>
            </div>

            <button type="submit" class="btn btn-primary"><i class="bi bi-upload"></i> Import</button>
            <a asp-action="Index" class="btn btn-secondary">Hủy</a>
        </form>
    </div>
</div>
