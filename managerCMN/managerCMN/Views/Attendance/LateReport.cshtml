@model IEnumerable<Attendance>
@{
    ViewData["Title"] = "Báo cáo đi muộn";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-exclamation-triangle text-warning"></i> Báo cáo đi muộn - Tháng @ViewBag.Month/@ViewBag.Year</h4>
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
</div>

<div class="card">
    <div class="card-body">
        <table class="table table-hover data-table">
            <thead class="table-light">
                <tr><th>Nhân viên</th><th>Ngày</th><th>Check-in</th><th>Ghi chú</th></tr>
            </thead>
            <tbody>
                @foreach (var att in Model)
                {
                <tr>
                    <td>@att.Employee?.FullName</td>
                    <td>@att.Date.ToString("dd/MM/yyyy")</td>
                    <td>@att.CheckIn?.ToString("HH\\:mm")</td>
                    <td>@att.Note</td>
                </tr>
                }
            </tbody>
        </table>
    </div>
</div>
