@model IEnumerable<AttendanceSummaryViewModel>
@{
    ViewData["Title"] = "Danh sách chấm công tổng";
    var year = ViewBag.Year;
    var month = ViewBag.Month;
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle me-1"></i>
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Info"] != null)
{
    <div class="alert alert-info alert-dismissible fade show">
        <i class="bi bi-info-circle me-1"></i>
        @TempData["Info"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-triangle me-1"></i>
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container-fluid mt-4">
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h4 class="mb-0"><i class="bi bi-list-check"></i> Danh sách chấm công tổng</h4>
            <div class="d-flex gap-2">
                <form method="get" class="d-flex gap-2">
                    <select name="month" class="form-select form-select-sm">
                        @for (int i = 1; i <= 12; i++)
                        {
                            <option value="@i" selected="@(i == month)">Tháng @i</option>
                        }
                    </select>
                    <select name="year" class="form-select form-select-sm">
                        @for (int y = DateTime.Now.Year - 2; y <= DateTime.Now.Year + 1; y++)
                        {
                            <option value="@y" selected="@(y == year)">@y</option>
                        }
                    </select>
                    <button type="submit" class="btn btn-primary btn-sm">
                        <i class="bi bi-funnel me-1"></i> Lọc
                    </button>
                </form>
                <a href="@Url.Action("ExportToExcel", new { year, month })" class="btn btn-success btn-sm">
                    <i class="bi bi-file-earmark-excel"></i> Xuất Excel
                </a>
                @if (User.IsInRole("Admin"))
                {
                    <button type="button" class="btn btn-warning btn-sm" data-bs-toggle="modal" data-bs-target="#updateLateMinutesModal">
                        <i class="bi bi-arrow-clockwise"></i> Cập nhật phút muộn
                    </button>
                    <button type="button" class="btn btn-danger btn-sm" data-bs-toggle="modal" data-bs-target="#fixDuplicateCheckInOutModal">
                        <i class="bi bi-tools"></i> Sửa CheckIn=CheckOut
                    </button>
                }
            </div>
        </div>
        <div class="card-body">
            <table class="table table-bordered table-hover table-sm" id="summaryTable">
                <thead class="table-light">
                    <tr>
                        <th style="width: 50px;">#</th>
                        <th>Mã NV</th>
                        <th>Họ tên</th>
                        <th>Phòng ban</th>
                        <th>Tổng công</th>
                        <th>Đơn có phép</th>
                        <th>Đơn không phép</th>
                        <th>Tổng phút đi muộn</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int index = 1;
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center">@index</td>
                            <td>@item.EmployeeCode</td>
                            <td>@item.FullName</td>
                            <td>@item.DepartmentName</td>
                            <td class="text-center">
                                <span class="badge bg-primary">@item.TotalCong</span>
                            </td>
                            <td class="text-center">
                                @if (item.DonCoPhep > 0)
                                {
                                    <span class="badge bg-success">@item.DonCoPhep</span>
                                }
                                else
                                {
                                    <span class="text-muted">0</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (item.DonKhongPhep > 0)
                                {
                                    <span class="badge bg-warning">@item.DonKhongPhep</span>
                                }
                                else
                                {
                                    <span class="text-muted">0</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (item.LateMinutes > 0)
                                {
                                    @if (item.LateMinutes >= 60)
                                    {
                                        var hours = item.LateMinutes / 60;
                                        var minutes = item.LateMinutes % 60;
                                        <span class="badge bg-danger">@hours giờ @minutes phút</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">@item.LateMinutes phút</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">0</span>
                                }
                            </td>
                            <td class="text-center">
                                <a href="@Url.Action("Index", new { employeeId = item.EmployeeId, year, month })" 
                                   class="btn btn-sm btn-outline-primary" title="Xem chi tiết">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                        index++;
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (User.IsInRole("Admin"))
{
    <!-- Update Late Minutes Modal -->
    <div class="modal fade" id="updateLateMinutesModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <form asp-action="UpdateLateMinutes" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-header bg-warning text-dark">
                        <h5 class="modal-title">
                            <i class="bi bi-arrow-clockwise"></i> Cập nhật phút đi muộn
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="alert alert-info border-0 mb-3">
                            <i class="bi bi-info-circle"></i>
                            <strong>Chức năng này sẽ:</strong>
                            <ul class="mt-2 mb-0">
                                <li>Tính toán phút đi muộn cho các bản ghi cũ</li>
                                <li>Chỉ cập nhật các bản ghi có <code>IsLate = true</code> nhưng <code>LateMinutes = 0</code></li>
                                <li>Dựa trên thời gian CheckIn so với 8:30 AM</li>
                            </ul>
                        </div>
                        <div class="alert alert-warning border-0 mb-0">
                            <i class="bi bi-exclamation-triangle"></i>
                            <strong>Lưu ý:</strong> Thao tác này sẽ cập nhật database và không thể hoàn tác.
                        </div>
                    </div>
                    <div class="modal-footer border-0">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-warning">
                            <i class="bi bi-arrow-clockwise"></i> Cập nhật
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Fix Duplicate CheckIn/CheckOut Modal -->
    <div class="modal fade" id="fixDuplicateCheckInOutModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <form asp-action="FixDuplicateCheckInOut" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-header bg-danger text-white">
                        <h5 class="modal-title">
                            <i class="bi bi-tools"></i> Sửa lỗi CheckIn = CheckOut
                        </h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="alert alert-info border-0 mb-3">
                            <i class="bi bi-info-circle"></i>
                            <strong>Chức năng này sẽ:</strong>
                            <ul class="mt-2 mb-0">
                                <li>Tìm các bản ghi có CheckIn = CheckOut (dữ liệu sai)</li>
                                <li>Tính lại CheckIn (lần chấm đầu) và CheckOut (lần chấm cuối) từ PunchRecords</li>
                                <li>Cập nhật lại WorkingHours và LateMinutes</li>
                                <li>Chỉ cập nhật nếu có nhiều hơn 1 lần chấm và thời gian khác nhau</li>
                            </ul>
                        </div>
                        <div class="alert alert-warning border-0 mb-0">
                            <i class="bi bi-exclamation-triangle"></i>
                            <strong>Lưu ý:</strong> Thao tác này sẽ cập nhật database và không thể hoàn tác.
                        </div>
                    </div>
                    <div class="modal-footer border-0">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-tools"></i> Sửa lỗi
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#summaryTable').DataTable({
                "pageLength": 25,
                "language": {
                    "url": "https://cdn.datatables.net/plug-ins/1.13.6/i18n/vi.json"
                },
                "order": [[2, 'asc']] // Sort by name
            });
        });
    </script>
}
