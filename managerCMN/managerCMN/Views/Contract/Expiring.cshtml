@model IEnumerable<Contract>
@{
    ViewData["Title"] = "Hợp đồng sắp hết hạn";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-exclamation-triangle text-warning"></i> Hợp đồng sắp hết hạn (30 ngày)</h4>
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
</div>

<div class="card">
    <div class="card-body">
        <table class="table table-hover data-table">
            <thead class="table-light">
                <tr>
                    <th>Nhân viên</th>
                    <th>Loại HĐ</th>
                    <th>Ngày kết thúc</th>
                    <th>Còn lại</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    var daysLeft = (c.EndDate!.Value - DateTime.UtcNow).Days;
                <tr class="@(daysLeft < 0 ? "table-danger" : daysLeft < 7 ? "table-warning" : "")">
                    <td>@c.Employee?.FullName</td>
                    <td>@c.ContractType</td>
                    <td>@c.EndDate?.ToString("dd/MM/yyyy")</td>
                    <td>
                        @if (daysLeft < 0) { <span class="text-danger fw-bold">Đã hết hạn @Math.Abs(daysLeft) ngày</span> }
                        else { <span>@daysLeft ngày</span> }
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@c.ContractId" class="btn btn-sm btn-outline-primary">Gia hạn</a>
                    </td>
                </tr>
                }
            </tbody>
        </table>
    </div>
</div>
