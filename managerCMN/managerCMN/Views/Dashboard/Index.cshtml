@model DashboardViewModel
@using managerCMN.Models.Enums
@{
    ViewData["Title"] = "Dashboard";
    var today = DateTime.Today;
    var p = Model.Personal;

    string ContractTypeText(ContractType ct) => ct switch
    {
        ContractType.Probation  => "Thử việc",
        ContractType.FixedTerm  => "Xác định thời hạn",
        ContractType.Indefinite => "Không xác định thời hạn",
        ContractType.Seasonal   => "Thời vụ",
        _                       => ct.ToString()
    };

    (string css, string label) ContractBadge(Contract c)
    {
        var near = c.EndDate.HasValue && c.EndDate.Value.Date <= today.AddDays(30);
        if (near) return ("bg-warning text-dark", "Sắp hết hạn");
        return c.Status switch
        {
            ContractStatus.Active     => ("bg-success", "Đang hiệu lực"),
            ContractStatus.Renewed    => ("bg-info text-dark", "Đã gia hạn"),
            ContractStatus.Expired    => ("bg-danger", "Hết hạn"),
            ContractStatus.Terminated => ("bg-secondary", "Thanh lý"),
            _                         => ("bg-light text-dark", c.Status.ToString())
        };
    }
}

@* ──────────────────────── PERSONAL user dashboard ──────────────────────── *@
@if (p != null)
{
    var contract   = p.CurrentContract;
    var nearExpiry = contract != null && contract.EndDate.HasValue && contract.EndDate.Value.Date <= today.AddDays(30);
    var daysLeft   = contract?.EndDate.HasValue == true ? (contract.EndDate.Value.Date - today).Days : (int?)null;
    var leave      = p.LeaveSummary;

    <!-- Welcome banner -->
    <div class="card mb-4 border-0 bg-primary bg-gradient text-white">
        <div class="card-body py-3 px-4">
            <div class="d-flex align-items-center gap-3">
                <div class="rounded-circle bg-white bg-opacity-25 d-flex align-items-center justify-content-center flex-shrink-0" style="width:56px;height:56px;">
                    <i class="bi bi-person-fill fs-3 text-white"></i>
                </div>
                <div>
                    <h5 class="mb-0 fw-semibold">Xin chào, @p.FullName!</h5>
                    <div class="opacity-75 small">@p.PositionName &nbsp;·&nbsp; @p.DepartmentName &nbsp;·&nbsp; @today.ToString("dd/MM/yyyy")</div>
                </div>
            </div>
        </div>
    </div>

    @if (nearExpiry && contract != null)
    {
        <div class="alert alert-warning d-flex align-items-start gap-2 mb-4">
            <i class="bi bi-exclamation-triangle-fill fs-5 mt-1 flex-shrink-0"></i>
            <div>
                <strong>Hợp đồng sắp hết hạn!</strong>
                Còn <strong>@daysLeft ngày</strong> (@contract.EndDate!.Value.ToString("dd/MM/yyyy")).
                Liên hệ quản lý để gia hạn kịp thời.
            </div>
        </div>
    }

    <!-- 5 stat cards -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3 col-lg-2">
            <div class="card text-center h-100 border-success">
                <div class="card-body py-3">
                    <div class="text-muted small"><i class="bi bi-calendar-check text-success"></i> Phép còn lại</div>
                    <div class="fs-2 fw-bold text-success">@(leave?.TotalRemaining.ToString("0.#") ?? "—")</div>
                    <div class="text-muted small">ngày</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3 col-lg-2">
            <div class="card text-center h-100 border-warning">
                <div class="card-body py-3">
                    <div class="text-muted small"><i class="bi bi-calendar-x text-warning"></i> Đã nghỉ tháng này</div>
                    <div class="fs-2 fw-bold text-warning">@(leave?.PaidLeaveTaken.ToString("0.#") ?? "—")</div>
                    <div class="text-muted small">ngày</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3 col-lg-2">
            <div class="card text-center h-100 border-primary">
                <div class="card-body py-3">
                    <div class="text-muted small"><i class="bi bi-person-check text-primary"></i> Đi làm tháng @today.Month</div>
                    <div class="fs-2 fw-bold text-primary">@p.AttendanceDaysWorked</div>
                    <div class="text-muted small">ngày</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3 col-lg-2">
            <div class="card text-center h-100 @(p.AttendanceLateCount > 0 ? "border-danger" : "border-secondary")">
                <div class="card-body py-3">
                    <div class="text-muted small">
                        <i class="bi bi-clock-history @(p.AttendanceLateCount > 0 ? "text-danger" : "text-secondary")"></i> Đi trễ tháng @today.Month
                    </div>
                    <div class="fs-2 fw-bold @(p.AttendanceLateCount > 0 ? "text-danger" : "text-secondary")">@p.AttendanceLateCount</div>
                    <div class="text-muted small">lần</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3 col-lg-2">
            <div class="card text-center h-100 border-info">
                <div class="card-body py-3">
                    <div class="text-muted small"><i class="bi bi-laptop text-info"></i> Tài sản được cấp</div>
                    <div class="fs-2 fw-bold text-info">@p.AssignedAssetsCount</div>
                    <div class="text-muted small">thiết bị</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Contract + Quick actions -->
    <div class="row g-3">
        <div class="col-md-7">
            <div class="card h-100 @(nearExpiry ? "border-warning" : "")">
                <div class="card-header fw-semibold @(nearExpiry ? "bg-warning bg-opacity-10" : "")">
                    <i class="bi bi-file-earmark-text me-1"></i> Hợp đồng lao động
                </div>
                <div class="card-body">
                @if (contract == null)
                {
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-exclamation-circle fs-3 d-block mb-2"></i>
                        Chưa có hợp đồng đang hiệu lực.
                    </div>
                }
                else
                {
                    var (css, label) = ContractBadge(contract);
                    <table class="table table-borderless table-sm mb-0">
                        <tr>
                            <td class="fw-semibold text-muted pe-3" style="width:140px">Loại HĐ</td>
                            <td>@ContractTypeText(contract.ContractType)</td>
                        </tr>
                        <tr>
                            <td class="fw-semibold text-muted pe-3">Ngày bắt đầu</td>
                            <td>@contract.StartDate.ToString("dd/MM/yyyy")</td>
                        </tr>
                        <tr>
                            <td class="fw-semibold text-muted pe-3">Ngày kết thúc</td>
                            <td>
                                @if (contract.EndDate.HasValue)
                                {
                                    @contract.EndDate.Value.ToString("dd/MM/yyyy")
                                    if (nearExpiry)
                                    {
                                        <span class="badge bg-warning text-dark ms-1">
                                            <i class="bi bi-clock"></i> @daysLeft ngày
                                        </span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">Không xác định thời hạn</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <td class="fw-semibold text-muted pe-3">Trạng thái</td>
                            <td><span class="badge @css">@label</span></td>
                        </tr>
                    </table>
                }
                </div>
            </div>
        </div>

        <div class="col-md-5 d-flex flex-column gap-3">
            <div class="card flex-grow-1">
                <div class="card-header fw-semibold"><i class="bi bi-lightning me-1"></i> Truy cập nhanh</div>
                <div class="card-body d-grid gap-2">
                    <a asp-controller="Request" asp-action="Create" class="btn btn-outline-success btn-sm">
                        <i class="bi bi-send-plus me-1"></i> Tạo đơn từ
                        @if (p.MyPendingRequests > 0)
                        {
                            <span class="badge bg-warning text-dark ms-1">@p.MyPendingRequests chờ duyệt</span>
                        }
                    </a>
                    <a asp-controller="Asset" asp-action="MyAssets" class="btn btn-outline-info btn-sm">
                        <i class="bi bi-laptop me-1"></i> Tài sản của tôi
                        @if (p.AssignedAssetsCount > 0)
                        {
                            <span class="badge bg-info ms-1">@p.AssignedAssetsCount</span>
                        }
                    </a>
                    <a asp-controller="Attendance" asp-action="Index" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-clock me-1"></i> Lịch sử chấm công
                    </a>
                    <a asp-controller="Profile" asp-action="Index" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-person-circle me-1"></i> Hồ sơ cá nhân
                    </a>
                </div>
            </div>

            @if (leave != null && leave.CarryForwardRemaining > 0)
            {
                <div class="alert alert-info small mb-0 py-2">
                    <i class="bi bi-info-circle me-1"></i>
                    Còn <strong>@leave.CarryForwardRemaining</strong> ngày phép bảo lưu — hết hạn <strong>@leave.CarryForwardExpiryDate?.ToString("dd/MM/yyyy")</strong>.
                </div>
            }
        </div>
    </div>
}
else
{
@* ──────────────────────── ADMIN / MANAGER dashboard ──────────────────────── *@

<div class="row g-3 mb-4">
    <div class="col-md-3 col-sm-6">
        <div class="card stat-card primary">
            <div class="card-body">
                <div class="stat-label">Nhân viên</div>
                <div class="stat-value text-primary">@Model.TotalEmployees</div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="card stat-card warning">
            <div class="card-body">
                <div class="stat-label">Yêu cầu chờ duyệt</div>
                <div class="stat-value text-warning">@Model.PendingRequests</div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="card stat-card danger">
            <div class="card-body">
                <div class="stat-label">Ticket đang mở</div>
                <div class="stat-value text-danger">@Model.ActiveTickets</div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="card stat-card info">
            <div class="card-body">
                <div class="stat-label">Tài sản</div>
                <div class="stat-value text-info">@Model.TotalAssets</div>
            </div>
        </div>
    </div>
</div>

@if (Model.ExpiringContracts?.Any() == true)
{
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-exclamation-triangle text-warning me-1"></i> Hợp đồng sắp hết hạn</span>
            <a asp-controller="Contract" asp-action="Index" class="btn btn-sm btn-outline-warning">Xem tất cả</a>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr><th>Nhân viên</th><th>Loại HĐ</th><th>Ngày hết hạn</th><th>Còn lại</th></tr>
                </thead>
                <tbody>
                    @foreach (var c in Model.ExpiringContracts)
                    {
                        var days = c.EndDate.HasValue ? (c.EndDate.Value.Date - today).Days : (int?)null;
                    <tr class="@(days <= 7 ? "table-danger" : "table-warning")">
                        <td>@c.Employee?.FullName</td>
                        <td>@ContractTypeText(c.ContractType)</td>
                        <td>@c.EndDate?.ToString("dd/MM/yyyy")</td>
                        <td>
                            @if (days.HasValue)
                            {
                                <span class="badge @(days <= 7 ? "bg-danger" : "bg-warning text-dark")">@days ngày</span>
                            }
                        </td>
                    </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="row g-3">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header"><i class="bi bi-lightning"></i> Truy cập nhanh</div>
            <div class="card-body">
                <div class="row g-2">
                    <div class="col-6"><a asp-controller="Employee" asp-action="Create" class="btn btn-outline-primary w-100"><i class="bi bi-person-plus"></i> Thêm nhân viên</a></div>
                    <div class="col-6"><a asp-controller="Request" asp-action="Create" class="btn btn-outline-success w-100"><i class="bi bi-send-plus"></i> Tạo đơn từ</a></div>
                    <div class="col-6"><a asp-controller="Leave" asp-action="Create" class="btn btn-outline-info w-100"><i class="bi bi-calendar-plus"></i> Xin Nghỉ</a></div>
                    <div class="col-6"><a asp-controller="Ticket" asp-action="Create" class="btn btn-outline-warning w-100"><i class="bi bi-ticket-plus"></i> Tạo ticket</a></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header"><i class="bi bi-bar-chart"></i> Thống kê</div>
            <div class="card-body">
                <canvas id="statsChart" height="200"></canvas>
            </div>
        </div>
    </div>
</div>


} @* end admin/manager *@

@section Scripts {
@if (Model.Personal == null)
{
<script>
    var ctx = document.getElementById('statsChart').getContext('2d');
    new Chart(ctx, {
        type: 'doughnut',
        data: {
            labels: ['Nhân viên', 'Yêu cầu chờ', 'Ticket mở', 'Tài sản'],
            datasets: [{
                data: [@Model.TotalEmployees, @Model.PendingRequests, @Model.ActiveTickets, @Model.TotalAssets],
                backgroundColor: ['#0d6efd', '#ffc107', '#dc3545', '#0dcaf0']
            }]
        },
        options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
    });
</script>
}
}
