@model Department
@{
    ViewData["Title"] = "Chi tiết Phòng ban";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-diagram-3"></i> @Model.DepartmentName</h4>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.DepartmentId" class="btn btn-warning"><i class="bi bi-pencil"></i> Sửa</a>
        <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">Thông tin</div>
            <div class="card-body">
                <p><strong>Tên:</strong> @Model.DepartmentName</p>
                <p><strong>Trưởng phòng:</strong> @(Model.Manager?.FullName ?? "Chưa có")</p>
                <p><strong>Mô tả:</strong> @Model.Description</p>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">Nhân viên trong phòng (@(Model.Employees?.Count ?? 0))</div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr><th>Mã NV</th><th>Họ tên</th><th>Chức vụ</th><th>Trạng thái</th></tr>
                    </thead>
                    <tbody>
                        @if (Model.Employees != null)
                        {
                            @foreach (var emp in Model.Employees)
                            {
                            <tr>
                                <td>@emp.EmployeeCode</td>
                                <td><a asp-controller="Employee" asp-action="Details" asp-route-id="@emp.EmployeeId">@emp.FullName</a></td>
                                <td>@emp.Position</td>
                                <td><span class="badge bg-@(emp.Status == EmployeeStatus.Active ? "success" : "secondary")">@emp.Status</span></td>
                            </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
