@model IEnumerable<Department>
@{
    ViewData["Title"] = "Quản lý Phòng ban";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-diagram-3"></i> Danh sách Phòng ban</h4>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Thêm phòng ban</a>
</div>

<div class="card">
    <div class="card-body">
        <table class="table table-hover data-table">
            <thead class="table-light">
                <tr>
                    <th>Tên phòng ban</th>
                    <th>Trưởng phòng</th>
                    <th>Mô tả</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var dept in Model)
                {
                <tr>
                    <td><strong>@dept.DepartmentName</strong></td>
                    <td>@dept.Manager?.FullName</td>
                    <td>@dept.Description</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@dept.DepartmentId" class="btn btn-sm btn-outline-info"><i class="bi bi-eye"></i></a>
                        <a asp-action="Edit" asp-route-id="@dept.DepartmentId" class="btn btn-sm btn-outline-warning"><i class="bi bi-pencil"></i></a>
                        <form asp-action="Delete" asp-route-id="@dept.DepartmentId" method="post" class="d-inline" onsubmit="return confirm('Bạn chắc chắn muốn xóa?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                        </form>
                    </td>
                </tr>
                }
            </tbody>
        </table>
    </div>
</div>
