@model Employee
@{
    ViewData["Title"] = "Chi tiết Nhân viên";
    var leaveSummary = ViewBag.LeaveSummary as LeaveBalanceSummaryViewModel;
    var leaveRequests = ViewBag.LeaveRequests as List<LeaveRequest> ?? new List<LeaveRequest>();

    var today = DateTimeHelper.VietnamToday;
    var currentContract = Model.Contracts
        .Where(c => c.Status == ContractStatus.Active || c.Status == ContractStatus.Renewed)
        .OrderByDescending(c => c.StartDate)
        .FirstOrDefault();

    // Near expiry: end date is in the future but within 30 days
    bool IsNearExpiry(Contract c) =>
        c.EndDate.HasValue
        && c.EndDate.Value.Date >= today
        && c.EndDate.Value.Date <= today.AddDays(30);

    // Actually expired: end date has passed
    bool IsExpired(Contract c) =>
        c.EndDate.HasValue && c.EndDate.Value.Date < today;

    string ContractTypeText(ContractType ct) => ct switch
    {
        ContractType.Probation  => "Thử việc",
        ContractType.FixedTerm  => "Xác định thời hạn",
        ContractType.Indefinite => "Không xác định thời hạn",
        ContractType.Seasonal   => "Thời vụ",
        _                       => ct.ToString()
    };

    (string css, string label) ContractStatusDisplay(Contract c)
    {
        // Check if actually expired first (end date has passed)
        if (IsExpired(c)) return ("bg-danger", "Hết hạn");
        if (IsNearExpiry(c)) return ("bg-warning text-dark", "Sắp hết hạn");
        return c.Status switch
        {
            ContractStatus.Active     => ("bg-success", "Đang hiệu lực"),
            ContractStatus.Renewed    => ("bg-info text-dark", "Đã gia hạn"),
            ContractStatus.Expired    => ("bg-danger", "Hết hạn"),
            ContractStatus.Terminated => ("bg-secondary", "Thanh lý"),
            _                         => ("bg-light text-dark", c.Status.ToString())
        };
    }
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-person-badge"></i> @Model.FullName</h4>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.EmployeeId" class="btn btn-warning"><i class="bi bi-pencil"></i> Sửa</a>
        <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
    </div>
</div>

<div class="row g-3">
    <!-- Left Col -->
    <div class="col-lg-8">
        <div class="card mb-3">
            <div class="card-header"><i class="bi bi-person"></i> Thông tin cá nhân</div>
            <div class="card-body">
                <div class="row g-2">
                    <div class="col-sm-4"><strong>Mã NV:</strong></div><div class="col-sm-8">@Model.EmployeeCode</div>
                    <div class="col-sm-4"><strong>Họ tên:</strong></div><div class="col-sm-8">@Model.FullName</div>
                    <div class="col-sm-4"><strong>Ngày sinh:</strong></div><div class="col-sm-8">@Model.DateOfBirth?.ToString("dd/MM/yyyy")</div>
                    <div class="col-sm-4"><strong>Giới tính:</strong></div><div class="col-sm-8">@(Model.Gender == Gender.Male ? "Nam" : Model.Gender == Gender.Female ? "Nữ" : "Khác")</div>
                    <div class="col-sm-4"><strong>Dân tộc:</strong></div><div class="col-sm-8">@(Model.Ethnicity ?? "—")</div>
                    <div class="col-sm-4"><strong>Quốc tịch:</strong></div><div class="col-sm-8">@(Model.Nationality ?? "—")</div>
                    <div class="col-sm-4"><strong>Email:</strong></div><div class="col-sm-8"><a href="mailto:@Model.Email">@Model.Email</a></div>
                    <div class="col-sm-4"><strong>Điện thoại:</strong></div><div class="col-sm-8">@Model.Phone</div>
                    <div class="col-sm-4"><strong>Bằng cấp:</strong></div><div class="col-sm-8">@(Model.Qualifications ?? "—")</div>
                </div>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header"><i class="bi bi-card-text"></i> CCCD</div>
            <div class="card-body">
                <div class="row g-2">
                    <div class="col-sm-4"><strong>Số CCCD:</strong></div><div class="col-sm-8">@(Model.IdCardNumber ?? "—")</div>
                    <div class="col-sm-4"><strong>Ngày cấp:</strong></div><div class="col-sm-8">@(Model.IdCardIssueDate?.ToString("dd/MM/yyyy") ?? "—")</div>
                    <div class="col-sm-4"><strong>Nơi cấp:</strong></div><div class="col-sm-8">@(Model.IdCardIssuePlace ?? "—")</div>
                </div>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header"><i class="bi bi-geo-alt"></i> Địa chỉ</div>
            <div class="card-body">
                <div class="row g-2">
                    <div class="col-sm-4"><strong>Thường trú:</strong></div><div class="col-sm-8">@(Model.PermanentAddress ?? "—")</div>
                    <div class="col-sm-4"><strong>Liên hệ:</strong></div><div class="col-sm-8">@(Model.TemporaryAddress ?? "—")</div>
                </div>
            </div>
        </div>

        <!-- Emergency Contacts -->
        <div class="card">
            <div class="card-header"><i class="bi bi-telephone"></i> Liên hệ người thân</div>
            <div class="card-body">
                @if (Model.EmergencyContacts?.Any() == true)
                {
                    <table class="table table-sm table-bordered mb-0">
                        <thead class="table-light">
                            <tr><th>Họ tên</th><th>Mối quan hệ</th><th>SĐT</th><th>Địa chỉ</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var c in Model.EmergencyContacts)
                            {
                                <tr><td>@c.FullName</td><td>@c.Relationship</td><td>@c.Phone</td><td>@c.Address</td></tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted mb-0">Chưa có thông tin liên hệ người thân.</p>
                }
            </div>
        </div>
    </div>

    <!-- Right Col -->
    <div class="col-lg-4">
        <div class="card mb-3">
            <div class="card-header"><i class="bi bi-briefcase"></i> Thông tin công việc</div>
            <div class="card-body">
                <p><strong>Phòng ban:</strong> @(Model.Department?.DepartmentName ?? "—")</p>
                <p><strong>Chức vụ:</strong> @(Model.JobTitle?.JobTitleName ?? "—")</p>
                <p><strong>Vị trí:</strong> @(Model.Position?.PositionName ?? "—")</p>
                <p><strong>Ngày vào làm:</strong> @Model.StartWorkingDate?.ToString("dd/MM/yyyy")</p>
                <p><strong>Chấm công:</strong> @(Model.AttendanceName) @(Model.AttendanceCode != null ? $"(#{Model.AttendanceCode})" : "")</p>
                <p><strong>Trạng thái:</strong>
                    @switch (Model.Status)
                    {
                        case EmployeeStatus.Active:
                            <span class="badge bg-success">Đang làm</span>
                            break;
                        case EmployeeStatus.OnLeave:
                            <span class="badge bg-info text-dark">Tạm nghỉ</span>
                            break;
                        case EmployeeStatus.Resigned:
                            <span class="badge bg-secondary">Đã nghỉ</span>
                            break;
                        case EmployeeStatus.Terminated:
                            <span class="badge bg-dark">Nghỉ việc</span>
                            break;
                    }
                </p>
                @if (Model.ResignationDate.HasValue)
                {
                    <p class="text-danger"><strong>Ngày thôi việc:</strong> @Model.ResignationDate.Value.ToString("dd/MM/yyyy")</p>
                    <p class="text-muted"><strong>Lý do:</strong> @(Model.ResignationReason ?? "—")</p>
                }
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header"><i class="bi bi-shield-check"></i> BHXH & Khác</div>
            <div class="card-body">
                <p><strong>Mã BHXH:</strong> @(Model.InsuranceCode ?? "—")</p>
                <p><strong>Số xe:</strong> @(Model.VehiclePlate ?? "—")</p>
                <p class="mb-0"><strong>Facebook:</strong>
                    @if (!string.IsNullOrEmpty(Model.FacebookUrl))
                    {
                        <a href="@Model.FacebookUrl" target="_blank" rel="noopener">@Model.FacebookUrl</a>
                    }
                    else { <span class="text-muted">—</span> }
                </p>
            </div>
        </div>

        <!-- Contracts Card with Full History -->
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-file-earmark-text"></i> Hợp đồng</span>
                <a asp-controller="Contract" asp-action="Create" asp-route-employeeId="@Model.EmployeeId"
                   class="btn btn-sm btn-outline-primary py-0"><i class="bi bi-plus-lg"></i> Thêm</a>
            </div>
            <div class="card-body">
            @if (!Model.Contracts.Any())
            {
                <p class="text-muted mb-0"><i class="bi bi-exclamation-circle me-1"></i>Chưa có hợp đồng.</p>
            }
            else
            {
                var sortedContracts = Model.Contracts
                    .OrderByDescending(c => c.StartDate)
                    .ThenByDescending(c => c.CreatedAt)
                    .ToList();

                <div class="contract-history">
                @foreach (var c in sortedContracts)
                {
                    var (css, label) = ContractStatusDisplay(c);
                    var isActive = c.Status == ContractStatus.Active || c.Status == ContractStatus.Renewed;
                    var nearExpiry = IsNearExpiry(c);
                    var daysLeft = c.EndDate.HasValue ? (c.EndDate.Value.Date - today).Days : (int?)null;
                    var cardBorder = isActive ? "border-success" : "";

                    <div class="contract-item card mb-2 @cardBorder" style="@(isActive ? "border-width: 2px;" : "")">
                        <div class="card-body p-3">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <h6 class="mb-1">
                                        <strong>@c.ContractNumber</strong>
                                        @if (isActive)
                                        {
                                            <span class="badge bg-success ms-1">Hiện tại</span>
                                        }
                                    </h6>
                                    <span class="text-muted small">@ContractTypeText(c.ContractType)</span>
                                </div>
                                <div class="text-end">
                                    <a asp-controller="Contract" asp-action="Edit" asp-route-id="@c.ContractId"
                                       class="btn btn-sm btn-outline-warning py-0"><i class="bi bi-pencil"></i></a>
                                </div>
                            </div>

                            @if (nearExpiry && isActive)
                            {
                                <div class="alert alert-warning py-1 px-2 small mb-2">
                                    <i class="bi bi-exclamation-triangle-fill me-1"></i>
                                    <strong>Sắp hết hạn!</strong> Còn <strong>@daysLeft ngày</strong>.
                                </div>
                            }

                            <div class="row g-1 small">
                                <div class="col-6"><strong>Bắt đầu:</strong> @c.StartDate.ToString("dd/MM/yyyy")</div>
                                <div class="col-6">
                                    <strong>Kết thúc:</strong>
                                    @if (c.EndDate.HasValue)
                                    {
                                        @c.EndDate.Value.ToString("dd/MM/yyyy")
                                    }
                                    else
                                    {
                                        <span class="text-muted">Không xác định</span>
                                    }
                                </div>
                                <div class="col-12 mt-1">
                                    <strong>Trạng thái:</strong> <span class="badge @css">@label</span>
                                    @if (!string.IsNullOrEmpty(c.FilePath))
                                    {
                                        <a href="@c.FilePath" target="_blank" class="btn btn-sm btn-outline-info py-0 ms-2">
                                            <i class="bi bi-download"></i> Tải file
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
                </div>

                <style>
                .contract-history .contract-item {
                    transition: box-shadow 0.2s;
                }
                .contract-history .contract-item:hover {
                    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
                }
                </style>
            }
            </div>
        </div>

        @if (leaveSummary != null)
        {
            <div class="card mb-3">
                <div class="card-header"><i class="bi bi-calendar-check"></i> Theo dõi phép</div>
                <div class="card-body">
                    <p><strong>Phép năm đã cấp:</strong> @leaveSummary.CurrentYearAllocated</p>
                    <p><strong>Đã dùng có lương:</strong> @leaveSummary.PaidLeaveTaken</p>
                    <p><strong>Nghỉ không phép:</strong> @leaveSummary.UnpaidLeaveTaken</p>
                    <p><strong>Phép bảo lưu còn lại:</strong> @leaveSummary.CarryForwardRemaining</p>
                    <p class="mb-0"><strong>Tổng còn dùng được:</strong> <span class="text-success fw-semibold">@leaveSummary.TotalRemaining</span></p>
                    <div class="small text-muted mt-2">Đã cấp @leaveSummary.GrantedQuarters/4 đợt phép. Phép bảo lưu hết hạn sau ngày @leaveSummary.CarryForwardExpiryDate?.ToString("dd/MM/yyyy").</div>
                </div>
            </div>
        }

        <div class="card mb-3">
            <div class="card-header"><i class="bi bi-wallet2"></i> Tài chính</div>
            <div class="card-body">
                <p><strong>MST:</strong> @(Model.TaxCode ?? "—")</p>
                <p><strong>Tài khoản:</strong> @(Model.BankAccount ?? "—")</p>
                <p class="mb-0"><strong>Ngân hàng:</strong> @(Model.BankName ?? "—")</p>
            </div>
        </div>

        @if (User.IsInRole("Admin") && leaveSummary != null)
        {
            <div class="card">
                <div class="card-header"><i class="bi bi-sliders"></i> Điều chỉnh phép</div>
                <div class="card-body">
                    <form asp-action="AdjustLeaveBalance" asp-route-id="@Model.EmployeeId" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-2">
                            <label class="form-label">Điều chỉnh phép năm hiện tại</label>
                            <input name="currentYearAdjustment" type="number" step="0.5" value="0" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Điều chỉnh phép bảo lưu</label>
                            <input name="carryForwardAdjustment" type="number" step="0.5" value="0" class="form-control" />
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Cập nhật số phép</button>
                    </form>
                </div>
            </div>
        }
    </div>
</div>

@if (leaveRequests.Any())
{
    <div class="card mt-3">
        <div class="card-header"><i class="bi bi-clock-history"></i> Lịch sử xin nghỉ gần đây</div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light">
                        <tr><th>Từ ngày</th><th>Đến ngày</th><th>Số ngày</th><th>Loại</th><th>Trạng thái</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var req in leaveRequests)
                        {
                            <tr>
                                <td>@req.StartDate.ToString("dd/MM/yyyy")</td>
                                <td>@req.EndDate.ToString("dd/MM/yyyy")</td>
                                <td>@req.TotalDays</td>
                                <td>@(req.PayType == LeavePayType.Paid ? "Có lương" : "Không phép")</td>
                                <td>@req.Status</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
