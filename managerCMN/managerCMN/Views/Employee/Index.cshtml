@model IEnumerable<Employee>
@{
    ViewData["Title"] = "Quản lý Nhân viên";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-people"></i> Danh sách Nhân viên</h4>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-person-plus"></i> Thêm nhân viên</a>
</div>

<div class="card">
    <div class="card-body">
        <table class="table table-hover data-table">
            <thead class="table-light">
                <tr>
                    <th>Mã NV</th>
                    <th>Họ tên</th>
                    <th>Email</th>
                    <th>Phòng ban</th>
                    <th>Chức vụ</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var emp in Model)
                {
                <tr>
                    <td><strong>@emp.EmployeeCode</strong></td>
                    <td>@emp.FullName</td>
                    <td>@emp.Email</td>
                    <td>@emp.Department?.DepartmentName</td>
                    <td>@emp.Position</td>
                    <td>
                        @switch (emp.Status)
                        {
                            case EmployeeStatus.Active:
                                <span class="badge bg-success">Đang làm</span>
                                break;
                            case EmployeeStatus.Resigned:
                                <span class="badge bg-secondary">Đã nghỉ</span>
                                break;
                            case EmployeeStatus.OnLeave:
                                <span class="badge bg-warning">Tạm nghỉ</span>
                                break;
                            default:
                                <span class="badge bg-dark">@emp.Status</span>
                                break;
                        }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@emp.EmployeeId" class="btn btn-sm btn-outline-info" title="Chi tiết"><i class="bi bi-eye"></i></a>
                        <a asp-action="Edit" asp-route-id="@emp.EmployeeId" class="btn btn-sm btn-outline-warning" title="Sửa"><i class="bi bi-pencil"></i></a>
                        <form asp-action="Delete" asp-route-id="@emp.EmployeeId" method="post" class="d-inline" onsubmit="return confirm('Bạn chắc chắn muốn xóa?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa"><i class="bi bi-trash"></i></button>
                        </form>
                    </td>
                </tr>
                }
            </tbody>
        </table>
    </div>
</div>
