@model IEnumerable<LeaveRequest>
@{
    ViewData["Title"] = "Xin nghỉ";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-calendar-check"></i> Nghỉ phép của tôi</h4>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Tạo đơn xin nghỉ </a>
</div>

@if (ViewBag.LeaveSummary is LeaveBalanceSummaryViewModel summary)
{
    <div class="row g-3 mb-3">
        <div class="col-md-3"><div class="card stat-card primary"><div class="card-body"><div class="stat-label">Phép năm đã cấp</div><div class="stat-value text-primary">@summary.CurrentYearAllocated</div></div></div></div>
        <div class="col-md-3"><div class="card stat-card success"><div class="card-body"><div class="stat-label">Đã dùng có lương</div><div class="stat-value text-success">@summary.PaidLeaveTaken</div></div></div></div>
        <div class="col-md-3"><div class="card stat-card info"><div class="card-body"><div class="stat-label">Còn lại</div><div class="stat-value text-info">@summary.TotalRemaining</div></div></div></div>
        <div class="col-md-3"><div class="card stat-card warning"><div class="card-body"><div class="stat-label">Bảo lưu năm trước</div><div class="stat-value text-warning">@summary.CarryForwardRemaining</div></div></div></div>
    </div>

    <div class="alert alert-light border mb-3">
        Đã cấp @summary.GrantedQuarters/4 đợt phép cho năm @summary.Year. Phần phép bảo lưu còn lại chỉ dùng đến hết ngày @summary.CarryForwardExpiryDate?.ToString("dd/MM/yyyy"). Nếu hết phép của đợt hiện tại thì đơn mới sẽ tự chuyển thành nghỉ không phép.
    </div>
}

<div class="card">
    <div class="card-body">
        <table class="table table-hover data-table">
            <thead class="table-light">
                <tr><th>Từ ngày</th><th>Đến ngày</th><th>Số ngày</th><th>Lý do</th><th>Loại</th><th>Trạng thái</th></tr>
            </thead>
            <tbody>
                @foreach (var req in Model)
                {
                <tr>
                    <td>@req.StartDate.ToString("dd/MM/yyyy")</td>
                    <td>@req.EndDate.ToString("dd/MM/yyyy")</td>
                    <td>@req.TotalDays</td>
                    <td>@req.Reason</td>
                    <td><span class="badge bg-@(req.PayType == LeavePayType.Paid ? "success" : "secondary")">@(req.PayType == LeavePayType.Paid ? "Có lương" : "Không lương")</span></td>
                    <td>
                        @switch (req.Status)
                        {
                            case RequestStatus.Pending: <span class="badge bg-warning">Chờ duyệt</span> break;
                            case RequestStatus.FullyApproved: <span class="badge bg-success">Đã duyệt</span> break;
                            case RequestStatus.Rejected: <span class="badge bg-danger">Từ chối</span> break;
                            default: <span class="badge bg-secondary">@req.Status</span> break;
                        }
                    </td>
                </tr>
                }
            </tbody>
        </table>
    </div>
</div>
