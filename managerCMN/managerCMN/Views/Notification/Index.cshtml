@model IEnumerable<Notification>
@{
    ViewData["Title"] = "Thông báo";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-bell"></i> Thông báo</h4>
    <form asp-action="MarkAllRead" method="post">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-outline-primary btn-sm"><i class="bi bi-check-all"></i> Đánh dấu tất cả đã đọc</button>
    </form>
</div>

<div class="list-group">
    @foreach (var n in Model)
    {
    <div class="list-group-item @(n.IsRead ? "" : "list-group-item-light border-start border-primary border-3")">
        <div class="d-flex justify-content-between align-items-start">
            <div>
                <h6 class="mb-1">@n.Title</h6>
                <p class="mb-1 text-muted">@n.Message</p>
                <small class="text-muted">@n.CreatedDate.ToString("dd/MM/yyyy HH:mm")</small>
            </div>
            @if (!n.IsRead)
            {
            <form asp-action="MarkAsRead" asp-route-id="@n.NotificationId" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm btn-outline-primary"><i class="bi bi-check"></i></button>
            </form>
            }
        </div>
    </div>
    }
</div>

@if (!Model.Any())
{
<div class="text-center text-muted py-5">
    <i class="bi bi-bell-slash fs-1"></i>
    <p>Không có thông báo nào.</p>
</div>
}
