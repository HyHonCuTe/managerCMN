@model Employee
@{
    ViewData["Title"] = "Cập nhật thông tin cá nhân";
}

<div class="mb-3">
    <h4><i class="bi bi-pencil-square"></i> Cập nhật thông tin cá nhân</h4>
    <small class="text-muted">Bạn chỉ có thể cập nhật các thông tin cá nhân. Chức vụ và Email do quản lý cập nhật.</small>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()

                    <!-- Readonly info -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label">Mã nhân viên</label>
                            <input value="@Model.EmployeeCode" class="form-control" readonly disabled />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Họ tên</label>
                            <input value="@Model.FullName" class="form-control" readonly disabled />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Email <i class="bi bi-lock text-muted" title="Do quản lý cập nhật"></i></label>
                            <input value="@Model.Email" class="form-control" readonly disabled />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Chức vụ <i class="bi bi-lock text-muted" title="Do quản lý cập nhật"></i></label>
                            <input value="@Model.Position?.PositionName" class="form-control" readonly disabled />
                        </div>
                    </div>

                    <hr/>

                    <!-- Editable fields -->
                    <h6 class="mb-3"><i class="bi bi-pencil"></i> Thông tin có thể cập nhật</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Số điện thoại</label>
                            <input name="Phone" value="@Model.Phone" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Mã số thuế</label>
                            <input name="TaxCode" value="@Model.TaxCode" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Số tài khoản ngân hàng</label>
                            <input name="BankAccount" value="@Model.BankAccount" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Ngân hàng</label>
                            <input name="BankName" value="@Model.BankName" class="form-control" />
                        </div>

                        <div class="col-12">
                            <label class="form-label">Địa chỉ thường trú</label>
                            <input name="PermanentAddress" value="@Model.PermanentAddress" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Địa chỉ tạm trú</label>
                            <input name="TemporaryAddress" value="@Model.TemporaryAddress" class="form-control" />
                        </div>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Lưu thay đổi</button>
                        <a asp-action="Index" class="btn btn-secondary">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-header"><i class="bi bi-info-circle"></i> Lưu ý</div>
            <div class="card-body">
                <ul class="mb-0 ps-3">
                    <li>Bạn <strong>không thể</strong> thay đổi Email và Chức vụ. Liên hệ quản lý hoặc admin để cập nhật.</li>
                    <li>Mọi thay đổi sẽ được <strong>thông báo</strong> đến quản lý và admin.</li>
                </ul>
            </div>
        </div>
    </div>
</div>
