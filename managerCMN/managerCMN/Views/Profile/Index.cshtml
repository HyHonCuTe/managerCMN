@model Employee?
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
}

<div class="mb-4">
    <h4 class="mb-0"><i class="bi bi-person-circle"></i> Hồ sơ cá nhân</h4>
</div>

@if (ViewBag.NoEmployee == true || Model == null)
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="bi bi-person-x text-muted" style="font-size: 4rem;"></i>
            <h5 class="mt-3">Tài khoản chưa liên kết với nhân viên</h5>
            <p class="text-muted">Vui lòng liên hệ quản lý hoặc admin để liên kết tài khoản với hồ sơ nhân viên.</p>
        </div>
    </div>
}
else
{

<div class="row g-4">
    <!-- Profile Card -->
    <div class="col-lg-4">
        <div class="card text-center">
            <div class="card-body py-4">
                <div class="rounded-circle bg-primary bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-3" style="width:80px;height:80px;">
                    <i class="bi bi-person-fill text-primary" style="font-size:2.5rem"></i>
                </div>
                <h5 class="mb-1">@Model.FullName</h5>
                <p class="text-muted mb-1">@Model.Position?.PositionName</p>
                <p class="text-muted mb-2"><small>@Model.Department?.DepartmentName</small></p>
                <span class="badge bg-@(Model.Status == EmployeeStatus.Active ? "success" : "secondary")">
                    @(Model.Status == EmployeeStatus.Active ? "Đang làm" : Model.Status.ToString())
                </span>
            </div>
            <ul class="list-group list-group-flush text-start">
                <li class="list-group-item"><i class="bi bi-envelope me-2 text-muted"></i>@Model.Email</li>
                <li class="list-group-item"><i class="bi bi-telephone me-2 text-muted"></i>@Model.Phone</li>
                <li class="list-group-item"><i class="bi bi-hash me-2 text-muted"></i>Mã NV: @Model.EmployeeCode</li>
                <li class="list-group-item"><i class="bi bi-fingerprint me-2 text-muted"></i>Mã CC: @Model.AttendanceCode</li>
                <li class="list-group-item"><i class="bi bi-calendar-event me-2 text-muted"></i>Vào làm: @Model.StartWorkingDate?.ToString("dd/MM/yyyy")</li>
            </ul>
            <div class="card-body">
                <a asp-action="Edit" class="btn btn-outline-primary w-100"><i class="bi bi-pencil"></i> Cập nhật thông tin</a>
            </div>
        </div>
    </div>

    <!-- Detail Cards -->
    <div class="col-lg-8">
        <div class="card mb-3">
            <div class="card-header"><i class="bi bi-person"></i> Thông tin cá nhân</div>
            <div class="card-body">
                <div class="row g-2">
                    <div class="col-sm-4"><strong>Họ tên:</strong></div><div class="col-sm-8">@Model.FullName</div>
                    <div class="col-sm-4"><strong>Ngày sinh:</strong></div><div class="col-sm-8">@Model.DateOfBirth?.ToString("dd/MM/yyyy")</div>
                    <div class="col-sm-4"><strong>Giới tính:</strong></div><div class="col-sm-8">@(Model.Gender == Gender.Male ? "Nam" : Model.Gender == Gender.Female ? "Nữ" : "Khác")</div>
                    <div class="col-sm-4"><strong>Email:</strong></div><div class="col-sm-8">@Model.Email</div>
                    <div class="col-sm-4"><strong>Số điện thoại:</strong></div><div class="col-sm-8">@Model.Phone</div>
                    <div class="col-sm-4"><strong>Địa chỉ thường trú:</strong></div><div class="col-sm-8">@Model.PermanentAddress</div>
                    <div class="col-sm-4"><strong>Địa chỉ tạm trú:</strong></div><div class="col-sm-8">@Model.TemporaryAddress</div>
                    <div class="col-sm-4"><strong>Bằng cấp:</strong></div><div class="col-sm-8">@Model.Qualifications</div>
                </div>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header"><i class="bi bi-briefcase"></i> Thông tin công việc</div>
            <div class="card-body">
                <div class="row g-2">
                    <div class="col-sm-4"><strong>Chức vụ:</strong></div><div class="col-sm-8">@(Model.Position?.PositionName ?? "Chưa có")</div>
                    <div class="col-sm-4"><strong>Phòng ban:</strong></div><div class="col-sm-8">@(Model.Department?.DepartmentName ?? "Chưa có")</div>
                    <div class="col-sm-4"><strong>Mã nhân viên:</strong></div><div class="col-sm-8">@Model.EmployeeCode</div>
                    <div class="col-sm-4"><strong>Mã chấm công:</strong></div><div class="col-sm-8">@Model.AttendanceCode</div>
                    <div class="col-sm-4"><strong>Ngày vào làm:</strong></div><div class="col-sm-8">@Model.StartWorkingDate?.ToString("dd/MM/yyyy")</div>
                    <div class="col-sm-4"><strong>Trạng thái:</strong></div>
                    <div class="col-sm-8">
                        <span class="badge bg-@(Model.Status == EmployeeStatus.Active ? "success" : "secondary")">
                            @(Model.Status == EmployeeStatus.Active ? "Đang làm" : Model.Status.ToString())
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header"><i class="bi bi-wallet2"></i> Tài chính</div>
            <div class="card-body">
                <div class="row g-2">
                    <div class="col-sm-4"><strong>Mã số thuế:</strong></div><div class="col-sm-8">@Model.TaxCode</div>
                    <div class="col-sm-4"><strong>Số tài khoản:</strong></div><div class="col-sm-8">@Model.BankAccount</div>
                    <div class="col-sm-4"><strong>Ngân hàng:</strong></div><div class="col-sm-8">@Model.BankName</div>
                </div>
            </div>
        </div>

        <!-- Emergency Contacts -->
        <div class="card">
            <div class="card-header"><i class="bi bi-telephone"></i> Liên hệ người thân</div>
            <div class="card-body">
                @if (Model.EmergencyContacts?.Any() == true)
                {
                    <table class="table table-sm table-bordered mb-0">
                        <thead class="table-light">
                            <tr><th>Họ tên</th><th>Mối quan hệ</th><th>SĐT</th><th>Địa chỉ</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var c in Model.EmergencyContacts)
                            {
                                <tr><td>@c.FullName</td><td>@c.Relationship</td><td>@c.Phone</td><td>@c.Address</td></tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted mb-0">Chưa có thông tin liên hệ người thân.</p>
                }
            </div>
        </div>
    </div>
</div>

} @* end else *@
