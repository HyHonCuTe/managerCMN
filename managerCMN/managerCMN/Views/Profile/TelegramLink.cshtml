@{
    ViewData["Title"] = "Kết nối Telegram";
    bool alreadyLinked = ViewBag.AlreadyLinked == true;
    bool botConfigured = ViewBag.BotConfigured == true;
    string? token = ViewBag.Token as string;
    string? deepLink = ViewBag.DeepLink as string;
    string? botUsername = ViewBag.BotUsername as string;
}

<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Hồ sơ cá nhân</a></li>
            <li class="breadcrumb-item active">Kết nối Telegram</li>
        </ol>
    </nav>
    <h4 class="mb-0"><i class="bi bi-telegram"></i> Kết nối Telegram</h4>
</div>

@if (!botConfigured)
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle me-2"></i>
        <strong>Chức năng Telegram chưa được cấu hình.</strong>
        Vui lòng liên hệ quản trị viên để thiết lập Telegram Bot.
    </div>
}
else if (alreadyLinked)
{
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-success">
                <div class="card-body text-center py-4">
                    <div class="mb-3">
                        <i class="bi bi-check-circle-fill text-success" style="font-size: 3rem;"></i>
                    </div>
                    <h5 class="text-success">Đã kết nối Telegram</h5>
                    <p class="text-muted">Tài khoản của bạn đang nhận thông báo qua Telegram.</p>

                    <form asp-action="TelegramUnlink" method="post" class="mt-3"
                          onsubmit="return confirm('Xác nhận hủy kết nối Telegram?')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger">
                            <i class="bi bi-x-circle me-1"></i> Hủy kết nối
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary ms-2">
                            <i class="bi bi-arrow-left me-1"></i> Quay lại
                        </a>
                    </form>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card">
                <div class="card-header">
                    <h6 class="mb-0"><i class="bi bi-link-45deg me-2"></i>Liên kết tài khoản với Telegram</h6>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-4">
                        Khi có thông báo (giao việc, duyệt đơn, cập nhật task, ...) hệ thống sẽ tự động gửi tin nhắn tới Telegram của bạn.
                    </p>

                    <div class="alert alert-primary d-flex align-items-center gap-3 mb-4">
                        <div class="bg-primary rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                             style="width:40px;height:40px;">
                            <i class="bi bi-key-fill text-white"></i>
                        </div>
                        <div>
                            <div class="fw-semibold mb-1">Mã kết nối của bạn</div>
                            <span class="font-monospace fs-4 fw-bold letter-spacing-1">@token</span>
                            <small class="d-block text-primary-emphasis mt-1">
                                <i class="bi bi-clock me-1"></i>Hết hạn sau 15 phút
                            </small>
                        </div>
                    </div>

                    <h6 class="mb-3">Hướng dẫn kết nối:</h6>
                    <div class="list-group list-group-flush mb-4">
                        <div class="list-group-item px-0">
                            <div class="d-flex gap-3">
                                <span class="badge bg-primary rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                                      style="width:28px;height:28px;">1</span>
                                <div>
                                    <strong>Mở Telegram</strong> và tìm bot
                                    <code>&#64;@(botUsername ?? "YourBot")</code>
                                </div>
                            </div>
                        </div>
                        <div class="list-group-item px-0">
                            <div class="d-flex gap-3">
                                <span class="badge bg-primary rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                                      style="width:28px;height:28px;">2</span>
                                <div>
                                    Gửi lệnh:
                                    <code class="fs-6">/start @token</code>
                                    <br>
                                    <small class="text-muted">hoặc nhấn nút bên dưới để mở trực tiếp</small>
                                </div>
                            </div>
                        </div>
                        <div class="list-group-item px-0">
                            <div class="d-flex gap-3">
                                <span class="badge bg-primary rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                                      style="width:28px;height:28px;">3</span>
                                <div>
                                    Bot phản hồi <strong>"✅ Kết nối thành công!"</strong> — xong!
                                </div>
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(deepLink))
                    {
                        <div class="d-grid gap-2 d-sm-flex">
                            <a href="@deepLink" target="_blank" class="btn btn-primary btn-lg">
                                <i class="bi bi-telegram me-2"></i> Mở Telegram để kết nối
                            </a>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                                <i class="bi bi-arrow-left me-1"></i> Quay lại
                            </a>
                        </div>
                    }

                    <hr class="my-4">
                    <div class="text-muted small">
                        <i class="bi bi-shield-check me-1"></i>
                        Mã kết nối chỉ dùng một lần và tự hủy sau 15 phút. Làm mới trang để lấy mã mới.
                    </div>
                </div>
            </div>
        </div>
    </div>
}
