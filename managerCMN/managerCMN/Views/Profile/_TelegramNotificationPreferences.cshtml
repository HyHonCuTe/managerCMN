@model TelegramLinkViewModel

@if (Model.ShowNotificationPreferences)
{
    <hr class="my-4">

    <div class="text-start">
        <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
            <div>
                <div class="fw-semibold fs-6">Loại thông báo Telegram</div>
                <small class="text-muted">
                    Tick chọn loại thông báo bạn muốn nhận. Riêng task và ticket luôn bật, không thể tắt.
                </small>
            </div>
        </div>

        <form asp-action="TelegramUpdatePreferences" method="post" class="mt-3">
            @Html.AntiForgeryToken()

            <div class="vstack gap-3">
                @foreach (var option in Model.NotificationOptions)
                {
                    <label class="border rounded-3 px-3 py-3 d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <div class="fw-semibold">
                                @option.Title
                                @if (option.IsMandatory)
                                {
                                    <span class="badge bg-secondary-subtle text-secondary-emphasis ms-2">Luôn bật</span>
                                }
                            </div>
                            <div class="text-muted small mt-1">@option.Description</div>
                        </div>

                        <div class="form-check form-switch m-0 pt-1">
                            <input class="form-check-input"
                                   type="checkbox"
                                   name="enabledCategories"
                                   value="@option.Category"
                                   checked="@option.IsEnabled"
                                   disabled="@option.IsMandatory" />
                            @if (option.IsMandatory)
                            {
                                <input type="hidden" name="enabledCategories" value="@option.Category" />
                            }
                        </div>
                    </label>
                }
            </div>

            <div class="d-flex justify-content-end mt-3">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check2-circle me-1"></i> Lưu lựa chọn
                </button>
            </div>
        </form>
    </div>
}
