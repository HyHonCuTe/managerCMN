@model managerCMN.Models.ViewModels.ProjectEditViewModel
@using managerCMN.Models.Enums
@{
    ViewData["Title"] = "Sửa dự án";
}

@section Styles {
    <link rel="stylesheet" href="~/css/project-management.css" asp-append-version="true" />
}

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-pencil text-danger me-2"></i>Sửa thông tin dự án</h5>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <input asp-for="ProjectId" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold"></label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Status" class="form-label fw-semibold"></label>
                        <select asp-for="Status" class="form-select">
                            @foreach (var s in Enum.GetValues<ProjectStatus>())
                            {
                                <option value="@s">@(s switch {
                                    ProjectStatus.Planning  => "Lên kế hoạch",
                                    ProjectStatus.Active    => "Đang thực hiện",
                                    ProjectStatus.OnHold    => "Tạm dừng",
                                    ProjectStatus.Completed => "Hoàn thành",
                                    ProjectStatus.Cancelled => "Đã huỷ",
                                    ProjectStatus.Archived  => "Lưu trữ",
                                    _ => s.ToString()
                                })</option>
                            }
                        </select>
                    </div>

                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label asp-for="StartDate" class="form-label fw-semibold"></label>
                            <input asp-for="StartDate" type="date" class="form-control" />
                        </div>
                        <div class="col-6">
                            <label asp-for="EndDate" class="form-label fw-semibold"></label>
                            <input asp-for="EndDate" type="date" class="form-control" />
                        </div>
                    </div>

                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-action="Details" asp-route-id="@Model.ProjectId" class="btn btn-outline-secondary">Huỷ</a>
                        <button type="submit" class="btn btn-danger"><i class="bi bi-check-circle me-1"></i>Lưu</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
