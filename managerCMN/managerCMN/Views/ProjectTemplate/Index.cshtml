@model IEnumerable<managerCMN.Models.ViewModels.ProjectTemplateListViewModel>
@{
    ViewData["Title"] = "Quản lý template dự án";
}

@section Styles {
    <link rel="stylesheet" href="~/css/project-management.css" asp-append-version="true" />
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h4 class="mb-0 fw-bold"><i class="bi bi-layout-text-sidebar-reverse text-danger me-2"></i>Template dự án</h4>
        <small class="text-muted">Quản lý các template để tạo dự án nhanh với task cha chuẩn sẵn</small>
    </div>
    <a asp-action="Create" class="btn btn-danger btn-sm">
        <i class="bi bi-plus-circle me-1"></i>Tạo template
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show py-2 small" role="alert">
        <i class="bi bi-check-circle me-1"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show py-2 small" role="alert">
        <i class="bi bi-exclamation-circle me-1"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-layout-text-sidebar-reverse fs-1 opacity-25 d-block mb-2"></i>
        <p class="mb-0">Chưa có template nào. <a asp-action="Create">Tạo template đầu tiên</a></p>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var t in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 @(!t.IsActive ? "opacity-50" : "")">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h6 class="card-title mb-0 fw-semibold">
                                @if (!t.IsActive)
                                {
                                    <span class="badge bg-secondary me-1 small">Tắt</span>
                                }
                                @t.Name
                            </h6>
                            <span class="badge bg-light text-dark border small">@t.TaskCount task</span>
                        </div>
                        @if (!string.IsNullOrEmpty(t.Description))
                        {
                            <p class="card-text text-muted small mb-2" style="overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical">@t.Description</p>
                        }
                        <small class="text-muted">Tạo bởi @t.CreatedByName &bull; @t.CreatedDate.ToString("dd/MM/yyyy")</small>
                    </div>
                    <div class="card-footer bg-transparent d-flex gap-2 justify-content-end">
                        <form asp-action="ToggleActive" asp-route-id="@t.ProjectTemplateId" method="post" class="d-inline">
                            <button type="submit" class="btn btn-sm @(t.IsActive ? "btn-outline-secondary" : "btn-outline-success")" title="@(t.IsActive ? "Tắt kích hoạt" : "Kích hoạt")">
                                <i class="bi @(t.IsActive ? "bi-pause-circle" : "bi-play-circle")"></i>
                            </button>
                        </form>
                        <a asp-action="Edit" asp-route-id="@t.ProjectTemplateId" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-pencil"></i> Sửa
                        </a>
                        <form asp-action="Delete" asp-route-id="@t.ProjectTemplateId" method="post" class="d-inline"
                              onsubmit="return confirm('Xóa template này? Các dự án đã tạo từ template sẽ không bị ảnh hưởng.')">
                            <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
