                        <i class="bi bi-info-circle"></i> Bạn đang duyệt đơn: <strong id="approveTitle"></strong>
                    </div>
                    <div class="mb-0">
                        <label class="form-label">Ghi chú (tùy chọn)</label>
                        <textarea name="Comment" class="form-control" rows="3" placeholder="Nhập ghi chú nếu cần..."></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-success px-4"><i class="bi bi-check-lg"></i> Duyệt</button>
                </div>
            </form>
        </div>
    </div>
</div>

@* Reject Modal *@
<div class="modal fade" id="rejectModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <form asp-action="DoReject" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="RequestId" id="rejectRequestId" />
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title"><i class="bi bi-x-circle"></i> Từ chối đơn</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-danger-subtle border-0 mb-3">
                        <i class="bi bi-exclamation-triangle"></i> Bạn đang từ chối đơn: <strong id="rejectTitle"></strong>
                    </div>
                    <div class="mb-0">
                        <label class="form-label">Lý do từ chối <span class="text-danger">*</span></label>
                        <textarea name="Comment" class="form-control" rows="3" placeholder="Vui lòng nhập lý do từ chối..." id="rejectComment"></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-danger px-4"><i class="bi bi-x-lg"></i> Từ chối</button>
                </div>
            </form>
        </div>
    </div>
</div>

@* Revert Approval Modal *@
<div class="modal fade" id="revertModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <form asp-action="RevertApproval" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="RequestId" id="revertRequestId" />
                <div class="modal-header bg-warning text-dark">
                    <h5 class="modal-title">
                        <i class="bi bi-arrow-counterclockwise"></i> Hoàn duyệt đơn
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-warning border-0 mb-3">
                        <i class="bi bi-exclamation-triangle"></i>
                        Bạn đang hoàn duyệt đơn: <strong id="revertTitle"></strong>
                        <div class="mt-2 small">
                            <i class="bi bi-info-circle"></i>
                            Số phép sẽ được hoàn trả lại cho nhân viên.
                        </div>
                    </div>
                    <div class="mb-0">
                        <label class="form-label">
                            Lý do hoàn duyệt <span class="text-danger">*</span>
                        </label>
                        <textarea name="Comment" class="form-control" rows="3"
                                  placeholder="Vui lòng nhập lý do hoàn duyệt..."
                                  id="revertComment" required></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-warning px-4">
                        <i class="bi bi-arrow-counterclockwise"></i> Hoàn duyệt
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Use Bootstrap modal events to get data from trigger button
    document.addEventListener('DOMContentLoaded', function() {
        // Auto-submit filter form when any filter field changes
        const filterForm = document.getElementById('filterForm');
        const filterFields = document.querySelectorAll('.filter-field');

        if (filterForm && filterFields.length > 0) {
            filterFields.forEach(field => {
                field.addEventListener('change', function() {
                    filterForm.submit();
                });
            });
        }

        // Bulk selection functionality
        const selectAllCheckbox = document.getElementById('selectAll');
        const requestCheckboxes = document.querySelectorAll('.request-checkbox');
        const bulkActions = document.getElementById('bulkActions');
        const selectedCountSpan = document.getElementById('selectedCount');
        const bulkApproveBtn = document.getElementById('bulkApproveBtn');
        const bulkRejectBtn = document.getElementById('bulkRejectBtn');
        const clearSelectionBtn = document.getElementById('clearSelectionBtn');

        function updateBulkActionsVisibility() {
            const selectedCheckboxes = document.querySelectorAll('.request-checkbox:checked');
            const count = selectedCheckboxes.length;

            if (count > 0) {
                bulkActions.style.display = 'block';
                selectedCountSpan.textContent = count;
            } else {
                bulkActions.style.display = 'none';
            }

            // Update select all checkbox state
            if (count === 0) {
                selectAllCheckbox.indeterminate = false;
                selectAllCheckbox.checked = false;
            } else if (count === requestCheckboxes.length) {
                selectAllCheckbox.indeterminate = false;
                selectAllCheckbox.checked = true;
            } else {
                selectAllCheckbox.indeterminate = true;
            }
        }

        // Select all checkbox handler
        if (selectAllCheckbox) {
            selectAllCheckbox.addEventListener('change', function() {
                const isChecked = this.checked;
                requestCheckboxes.forEach(checkbox => {
                    checkbox.checked = isChecked;
                });
                updateBulkActionsVisibility();
            });
        }

        // Individual checkbox handlers
        requestCheckboxes.forEach(checkbox => {
            checkbox.addEventListener('change', updateBulkActionsVisibility);
        });

        // Clear selection button
        if (clearSelectionBtn) {
            clearSelectionBtn.addEventListener('click', function() {
                requestCheckboxes.forEach(checkbox => {
                    checkbox.checked = false;
                });
                updateBulkActionsVisibility();
            });
        }

        // Bulk approve button
        if (bulkApproveBtn) {
            bulkApproveBtn.addEventListener('click', function() {
                const selectedCheckboxes = document.querySelectorAll('.request-checkbox:checked');
                const requestIds = Array.from(selectedCheckboxes).map(cb => cb.value);
                const requestTitles = Array.from(selectedCheckboxes).map(cb => cb.dataset.requestTitle);

                if (requestIds.length === 0) {
                    alert('Vui lòng chọn ít nhất một đơn để duyệt.');
                    return;
                }

                // Populate bulk approve modal
                document.getElementById('bulkApproveIds').value = requestIds.join(',');
                document.getElementById('bulkApproveCount').textContent = requestIds.length;

                const listDiv = document.getElementById('bulkApproveList');
                listDiv.innerHTML = requestTitles.map(title => `<div><i class="bi bi-check-circle text-success"></i> ${title}</div>`).join('');

                // Show modal
                new bootstrap.Modal(document.getElementById('bulkApproveModal')).show();
            });
        }

        // Bulk reject button
        if (bulkRejectBtn) {
            bulkRejectBtn.addEventListener('click', function() {
                const selectedCheckboxes = document.querySelectorAll('.request-checkbox:checked');
                const requestIds = Array.from(selectedCheckboxes).map(cb => cb.value);
                const requestTitles = Array.from(selectedCheckboxes).map(cb => cb.dataset.requestTitle);

                if (requestIds.length === 0) {
                    alert('Vui lòng chọn ít nhất một đơn để từ chối.');
                    return;
                }

                // Populate bulk reject modal
                document.getElementById('bulkRejectIds').value = requestIds.join(',');
                document.getElementById('bulkRejectCount').textContent = requestIds.length;

                const listDiv = document.getElementById('bulkRejectList');
                listDiv.innerHTML = requestTitles.map(title => `<div><i class="bi bi-x-circle text-danger"></i> ${title}</div>`).join('');

                // Clear previous comment
                const bulkRejectComment = document.getElementById('bulkRejectComment');
                if (bulkRejectComment) bulkRejectComment.value = '';

                // Show modal
                new bootstrap.Modal(document.getElementById('bulkRejectModal')).show();
            });
        }

        // Bulk reject form validation
        const bulkRejectForm = document.getElementById('bulkRejectForm');
        if (bulkRejectForm) {
            bulkRejectForm.addEventListener('submit', function(e) {
                const comment = document.getElementById('bulkRejectComment').value;
                if (!comment || comment.trim() === '') {
                    e.preventDefault();
                    alert('Vui lòng nhập lý do từ chối.');
                    document.getElementById('bulkRejectComment').focus();
                    return false;
                }
            });
        }

        // Approve modal - capture data when modal is shown
        var approveModal = document.getElementById('approveModal');
        if (approveModal) {
            approveModal.addEventListener('show.bs.modal', function(event) {
                var button = event.relatedTarget;
                var requestId = button.getAttribute('data-request-id');
                var requestTitle = button.getAttribute('data-request-title');

                document.getElementById('approveRequestId').value = requestId;
                document.getElementById('approveTitle').textContent = requestTitle;
            });
        }

        // Reject modal - capture data when modal is shown
        var rejectModal = document.getElementById('rejectModal');
        if (rejectModal) {
            rejectModal.addEventListener('show.bs.modal', function(event) {
                var button = event.relatedTarget;
                var requestId = button.getAttribute('data-request-id');
                var requestTitle = button.getAttribute('data-request-title');

                document.getElementById('rejectRequestId').value = requestId;
                document.getElementById('rejectTitle').textContent = requestTitle;

                // Clear previous comment
                var commentField = document.getElementById('rejectComment');
                if (commentField) commentField.value = '';
            });
        }

        // Handle reject form submission
        var rejectForm = document.querySelector('#rejectModal form');
        if (rejectForm) {
            rejectForm.addEventListener('submit', function(e) {
                var requestId = document.getElementById('rejectRequestId').value;
                var comment = document.getElementById('rejectComment').value;

                if (!requestId || requestId === '0' || requestId === '') {
                    e.preventDefault();
                    alert('Lỗi: Không tìm thấy mã đơn. Vui lòng thử lại.');
                    return false;
                }

                if (!comment || comment.trim() === '') {
                    e.preventDefault();
                    alert('Vui lòng nhập lý do từ chối.');
                    document.getElementById('rejectComment').focus();
                    return false;
                }

                // Form will submit normally
                return true;
            });
        }

        // Revert modal - capture data when modal is shown
        var revertModal = document.getElementById('revertModal');
        if (revertModal) {
            revertModal.addEventListener('show.bs.modal', function(event) {
                var button = event.relatedTarget;
                var requestId = button.getAttribute('data-request-id');
                var requestTitle = button.getAttribute('data-request-title');

                document.getElementById('revertRequestId').value = requestId;
                document.getElementById('revertTitle').textContent = requestTitle;

                // Clear previous comment
                var commentField = document.getElementById('revertComment');
                if (commentField) commentField.value = '';
            });
        }

        // Handle revert form submission with validation
        var revertForm = document.querySelector('#revertModal form');
        if (revertForm) {
            revertForm.addEventListener('submit', function(e) {
                var requestId = document.getElementById('revertRequestId').value;
                var comment = document.getElementById('revertComment').value;

                if (!requestId || requestId === '0' || requestId === '') {
                    e.preventDefault();
                    alert('Lỗi: Không tìm thấy mã đơn. Vui lòng thử lại.');
                    return false;
                }

                if (!comment || comment.trim() === '') {
                    e.preventDefault();
                    alert('Vui lòng nhập lý do hoàn duyệt.');
                    document.getElementById('revertComment').focus();
                    return false;
                }

                // Confirm action
                if (!confirm('Bạn chắc chắn muốn hoàn duyệt đơn này? Số phép sẽ được hoàn trả.')) {
                    e.preventDefault();
                    return false;
                }

                return true;
            });
        }

        // Handle approve form submission
        var approveForm = document.querySelector('#approveModal form');
        if (approveForm) {
            approveForm.addEventListener('submit', function(e) {
                var requestId = document.getElementById('approveRequestId').value;

                if (!requestId || requestId === '0' || requestId === '') {
                    e.preventDefault();
                    alert('Lỗi: Không tìm thấy mã đơn. Vui lòng thử lại.');
                    return false;
                }

                // Form will submit normally
                return true;
            });
        }
    });

    $(document).ready(function () {
        // Only initialize DataTable if table has proper structure
        var table = $('#approveTable');
        if (table.length && table.find('thead th').length > 0) {
            table.DataTable({
                language: {
                    url: 'https://cdn.datatables.net/plug-ins/1.13.11/i18n/vi.json',
                    emptyTable: '<div class="text-center py-4 text-muted"><i class="bi bi-inbox fs-1 d-block mb-2"></i>Không có đơn từ nào.</div>'
                },
                paging: false,
                scrollY: '520px',
                scrollCollapse: true,
                order: [],
                columnDefs: [
                    { targets: 0, orderable: false } // Disable sorting on checkbox column
                ]
            });
        }
    });
</script>
}
