@model RequestCreateViewModel
@using managerCMN.Helpers
@using managerCMN.Models.Enums
@{
    ViewData["Title"] = "Tạo đơn từ mới";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h4 class="mb-0"><i class="bi bi-send-plus"></i> Tạo đơn từ mới</h4>
        <small class="text-muted">Điền thông tin đầy đủ để gửi đơn</small>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
</div>

<form asp-action="Create" method="post" enctype="multipart/form-data" id="requestCreateForm">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    @* Card 1: Thông tin chung *@
    <div class="card mb-3">
        <div class="card-header bg-white fw-semibold">
            <i class="bi bi-info-circle text-primary"></i> Thông tin chung
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="RequestType" class="form-label fw-semibold">Loại đơn <span class="text-danger">*</span></label>
                    <select asp-for="RequestType" class="form-select" id="requestType">
                        <option value="0">Xin nghỉ</option>
                        <option value="1">Checkin/out</option>
                        <option value="2">Vắng mặt</option>
                        <option value="3">Làm ở nhà (WFH)</option>
                    </select>
                </div>
                <div class="col-md-4" id="checkInOutTypeWrap" style="display: none;">
                    <label asp-for="CheckInOutType" class="form-label fw-semibold">Loại <span class="text-danger">*</span></label>
                    <select asp-for="CheckInOutType" class="form-select" id="checkInOutType">
                        <option value="0">Quên check in</option>
                        <option value="1">Quên check out</option>
                    </select>
                </div>
                <div class="col-md-8" id="titleWrap">
                    <label asp-for="Title" class="form-label fw-semibold">Tiêu đề <span class="text-danger">*</span></label>
                    <input asp-for="Title" class="form-control" placeholder="" required />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>
            </div>
        </div>
    </div>

    @* Card 2: Thời gian *@
    <div class="card mb-3">
        <div class="card-header bg-white fw-semibold">
            <i class="bi bi-calendar-event text-primary"></i> Thời gian
        </div>
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label asp-for="StartTime" class="form-label fw-semibold" id="startDateLabel">Từ ngày <span class="text-danger">*</span></label>
                    <input asp-for="StartDate" class="form-control" type="date" id="startDate" required />
                    <span asp-validation-for="StartTime" class="text-danger small"></span>
                </div>
                <div class="col-md-2" id="startTimeWrap" style="display: none;">
                    <label class="form-label fw-semibold">Giờ bắt đầu</label>
                    <input asp-for="StartClock" type="time" class="form-control form-control-sm" id="startTimeInput" />
                    <span asp-validation-for="StartClock" class="text-danger small"></span>
                </div>
                <div class="col-md-2" id="halfDayStartWrap">
                    <label class="form-label fw-semibold">Ca bắt đầu</label>
                    <select asp-for="HalfDayStartOption" class="form-select form-select-sm" id="halfDayStartOpt">
                        <option value="0">Cả ngày</option>
                        <option value="1">Nửa ca sáng</option>
                        <option value="2">Nửa ca chiều</option>
                    </select>
                </div>
                <div class="col-md-3" id="endDateWrap">
                    <label asp-for="EndTime" class="form-label fw-semibold" id="endDateLabel">Đến ngày <span class="text-danger">*</span></label>
                    <input asp-for="EndDate" class="form-control" type="date" id="endDate" required />
                    <span asp-validation-for="EndTime" class="text-danger small"></span>
                </div>
                <div class="col-md-2" id="endTimeWrap" style="display: none;">
                    <label class="form-label fw-semibold">Giờ kết thúc</label>
                    <input asp-for="EndClock" type="time" class="form-control form-control-sm" id="endTimeInput" />
                    <span asp-validation-for="EndClock" class="text-danger small"></span>
                </div>
                <div class="col-md-2" id="halfDayEndWrap">
                    <label class="form-label fw-semibold">Ca kết thúc</label>
                    <select asp-for="HalfDayEndOption" class="form-select form-select-sm" id="halfDayEndOpt">
                        <option value="0">Cả ngày</option>
                        <option value="1">Nửa ca sáng</option>
                        <option value="2">Nửa ca chiều</option>
                    </select>
                </div>
                <div class="col-md-2" id="totalDaysWrap">
                    <label class="form-label fw-semibold">Tổng ngày</label>
                    <div class="input-group">
                        <input type="text" class="form-control bg-light fw-semibold text-center" id="totalDays" readonly value="1" />
                        <span class="input-group-text">ngày</span>
                    </div>
                    <input asp-for="TotalDays" type="hidden" id="totalDaysHidden" />
                </div>
            </div>
        </div>
    </div>

    @* Card 3: Lý do *@
    <div class="card mb-3">
        <div class="card-header bg-white fw-semibold">
            <i class="bi bi-card-text text-primary"></i> Lý do
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-8">
                    <label class="form-label fw-semibold">Lý do <span class="text-danger">*</span></label>
                    <select asp-for="LeaveReason" class="form-select" id="leaveReasonSelect" required>
                        <option value="">-- Chọn lý do --</option>
                        @if (Model.AvailableReasons != null)
                        {
                            foreach (var r in Model.AvailableReasons)
                            {
                                <option value="@r.Value">@r.Text</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Tính công</label>
                    <div class="form-control bg-light d-flex align-items-center" id="countsAsWorkDisplay">
                        <i class="bi bi-check-circle text-success me-2"></i> Tính công
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Card 3.5: Thông tin số dư phép (Only for Leave Request) *@
    <div class="card mb-3" id="leaveBalanceCard" style="display: none;">
        <div class="card-header bg-light fw-semibold">
            <i class="bi bi-calendar-check text-info"></i> Thông tin số dư phép
        </div>
        <div class="card-body">
            <div id="balanceInfo">
                <div class="text-center text-muted">
                    <i class="bi bi-hourglass-split"></i> Chọn ngày để kiểm tra số dư phép
                </div>
            </div>
        </div>
    </div>

    @* Card 4: Người duyệt *@
    <div class="card mb-3">
        <div class="card-header bg-white fw-semibold">
            <i class="bi bi-person-check text-primary"></i> Người duyệt
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Người duyệt 1 <span class="text-danger">*</span></label>

                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-person-plus"></i></span>
                        <select asp-for="Approver1Id" asp-items="Model.AvailableApprover1s" class="form-select" id="approver1Select" required>
                            <option value="">-- Chọn người duyệt 1 --</option>
                        </select>
                    </div>
                    <span asp-validation-for="Approver1Id" class="text-danger small"></span>
                    <small class="text-muted">Chọn người duyệt 1 từ danh sách</small>
                </div>
                <div class="col-md-6">
                    <label asp-for="Approver2Id" class="form-label fw-semibold">Người duyệt 2 <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-person-plus"></i></span>
                        <select asp-for="Approver2Id" asp-items="Model.AvailableApprovers" class="form-select" id="approver2Select" required>
                            <option value="">-- Chọn người duyệt --</option>
                        </select>
                    </div>
                    <span asp-validation-for="Approver2Id" class="text-danger small"></span>
                    <small class="text-muted">Chọn từ danh sách người duyệt</small>
                </div>
            </div>
        </div>
    </div>

    @* Card 5: Mô tả *@
    <div class="card mb-3">
        <div class="card-header bg-white fw-semibold">
            <i class="bi bi-text-paragraph text-primary"></i> Mô tả chi tiết
        </div>
        <div class="card-body">
            <textarea asp-for="Description" class="form-control" id="descriptionEditor" rows="5"></textarea>
        </div>
    </div>

    @* Card 6: Đính kèm *@
    <div class="card mb-3">
        <div class="card-header bg-white fw-semibold">
            <i class="bi bi-paperclip text-primary"></i> Tệp đính kèm
        </div>
        <div class="card-body">
            <input asp-for="Attachments" class="form-control" type="file" multiple id="attachmentsInput" />
            <small class="text-muted mt-1 d-block">Có thể chọn nhiều file (hình ảnh, PDF, tài liệu...)</small>
        </div>
    </div>

    @* Submit *@
    <div class="d-flex gap-2 mb-4">
        <button type="button" class="btn btn-primary px-4" id="openConfirmModalButton">
            <i class="bi bi-send"></i> Gửi đơn
        </button>
        <a asp-action="Index" class="btn btn-light">Hủy</a>
    </div>
</form>

<div class="modal fade" id="confirmSubmitModal" tabindex="-1" aria-labelledby="confirmSubmitModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable">
        <div class="modal-content border-0 shadow">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title mb-1" id="confirmSubmitModalLabel">
                        <i class="bi bi-clipboard-check text-primary me-2"></i>Xác nhận gửi đơn
                    </h5>
                    <small class="text-muted">Kiểm tra lại thông tin trước khi gửi cho người duyệt.</small>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="border rounded-3 p-3 h-100 bg-light-subtle">
                            <div class="small text-muted mb-1">Loại đơn</div>
                            <div class="fw-semibold" id="confirmRequestType">-</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="border rounded-3 p-3 h-100 bg-light-subtle">
                            <div class="small text-muted mb-1">Tiêu đề</div>
                            <div class="fw-semibold" id="confirmTitle">-</div>
                        </div>
                    </div>
                    <div class="col-md-6" id="confirmCheckInOutTypeWrap" style="display: none;">
                        <div class="border rounded-3 p-3 h-100 bg-light-subtle">
                            <div class="small text-muted mb-1">Loại checkin/out</div>
                            <div class="fw-semibold" id="confirmCheckInOutType">-</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="border rounded-3 p-3 h-100 bg-light-subtle">
                            <div class="small text-muted mb-1">Thời gian</div>
                            <div class="fw-semibold" id="confirmTimeRange">-</div>
                        </div>
                    </div>
                    <div class="col-md-6" id="confirmTotalDaysWrap">
                        <div class="border rounded-3 p-3 h-100 bg-light-subtle">
                            <div class="small text-muted mb-1">Tổng ngày</div>
                            <div class="fw-semibold" id="confirmTotalDays">-</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="border rounded-3 p-3 h-100 bg-light-subtle">
                            <div class="small text-muted mb-1">Lý do</div>
                            <div class="fw-semibold" id="confirmReason">-</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="border rounded-3 p-3 h-100 bg-light-subtle">
                            <div class="small text-muted mb-1">Tính công</div>
                            <div class="fw-semibold" id="confirmCountsAsWork">-</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="border rounded-3 p-3 h-100 bg-light-subtle">
                            <div class="small text-muted mb-1">Người duyệt 1</div>
                            <div class="fw-semibold" id="confirmApprover1">-</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="border rounded-3 p-3 h-100 bg-light-subtle">
                            <div class="small text-muted mb-1">Người duyệt 2</div>
                            <div class="fw-semibold" id="confirmApprover2">-</div>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="border rounded-3 p-3 bg-light-subtle">
                            <div class="small text-muted mb-1">Tệp đính kèm</div>
                            <div class="fw-semibold text-break" id="confirmAttachments">Không có tệp đính kèm</div>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="border rounded-3 p-3 bg-light-subtle">
                            <div class="small text-muted mb-1">Mô tả chi tiết</div>
                            <div class="fw-semibold text-break" id="confirmDescription">Không có mô tả.</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Quay lại chỉnh sửa</button>
                <button type="button" class="btn btn-primary px-4" id="confirmSubmitButton">
                    <i class="bi bi-send-check me-1"></i>Xác nhận gửi
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <link href="https://cdn.jsdelivr.net/npm/summernote@0.8.20/dist/summernote-bs5.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/summernote@0.8.20/dist/summernote-bs5.min.js"></script>
    <script>
        $(document).ready(function() {
            $('#descriptionEditor').summernote({
                height: 200,
                toolbar: [
                    ['style', ['bold', 'italic', 'underline', 'clear']],
                    ['para', ['ul', 'ol']],
                    ['insert', ['link']],
                    ['view', ['codeview']]
                ],
                placeholder: 'Nhập mô tả chi tiết...'
            });
        });

        var requestTypeSelect = document.getElementById('requestType');
        var titleInput = document.getElementById('Title');
        var startDate = document.getElementById('startDate');
        var endDate = document.getElementById('endDate');
        var startDateLabel = document.getElementById('startDateLabel');
        var endDateLabel = document.getElementById('endDateLabel');
        var halfDayStartOpt = document.getElementById('halfDayStartOpt');
        var halfDayEndOpt = document.getElementById('halfDayEndOpt');
        var halfDayStartWrap = document.getElementById('halfDayStartWrap');
        var halfDayEndWrap = document.getElementById('halfDayEndWrap');
        var endDateWrap = document.getElementById('endDateWrap');
        var startTimeWrap = document.getElementById('startTimeWrap');
        var endTimeWrap = document.getElementById('endTimeWrap');
        var startTimeInput = document.getElementById('startTimeInput');
        var endTimeInput = document.getElementById('endTimeInput');
        var totalDays = document.getElementById('totalDays');
        var totalDaysHidden = document.getElementById('totalDaysHidden');
        var totalDaysWrap = document.getElementById('totalDaysWrap');
        var leaveReasonSelect = document.getElementById('leaveReasonSelect');
        var countsAsWorkDisplay = document.getElementById('countsAsWorkDisplay');
        var checkInOutTypeWrap = document.getElementById('checkInOutTypeWrap');
        var checkInOutType = document.getElementById('checkInOutType');
        var titleWrap = document.getElementById('titleWrap');
        var approver1Select = document.getElementById('approver1Select');
        var approver2Select = document.getElementById('approver2Select');
        var requestCreateForm = document.getElementById('requestCreateForm');
        var attachmentsInput = document.getElementById('attachmentsInput');
        var openConfirmModalButton = document.getElementById('openConfirmModalButton');
        var confirmSubmitButton = document.getElementById('confirmSubmitButton');
        var confirmSubmitModalElement = document.getElementById('confirmSubmitModal');
        var confirmSubmitModal = new bootstrap.Modal(confirmSubmitModalElement);
        var selectedCheckInOutTypeValue = '@(Model.CheckInOutType.HasValue ? ((int)Model.CheckInOutType.Value).ToString() : string.Empty)';

        function ensureCheckInOutOptions() {
            var requiredOptions = [
                { value: '2', text: 'Đi trễ' },
                { value: '3', text: 'Về sớm' }
            ];

            requiredOptions.forEach(function(optionData) {
                if (!checkInOutType.querySelector('option[value="' + optionData.value + '"]')) {
                    var option = document.createElement('option');
                    option.value = optionData.value;
                    option.textContent = optionData.text;
                    checkInOutType.appendChild(option);
                }
            });

            if (selectedCheckInOutTypeValue) {
                checkInOutType.value = selectedCheckInOutTypeValue;
            }
        }

        function updateFormByRequestType(type) {
            // Reset visibility
            halfDayStartWrap.style.display = '';
            halfDayEndWrap.style.display = '';
            endDateWrap.style.display = '';
            startTimeWrap.style.display = 'none';
            endTimeWrap.style.display = 'none';
            totalDaysWrap.style.display = '';
            checkInOutTypeWrap.style.display = 'none';

            // Adjust title wrap width
            titleWrap.className = 'col-md-8';

            // RequestType: 0=Leave, 1=CheckInOut, 2=Absence, 3=WorkFromHome
            if (type === 1) {
                // CheckInOut: Show dropdown to select type, then show appropriate time field
                checkInOutTypeWrap.style.display = '';
                titleWrap.className = 'col-md-4';
                startDateLabel.innerHTML = 'Ngày quên checkin/out <span class="text-danger">*</span>';
                endDateWrap.style.display = 'none';
                halfDayStartWrap.style.display = 'none';
                halfDayEndWrap.style.display = 'none';
                totalDaysWrap.style.display = 'none';

                // Show time input based on CheckInOutType
                updateCheckInOutTimeFields();
                startDateLabel.innerHTML = 'Ngày<span class="text-danger">*</span>';

                // Set end date same as start date
                endDate.value = startDate.value;
            } else if (type === 2) {
                // Absence: Select 1 day and time range, hide "Tổng ngày"
                startDateLabel.innerHTML = 'Ngày vắng <span class="text-danger">*</span>';
                endDateWrap.style.display = 'none';
                startTimeWrap.style.display = '';
                endTimeWrap.style.display = '';
                halfDayStartWrap.style.display = 'none';
                halfDayEndWrap.style.display = 'none';
                totalDaysWrap.style.display = 'none'; // Hide "Tổng ngày" for Absence

                // Set end date same as start date
                endDate.value = startDate.value;
            } else if (type === 3) {
                // WorkFromHome: Chỉ cần ngày hoặc ca sáng/chiều
                startDateLabel.innerHTML = 'Ngày làm ở nhà <span class="text-danger">*</span>';
                endDateWrap.style.display = 'none';
                halfDayEndWrap.style.display = 'none';
                // Set end date same as start date
                endDate.value = startDate.value;
            } else {
                // Leave (default): Full date range with half-day options
                startDateLabel.innerHTML = 'Từ ngày <span class="text-danger">*</span>';
                endDateLabel.innerHTML = 'Đến ngày <span class="text-danger">*</span>';
            }

            syncTimeFieldRequirements(type);
        }

        function updateCheckInOutTimeFields() {
            var checkInOutTypeValue = parseInt(checkInOutType.value);
            if (checkInOutTypeValue === 0 || checkInOutTypeValue === 2) {
                // Check-in based requests: Show start time only
                startTimeWrap.style.display = '';
                endTimeWrap.style.display = 'none';
            } else {
                // Check-out based requests: Show end time only
                startTimeWrap.style.display = 'none';
                endTimeWrap.style.display = '';
            }

            syncTimeFieldRequirements(parseInt(requestTypeSelect.value));
        }

        function syncTimeFieldRequirements(type) {
            startTimeInput.required = false;
            endTimeInput.required = false;

            if (type === 2) {
                startTimeInput.required = true;
                endTimeInput.required = true;
                return;
            }

            if (type === 1) {
                var checkInOutTypeValue = parseInt(checkInOutType.value);
                startTimeInput.required = checkInOutTypeValue === 0 || checkInOutTypeValue === 2;
                endTimeInput.required = checkInOutTypeValue === 1 || checkInOutTypeValue === 3;
            }
        }

        function calcDays() {
            var type = parseInt(requestTypeSelect.value);
            var s = startDate.value, e = endDate.value;
            
            // Single-day request types must always keep end date in sync with start date.
            if (type === 1 || type === 2 || type === 3) {
                endDate.value = s;
                e = s;
            }
            
            if (s && e) {
                // Leave requests use server-side working-day rules so the UI matches the business logic.
                if (type === 0) {
                    totalDays.value = '';
                    totalDaysHidden.value = '';
                    halfDayEndWrap.style.display = (s === e) ? 'none' : '';
                    checkLeaveBalance();
                    return;
                }

                var diff = (new Date(e) - new Date(s)) / (1000*60*60*24) + 1;

                // Only calculate half-days for WorkFromHome here.
                if (type === 3) {
                    var startOpt = parseInt(halfDayStartOpt.value);
                    var endOpt = parseInt(halfDayEndOpt.value);
                    if (diff === 1) {
                        if (startOpt > 0) diff = 0.5;
                    } else {
                        if (startOpt > 0) diff -= 0.5;
                        if (endOpt > 0) diff -= 0.5;
                    }
                }

                if (diff <= 0) {
                    totalDays.value = '';
                    totalDaysHidden.value = '';
                    return;
                }

                totalDays.value = diff;
                totalDaysHidden.value = diff;

                // Check leave balance after calculating days
                checkLeaveBalance();
            }
        }

        async function checkLeaveBalance() {
            // Only check for Leave requests (RequestType = 0)
            if (requestTypeSelect.value !== '0') {
                document.getElementById('leaveBalanceCard').style.display = 'none';
                return;
            }

            const startDateValue = startDate.value;
            const endDateValue = endDate.value;

            if (!startDateValue || !endDateValue) {
                document.getElementById('leaveBalanceCard').style.display = 'none';
                totalDays.value = '';
                totalDaysHidden.value = '';
                return;
            }

            // Show the balance card for Leave requests
            document.getElementById('leaveBalanceCard').style.display = 'block';

            const selectedReason = leaveReasonSelect.options[leaveReasonSelect.selectedIndex];
            const skipsLeaveDeduction = selectedReason && selectedReason.value && selectedReason.dataset.deductsLeave === 'false';

            const isHalfDayStart = parseInt(halfDayStartOpt.value) > 0;
            const isHalfDayEnd = parseInt(halfDayEndOpt.value) > 0;

            try {
                const response = await fetch(`/Request/GetLeaveBalance?startDate=${startDateValue}&endDate=${endDateValue}&isHalfDayStart=${isHalfDayStart}&isHalfDayEnd=${isHalfDayEnd}`);
                const data = await response.json();
                if (response.ok) {
                    totalDays.value = data.totalDays ?? '';
                    totalDaysHidden.value = data.totalDays ?? '';
                } else {
                    totalDays.value = '';
                    totalDaysHidden.value = '';
                }

                if (skipsLeaveDeduction) {
                    data.hasSufficientBalance = true;
                    data.message = 'Lý do này vẫn tính công và không trừ phép.';
                }

                updateBalanceDisplay(data);
            } catch (error) {
                console.error('Error checking leave balance:', error);
                totalDays.value = '';
                totalDaysHidden.value = '';
                updateBalanceDisplay({
                    message: 'Không thể kiểm tra số dư phép. Vui lòng thử lại.',
                    hasSufficientBalance: false
                });
            }
        }

        function updateBalanceDisplay(balanceData) {
            const balanceInfo = document.getElementById('balanceInfo');
            const alertClass = balanceData.hasSufficientBalance ? 'alert-success' : 'alert-warning';
            const iconClass = balanceData.hasSufficientBalance ? 'bi-check-circle' : 'bi-exclamation-triangle';

            balanceInfo.innerHTML = `
                <div class="alert ${alertClass} mb-0">
                    <i class="bi ${iconClass} me-2"></i>
                    ${balanceData.message}
                </div>
            `;
        }

        startDate.addEventListener('change', calcDays);
        endDate.addEventListener('change', calcDays);
        halfDayStartOpt.addEventListener('change', calcDays);
        halfDayEndOpt.addEventListener('change', calcDays);

        function loadReasons(type) {
            fetch('/Request/GetReasons?type=' + type)
                .then(r => r.json())
                .then(data => {
                    leaveReasonSelect.innerHTML = '<option value="">-- Chọn lý do --</option>';
                    data.forEach(function(r) {
                        var opt = document.createElement('option');
                        opt.value = r.value;
                        opt.dataset.countsAsWork = r.countsAsWork;
                        opt.dataset.deductsLeave = r.deductsLeave;
                        opt.textContent = r.text + ' \u2192 ' + (r.countsAsWork ? 'Tính công' : 'Không tính công');
                        opt.textContent = r.statusText ? (r.text + ' -> ' + r.statusText) : opt.textContent;
                        leaveReasonSelect.appendChild(opt);
                    });
                    if (data.length === 1) {
                        leaveReasonSelect.value = data[0].value;
                        updateCountsAsWork(data[0].countsAsWork);
                    }
                });
        }

        function updateCountsAsWork(v) {
            countsAsWorkDisplay.innerHTML = v
                ? '<i class="bi bi-check-circle text-success me-2"></i> Tính công'
                : '<i class="bi bi-x-circle text-danger me-2"></i> Không tính công';
        }

        function getSelectedText(selectElement, fallback = '-') {
            if (!selectElement || selectElement.selectedIndex < 0) return fallback;

            var selectedOption = selectElement.options[selectElement.selectedIndex];
            if (!selectedOption || !selectedOption.value) return fallback;

            return selectedOption.textContent.trim();
        }

        function formatDateDisplay(value) {
            if (!value) return '-';

            var parts = value.split('-');
            return parts.length === 3 ? `${parts[2]}/${parts[1]}/${parts[0]}` : value;
        }

        function formatTimeDisplay(value) {
            return value ? value : '--:--';
        }

        function stripHtml(html) {
            var temp = document.createElement('div');
            temp.innerHTML = html || '';
            return (temp.textContent || temp.innerText || '').trim();
        }

        function getReasonSummary() {
            return getSelectedText(leaveReasonSelect, '-- Chưa chọn lý do --').replace(/\s+\u2192\s+/g, ' | ');
        }

        function getCountsAsWorkSummary() {
            return stripHtml(countsAsWorkDisplay.textContent) || '-';
        }

        function getTimeRangeSummary(type) {
            var startDateText = formatDateDisplay(startDate.value);
            var endDateText = formatDateDisplay(endDate.value);
            var startShift = getSelectedText(halfDayStartOpt, 'Cả ngày');
            var endShift = getSelectedText(halfDayEndOpt, 'Cả ngày');
            var startTimeText = formatTimeDisplay(startTimeInput.value);
            var endTimeText = formatTimeDisplay(endTimeInput.value);

            if (type === 1) {
                return `${startDateText} | ${startTimeText !== '--:--' ? startTimeText : endTimeText}`;
            }

            if (type === 2) {
                return `${startDateText} | ${startTimeText} - ${endTimeText}`;
            }

            if (type === 3) {
                return `${startDateText} | ${startShift}`;
            }

            if (startDate.value === endDate.value) {
                return `${startDateText} | ${startShift}`;
            }

            return `${startDateText} (${startShift}) -> ${endDateText} (${endShift})`;
        }

        function getAttachmentsSummary() {
            if (!attachmentsInput || !attachmentsInput.files || attachmentsInput.files.length === 0) {
                return 'Không có tệp đính kèm';
            }

            return Array.from(attachmentsInput.files)
                .map(file => file.name)
                .join(', ');
        }

        function syncRequiredClientValidation() {
            titleInput.setCustomValidity(titleInput.value.trim() ? '' : 'Vui lòng nhập tiêu đề.');
            leaveReasonSelect.setCustomValidity(leaveReasonSelect.value ? '' : 'Vui lòng chọn lý do.');
            approver1Select.setCustomValidity(approver1Select.value ? '' : 'Vui lòng chọn người duyệt 1.');
            approver2Select.setCustomValidity(approver2Select.value ? '' : 'Vui lòng chọn người duyệt 2.');
        }

        function populateConfirmationModal() {
            var requestType = parseInt(requestTypeSelect.value);
            var totalDaysText = totalDaysHidden.value || totalDays.value || '0';
            var descriptionHtml = $('#descriptionEditor').summernote('code');
            var descriptionText = stripHtml(descriptionHtml);

            document.getElementById('confirmRequestType').textContent = getSelectedText(requestTypeSelect);
            document.getElementById('confirmTitle').textContent = document.getElementById('Title').value.trim() || '-';
            document.getElementById('confirmCheckInOutType').textContent = getSelectedText(checkInOutType, '-');
            document.getElementById('confirmTimeRange').textContent = getTimeRangeSummary(requestType);
            document.getElementById('confirmTotalDays').textContent = `${totalDaysText} ngày`;
            document.getElementById('confirmReason').textContent = getReasonSummary();
            document.getElementById('confirmCountsAsWork').textContent = getCountsAsWorkSummary();
            document.getElementById('confirmApprover1').textContent = getSelectedText(document.getElementById('approver1Select'), '-- Chưa chọn --');
            document.getElementById('confirmApprover2').textContent = getSelectedText(document.getElementById('approver2Select'), '-- Chưa chọn --');
            document.getElementById('confirmAttachments').textContent = getAttachmentsSummary();
            document.getElementById('confirmDescription').textContent = descriptionText || 'Không có mô tả.';

            document.getElementById('confirmCheckInOutTypeWrap').style.display = requestType === 1 ? '' : 'none';
            document.getElementById('confirmTotalDaysWrap').style.display = (requestType === 1 || requestType === 2) ? 'none' : '';
        }

        function canOpenConfirmationModal() {
            syncRequiredClientValidation();

            if (typeof $ !== 'undefined' && typeof $(requestCreateForm).valid === 'function' && !$(requestCreateForm).valid()) {
                return false;
            }

            if (typeof requestCreateForm.reportValidity === 'function' && !requestCreateForm.reportValidity()) {
                return false;
            }

            return true;
        }

        requestTypeSelect.addEventListener('change', function() {
            var type = parseInt(this.value);
            updateFormByRequestType(type);
            loadReasons(type);
            calcDays();
            checkLeaveBalance(); // Check balance when request type changes
        });

        checkInOutType.addEventListener('change', function() {
            updateCheckInOutTimeFields();
        });

        titleInput.addEventListener('input', syncRequiredClientValidation);
        approver1Select.addEventListener('change', syncRequiredClientValidation);
        approver2Select.addEventListener('change', syncRequiredClientValidation);

        leaveReasonSelect.addEventListener('change', function() {
            if (this.value) {
                var text = this.options[this.selectedIndex].textContent;
                updateCountsAsWork(!text.includes('Không tính công'));
            }
        });

        leaveReasonSelect.addEventListener('change', function() {
            syncRequiredClientValidation();
            checkLeaveBalance();
        });

        openConfirmModalButton.addEventListener('click', async function() {
            if (!canOpenConfirmationModal()) {
                return;
            }

            if (parseInt(requestTypeSelect.value) === 0) {
                await checkLeaveBalance();
            } else {
                calcDays();
            }

            populateConfirmationModal();
            confirmSubmitModal.show();
        });

        confirmSubmitButton.addEventListener('click', function() {
            confirmSubmitButton.disabled = true;
            confirmSubmitButton.innerHTML = '<i class="bi bi-hourglass-split me-1"></i>Đang gửi...';
            document.getElementById('descriptionEditor').value = $('#descriptionEditor').summernote('code');
            requestCreateForm.submit();
        });

        confirmSubmitModalElement.addEventListener('hidden.bs.modal', function() {
            confirmSubmitButton.disabled = false;
            confirmSubmitButton.innerHTML = '<i class="bi bi-send-check me-1"></i>Xác nhận gửi';
        });

        ensureCheckInOutOptions();

        // Initialize form based on default request type
        updateFormByRequestType(parseInt(requestTypeSelect.value));
        loadReasons(parseInt(requestTypeSelect.value));
        syncRequiredClientValidation();
        calcDays();
    </script>
}
