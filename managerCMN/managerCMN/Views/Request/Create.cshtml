@model RequestCreateViewModel
@using managerCMN.Models.Enums
@{
    ViewData["Title"] = "Tạo đơn từ mới";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h4 class="mb-0"><i class="bi bi-send-plus"></i> Tạo đơn từ mới</h4>
        <small class="text-muted">Điền thông tin đầy đủ để gửi đơn</small>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
</div>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    @* Card 1: Thông tin chung *@
    <div class="card mb-3">
        <div class="card-header bg-white fw-semibold">
            <i class="bi bi-info-circle text-primary"></i> Thông tin chung
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="RequestType" class="form-label fw-semibold">Loại đơn <span class="text-danger">*</span></label>
                    <select asp-for="RequestType" class="form-select" id="requestType">
                        <option value="0">Xin nghỉ</option>
                        <option value="1">Checkin/out</option>
                        <option value="2">Vắng mặt</option>
                        <option value="3">Làm ở nhà (WFH)</option>
                    </select>
                </div>
                <div class="col-md-4" id="checkInOutTypeWrap" style="display: none;">
                    <label asp-for="CheckInOutType" class="form-label fw-semibold">Loại <span class="text-danger">*</span></label>
                    <select asp-for="CheckInOutType" class="form-select" id="checkInOutType">
                        <option value="0">Quên check in</option>
                        <option value="1">Quên check out</option>
                    </select>
                </div>
                <div class="col-md-8" id="titleWrap">
                    <label asp-for="Title" class="form-label fw-semibold">Tiêu đề <span class="text-danger">*</span></label>
                    <input asp-for="Title" class="form-control" placeholder="" />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>
            </div>
        </div>
    </div>

    @* Card 2: Thời gian *@
    <div class="card mb-3">
        <div class="card-header bg-white fw-semibold">
            <i class="bi bi-calendar-event text-primary"></i> Thời gian
        </div>
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label asp-for="StartTime" class="form-label fw-semibold" id="startDateLabel">Từ ngày <span class="text-danger">*</span></label>
                    <input asp-for="StartTime" class="form-control" type="date" id="startDate" />
                    <span asp-validation-for="StartTime" class="text-danger small"></span>
                </div>
                <div class="col-md-2" id="startTimeWrap" style="display: none;">
                    <label class="form-label fw-semibold">Giờ bắt đầu</label>
                    <input type="time" class="form-control form-control-sm" id="startTimeInput" />
                </div>
                <div class="col-md-2" id="halfDayStartWrap">
                    <label class="form-label fw-semibold">Ca bắt đầu</label>
                    <select asp-for="HalfDayStartOption" class="form-select form-select-sm" id="halfDayStartOpt">
                        <option value="0">Cả ngày</option>
                        <option value="1">Nửa ca sáng</option>
                        <option value="2">Nửa ca chiều</option>
                    </select>
                </div>
                <div class="col-md-3" id="endDateWrap">
                    <label asp-for="EndTime" class="form-label fw-semibold" id="endDateLabel">Đến ngày <span class="text-danger">*</span></label>
                    <input asp-for="EndTime" class="form-control" type="date" id="endDate" />
                </div>
                <div class="col-md-2" id="endTimeWrap" style="display: none;">
                    <label class="form-label fw-semibold">Giờ kết thúc</label>
                    <input type="time" class="form-control form-control-sm" id="endTimeInput" />
                </div>
                <div class="col-md-2" id="halfDayEndWrap">
                    <label class="form-label fw-semibold">Ca kết thúc</label>
                    <select asp-for="HalfDayEndOption" class="form-select form-select-sm" id="halfDayEndOpt">
                        <option value="0">Cả ngày</option>
                        <option value="1">Nửa ca sáng</option>
                        <option value="2">Nửa ca chiều</option>
                    </select>
                </div>
                <div class="col-md-2" id="totalDaysWrap">
                    <label class="form-label fw-semibold">Tổng ngày</label>
                    <div class="input-group">
                        <input type="text" class="form-control bg-light fw-semibold text-center" id="totalDays" readonly value="1" />
                        <span class="input-group-text">ngày</span>
                    </div>
                    <input asp-for="TotalDays" type="hidden" id="totalDaysHidden" />
                </div>
            </div>
        </div>
    </div>

    @* Card 3: Lý do *@
    <div class="card mb-3">
        <div class="card-header bg-white fw-semibold">
            <i class="bi bi-card-text text-primary"></i> Lý do
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-8">
                    <label class="form-label fw-semibold">Lý do <span class="text-danger">*</span></label>
                    <select class="form-select" id="leaveReasonSelect" name="LeaveReason">
                        <option value="">-- Chọn lý do --</option>
                        @if (Model.AvailableReasons != null)
                        {
                            foreach (var r in Model.AvailableReasons)
                            {
                                <option value="@r.Value">@r.Text</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Tính công</label>
                    <div class="form-control bg-light d-flex align-items-center" id="countsAsWorkDisplay">
                        <i class="bi bi-check-circle text-success me-2"></i> Tính công
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Card 3.5: Thông tin số dư phép (Only for Leave Request) *@
    <div class="card mb-3" id="leaveBalanceCard" style="display: none;">
        <div class="card-header bg-light fw-semibold">
            <i class="bi bi-calendar-check text-info"></i> Thông tin số dư phép
        </div>
        <div class="card-body">
            <div id="balanceInfo">
                <div class="text-center text-muted">
                    <i class="bi bi-hourglass-split"></i> Chọn ngày để kiểm tra số dư phép
                </div>
            </div>
        </div>
    </div>

    @* Card 4: Người duyệt *@
    <div class="card mb-3">
        <div class="card-header bg-white fw-semibold">
            <i class="bi bi-person-check text-primary"></i> Người duyệt
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Người duyệt 1 <span class="text-danger">*</span></label>

                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-person-plus"></i></span>
                        <select asp-for="Approver1Id" asp-items="Model.AvailableApprover1s" class="form-select" id="approver1Select">
                            <option value="">-- Chọn người duyệt 1 --</option>
                        </select>
                    </div>
                    <span asp-validation-for="Approver1Id" class="text-danger small"></span>
                    <small class="text-muted">Chọn người duyệt 1 từ danh sách</small>
                </div>
                <div class="col-md-6">
                    <label asp-for="Approver2Id" class="form-label fw-semibold">Người duyệt 2 <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-person-plus"></i></span>
                        <select asp-for="Approver2Id" asp-items="Model.AvailableApprovers" class="form-select" id="approver2Select">
                            <option value="">-- Chọn người duyệt --</option>
                        </select>
                    </div>
                    <span asp-validation-for="Approver2Id" class="text-danger small"></span>
                    <small class="text-muted">Chọn từ danh sách người duyệt</small>
                </div>
            </div>
        </div>
    </div>

    @* Card 5: Mô tả *@
    <div class="card mb-3">
        <div class="card-header bg-white fw-semibold">
            <i class="bi bi-text-paragraph text-primary"></i> Mô tả chi tiết
        </div>
        <div class="card-body">
            <textarea asp-for="Description" class="form-control" id="descriptionEditor" rows="5"></textarea>
        </div>
    </div>

    @* Card 6: Đính kèm *@
    <div class="card mb-3">
        <div class="card-header bg-white fw-semibold">
            <i class="bi bi-paperclip text-primary"></i> Tệp đính kèm
        </div>
        <div class="card-body">
            <input asp-for="Attachments" class="form-control" type="file" multiple />
            <small class="text-muted mt-1 d-block">Có thể chọn nhiều file (hình ảnh, PDF, tài liệu...)</small>
        </div>
    </div>

    @* Submit *@
    <div class="d-flex gap-2 mb-4">
        <button type="submit" class="btn btn-primary px-4">
            <i class="bi bi-send"></i> Gửi đơn
        </button>
        <a asp-action="Index" class="btn btn-light">Hủy</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <link href="https://cdn.jsdelivr.net/npm/summernote@0.8.20/dist/summernote-bs5.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/summernote@0.8.20/dist/summernote-bs5.min.js"></script>
    <script>
        $(document).ready(function() {
            $('#descriptionEditor').summernote({
                height: 200,
                toolbar: [
                    ['style', ['bold', 'italic', 'underline', 'clear']],
                    ['para', ['ul', 'ol']],
                    ['insert', ['link']],
                    ['view', ['codeview']]
                ],
                placeholder: 'Nhập mô tả chi tiết...'
            });
        });

        var requestTypeSelect = document.getElementById('requestType');
        var startDate = document.getElementById('startDate');
        var endDate = document.getElementById('endDate');
        var startDateLabel = document.getElementById('startDateLabel');
        var endDateLabel = document.getElementById('endDateLabel');
        var halfDayStartOpt = document.getElementById('halfDayStartOpt');
        var halfDayEndOpt = document.getElementById('halfDayEndOpt');
        var halfDayStartWrap = document.getElementById('halfDayStartWrap');
        var halfDayEndWrap = document.getElementById('halfDayEndWrap');
        var endDateWrap = document.getElementById('endDateWrap');
        var startTimeWrap = document.getElementById('startTimeWrap');
        var endTimeWrap = document.getElementById('endTimeWrap');
        var startTimeInput = document.getElementById('startTimeInput');
        var endTimeInput = document.getElementById('endTimeInput');
        var totalDays = document.getElementById('totalDays');
        var totalDaysHidden = document.getElementById('totalDaysHidden');
        var totalDaysWrap = document.getElementById('totalDaysWrap');
        var leaveReasonSelect = document.getElementById('leaveReasonSelect');
        var countsAsWorkDisplay = document.getElementById('countsAsWorkDisplay');
        var checkInOutTypeWrap = document.getElementById('checkInOutTypeWrap');
        var checkInOutType = document.getElementById('checkInOutType');
        var titleWrap = document.getElementById('titleWrap');

        function updateFormByRequestType(type) {
            // Reset visibility
            halfDayStartWrap.style.display = '';
            halfDayEndWrap.style.display = '';
            endDateWrap.style.display = '';
            startTimeWrap.style.display = 'none';
            endTimeWrap.style.display = 'none';
            totalDaysWrap.style.display = '';
            checkInOutTypeWrap.style.display = 'none';

            // Adjust title wrap width
            titleWrap.className = 'col-md-8';

            // RequestType: 0=Leave, 1=CheckInOut, 2=Absence, 3=WorkFromHome
            if (type === 1) {
                // CheckInOut: Show dropdown to select type, then show appropriate time field
                checkInOutTypeWrap.style.display = '';
                titleWrap.className = 'col-md-4';
                startDateLabel.innerHTML = 'Ngày quên checkin/out <span class="text-danger">*</span>';
                endDateWrap.style.display = 'none';
                halfDayStartWrap.style.display = 'none';
                halfDayEndWrap.style.display = 'none';
                totalDaysWrap.style.display = 'none';

                // Show time input based on CheckInOutType
                updateCheckInOutTimeFields();

                // Set end date same as start date
                endDate.value = startDate.value;
            } else if (type === 2) {
                // Absence: Select 1 day and time range, hide "Tổng ngày"
                startDateLabel.innerHTML = 'Ngày vắng <span class="text-danger">*</span>';
                endDateWrap.style.display = 'none';
                startTimeWrap.style.display = '';
                endTimeWrap.style.display = '';
                halfDayStartWrap.style.display = 'none';
                halfDayEndWrap.style.display = 'none';
                totalDaysWrap.style.display = 'none'; // Hide "Tổng ngày" for Absence

                // Set end date same as start date
                endDate.value = startDate.value;
            } else if (type === 3) {
                // WorkFromHome: Chỉ cần ngày hoặc ca sáng/chiều
                startDateLabel.innerHTML = 'Ngày làm ở nhà <span class="text-danger">*</span>';
                endDateWrap.style.display = 'none';
                halfDayEndWrap.style.display = 'none';
                // Set end date same as start date
                endDate.value = startDate.value;
            } else {
                // Leave (default): Full date range with half-day options
                startDateLabel.innerHTML = 'Từ ngày <span class="text-danger">*</span>';
                endDateLabel.innerHTML = 'Đến ngày <span class="text-danger">*</span>';
            }
        }

        function updateCheckInOutTimeFields() {
            var checkInOutTypeValue = parseInt(checkInOutType.value);
            if (checkInOutTypeValue === 0) {
                // Missed Check In: Show start time only
                startTimeWrap.style.display = '';
                endTimeWrap.style.display = 'none';
            } else {
                // Missed Check Out: Show end time only
                startTimeWrap.style.display = 'none';
                endTimeWrap.style.display = '';
            }
        }

        function calcDays() {
            var type = parseInt(requestTypeSelect.value);
            var s = startDate.value, e = endDate.value;
            
            // For CheckInOut and WorkFromHome, sync end date with start date
            if (type === 1 || type === 3) {
                endDate.value = s;
                e = s;
            }
            
            if (s && e) {
                var diff = (new Date(e) - new Date(s)) / (1000*60*60*24) + 1;
                
                // Only calculate half-days for Leave and WorkFromHome
                if (type === 0 || type === 3) {
                    var startOpt = parseInt(halfDayStartOpt.value);
                    var endOpt = parseInt(halfDayEndOpt.value);
                    if (diff === 1) {
                        // Same day: if either is half-day
                        if (startOpt > 0) diff = 0.5;
                    } else {
                        if (startOpt > 0) diff -= 0.5;
                        if (endOpt > 0) diff -= 0.5;
                    }
                }
                
                diff = Math.max(diff, 0.5);
                totalDays.value = diff;
                totalDaysHidden.value = diff;
                
                // When same day, hide end half-day (for Leave type only)
                if (type === 0) {
                    halfDayEndWrap.style.display = (s === e) ? 'none' : '';
                }

                // Check leave balance after calculating days
                checkLeaveBalance();
            }
        }

        async function checkLeaveBalance() {
            // Only check for Leave requests (RequestType = 0)
            if (requestTypeSelect.value !== '0') {
                document.getElementById('leaveBalanceCard').style.display = 'none';
                return;
            }

            const startDateValue = startDate.value;
            const endDateValue = endDate.value;

            if (!startDateValue || !endDateValue) {
                document.getElementById('leaveBalanceCard').style.display = 'none';
                return;
            }

            // Show the balance card for Leave requests
            document.getElementById('leaveBalanceCard').style.display = 'block';

            const isHalfDayStart = parseInt(halfDayStartOpt.value) > 0;
            const isHalfDayEnd = parseInt(halfDayEndOpt.value) > 0;

            try {
                const response = await fetch(`/Request/GetLeaveBalance?startDate=${startDateValue}&endDate=${endDateValue}&isHalfDayStart=${isHalfDayStart}&isHalfDayEnd=${isHalfDayEnd}`);
                const data = await response.json();
                updateBalanceDisplay(data);
            } catch (error) {
                console.error('Error checking leave balance:', error);
                updateBalanceDisplay({
                    message: 'Không thể kiểm tra số dư phép. Vui lòng thử lại.',
                    hasSufficientBalance: false
                });
            }
        }

        function updateBalanceDisplay(balanceData) {
            const balanceInfo = document.getElementById('balanceInfo');
            const alertClass = balanceData.hasSufficientBalance ? 'alert-success' : 'alert-warning';
            const iconClass = balanceData.hasSufficientBalance ? 'bi-check-circle' : 'bi-exclamation-triangle';

            balanceInfo.innerHTML = `
                <div class="alert ${alertClass} mb-0">
                    <i class="bi ${iconClass} me-2"></i>
                    ${balanceData.message}
                </div>
            `;
        }

        startDate.addEventListener('change', calcDays);
        endDate.addEventListener('change', calcDays);
        halfDayStartOpt.addEventListener('change', calcDays);
        halfDayEndOpt.addEventListener('change', calcDays);

        function loadReasons(type) {
            fetch('/Request/GetReasons?type=' + type)
                .then(r => r.json())
                .then(data => {
                    leaveReasonSelect.innerHTML = '<option value="">-- Chọn lý do --</option>';
                    data.forEach(function(r) {
                        var opt = document.createElement('option');
                        opt.value = r.value;
                        opt.textContent = r.text + ' \u2192 ' + (r.countsAsWork ? 'Tính công' : 'Không tính công');
                        leaveReasonSelect.appendChild(opt);
                    });
                    if (data.length === 1) {
                        leaveReasonSelect.value = data[0].value;
                        updateCountsAsWork(data[0].countsAsWork);
                    }
                });
        }

        function updateCountsAsWork(v) {
            countsAsWorkDisplay.innerHTML = v
                ? '<i class="bi bi-check-circle text-success me-2"></i> Tính công'
                : '<i class="bi bi-x-circle text-danger me-2"></i> Không tính công';
        }

        requestTypeSelect.addEventListener('change', function() {
            var type = parseInt(this.value);
            updateFormByRequestType(type);
            loadReasons(type);
            calcDays();
            checkLeaveBalance(); // Check balance when request type changes
        });

        checkInOutType.addEventListener('change', function() {
            updateCheckInOutTimeFields();
        });

        leaveReasonSelect.addEventListener('change', function() {
            if (this.value) {
                var text = this.options[this.selectedIndex].textContent;
                updateCountsAsWork(!text.includes('Không tính công'));
            }
        });

        // Initialize form based on default request type
        updateFormByRequestType(parseInt(requestTypeSelect.value));
        calcDays();
    </script>
}
