@model RequestCreateViewModel
@using managerCMN.Models.Enums
@{
    ViewData["Title"] = "Chỉnh sửa đơn từ";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h4 class="mb-0"><i class="bi bi-pencil-square"></i> Chỉnh sửa đơn từ <span class="badge bg-warning text-dark ms-2">#@Model.RequestId</span></h4>
        <small class="text-muted">Chỉnh sửa thông tin đơn đang chờ duyệt</small>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
</div>

<form asp-action="Edit" asp-route-id="@Model.RequestId" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    @* Card 1: Thông tin chung *@
    <div class="card mb-3">
        <div class="card-header bg-white fw-semibold">
            <i class="bi bi-info-circle text-primary"></i> Thông tin chung
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="RequestType" class="form-label fw-semibold">Loại đơn <span class="text-danger">*</span></label>
                    <select asp-for="RequestType" class="form-select" id="requestType">
                        <option value="0">Xin nghỉ</option>
                        <option value="1">Checkin/out</option>
                        <option value="2">Vắng mặt</option>
                        <option value="3">Làm ở nhà (WFH)</option>
                    </select>
                    <select asp-for="CheckInOutType" class="form-select mt-2" id="checkInOutType" style="display: none;">
                        <option value="0">Quên check in</option>
                        <option value="1">Quên check out</option>
                        <option value="2">Đi trễ</option>
                        <option value="3">Về sớm</option>
                    </select>
                </div>
                <div class="col-md-8">
                    <label asp-for="Title" class="form-label fw-semibold">Tiêu đề <span class="text-danger">*</span></label>
                    <input asp-for="Title" class="form-control" placeholder="VD: Xin nghỉ phép ngày 20/03..." />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>
            </div>
        </div>
    </div>

    @* Card 2: Thời gian *@
    <div class="card mb-3">
        <div class="card-header bg-white fw-semibold">
            <i class="bi bi-calendar-event text-primary"></i> Thời gian
        </div>
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label asp-for="StartTime" class="form-label fw-semibold">Từ ngày <span class="text-danger">*</span></label>
                    <input asp-for="StartDate" class="form-control" type="date" id="startDate" required />
                    <span asp-validation-for="StartTime" class="text-danger small"></span>
                </div>
                <div class="col-md-2" id="startTimeWrap" style="display: none;">
                    <label asp-for="StartClock" class="form-label fw-semibold">Giờ bắt đầu</label>
                    <input asp-for="StartClock" type="time" class="form-control form-control-sm" id="startTimeInput" />
                    <span asp-validation-for="StartClock" class="text-danger small"></span>
                </div>
                <div class="col-md-2" id="halfDayStartWrap">
                    <label class="form-label fw-semibold">Ca bắt đầu</label>
                    <select asp-for="HalfDayStartOption" class="form-select form-select-sm" id="halfDayStartOpt">
                        <option value="0">Cả ngày</option>
                        <option value="1">Nửa ca sáng</option>
                        <option value="2">Nửa ca chiều</option>
                    </select>
                </div>
                <div class="col-md-3" id="endDateWrap">
                    <label asp-for="EndTime" class="form-label fw-semibold">Đến ngày <span class="text-danger">*</span></label>
                    <input asp-for="EndDate" class="form-control" type="date" id="endDate" required />
                </div>
                <div class="col-md-2" id="endTimeWrap" style="display: none;">
                    <label asp-for="EndClock" class="form-label fw-semibold">Giờ kết thúc</label>
                    <input asp-for="EndClock" type="time" class="form-control form-control-sm" id="endTimeInput" />
                    <span asp-validation-for="EndClock" class="text-danger small"></span>
                </div>
                <div class="col-md-2" id="halfDayEndWrap">
                    <label class="form-label fw-semibold">Ca kết thúc</label>
                    <select asp-for="HalfDayEndOption" class="form-select form-select-sm" id="halfDayEndOpt">
                        <option value="0">Cả ngày</option>
                        <option value="1">Nửa ca sáng</option>
                        <option value="2">Nửa ca chiều</option>
                    </select>
                </div>
                <div class="col-md-2" id="totalDaysWrap">
                    <label class="form-label fw-semibold">Tổng ngày</label>
                    <div class="input-group">
                        <input type="text" class="form-control bg-light fw-semibold text-center" id="totalDays" readonly />
                        <span class="input-group-text">ngày</span>
                    </div>
                    <input asp-for="TotalDays" type="hidden" id="totalDaysHidden" />
                </div>
            </div>
        </div>
    </div>

    @* Card 3: Lý do *@
    <div class="card mb-3">
        <div class="card-header bg-white fw-semibold">
            <i class="bi bi-card-text text-primary"></i> Lý do
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-8">
                    <label class="form-label fw-semibold">Lý do <span class="text-danger">*</span></label>
                    <select asp-for="LeaveReason" class="form-select" id="leaveReasonSelect" required>
                        <option value="">-- Chọn lý do --</option>
                        @if (Model.AvailableReasons != null)
                        {
                            foreach (var r in Model.AvailableReasons)
                            {
                                <option value="@r.Value" selected="@(r.Value == ((int?)Model.LeaveReason)?.ToString())">@r.Text</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Tính công</label>
                    <div class="form-control bg-light d-flex align-items-center" id="countsAsWorkDisplay">
                        <i class="bi bi-check-circle text-success me-2"></i> Tính công
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Card 4: Người duyệt *@
    <div class="card mb-3">
        <div class="card-header bg-white fw-semibold">
            <i class="bi bi-person-check text-primary"></i> Người duyệt
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Người duyệt 1 <span class="text-danger">*</span></label>

                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-person-plus"></i></span>
                        <select asp-for="Approver1Id" asp-items="Model.AvailableApprover1s" class="form-select" required>
                            <option value="">-- Chọn người duyệt 1 --</option>
                        </select>
                    </div>
                    <span asp-validation-for="Approver1Id" class="text-danger small"></span>
                    <small class="text-muted">Chọn người duyệt 1 từ danh sách</small>
                </div>
                <div class="col-md-6">
                    <label asp-for="Approver2Id" class="form-label fw-semibold">Người duyệt 2 <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-person-plus"></i></span>
                        <select asp-for="Approver2Id" asp-items="Model.AvailableApprovers" class="form-select" required>
                            <option value="">-- Chọn người duyệt --</option>
                        </select>
                    </div>
                    <span asp-validation-for="Approver2Id" class="text-danger small"></span>
                </div>
            </div>
        </div>
    </div>

    @* Card 5: Mô tả *@
    <div class="card mb-3">
        <div class="card-header bg-white fw-semibold">
            <i class="bi bi-text-paragraph text-primary"></i> Mô tả chi tiết
        </div>
        <div class="card-body">
            <textarea asp-for="Description" class="form-control" id="descriptionEditor" rows="5"></textarea>
        </div>
    </div>

    @* Submit *@
    <div class="d-flex gap-2 mb-4">
        <button type="submit" class="btn btn-warning px-4">
            <i class="bi bi-save"></i> Lưu thay đổi
        </button>
        <a asp-action="Details" asp-route-id="@Model.RequestId" class="btn btn-light">Hủy</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <link href="https://cdn.jsdelivr.net/npm/summernote@0.8.20/dist/summernote-bs5.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/summernote@0.8.20/dist/summernote-bs5.min.js"></script>
    <script>
        $(document).ready(function() {
            $('#descriptionEditor').summernote({
                height: 200,
                toolbar: [
                    ['style', ['bold', 'italic', 'underline', 'clear']],
                    ['para', ['ul', 'ol']],
                    ['insert', ['link']],
                    ['view', ['codeview']]
                ],
                placeholder: 'Nhập mô tả chi tiết...'
            });
        });

        var requestTypeSelect = document.getElementById('requestType');
        var checkInOutType = document.getElementById('checkInOutType');
        var startDate = document.getElementById('startDate');
        var endDate = document.getElementById('endDate');
        var startDateLabel = startDate.closest('.col-md-3').querySelector('label');
        var startTimeWrap = document.getElementById('startTimeWrap');
        var endTimeWrap = document.getElementById('endTimeWrap');
        var startTimeInput = document.getElementById('startTimeInput');
        var endTimeInput = document.getElementById('endTimeInput');
        var halfDayStartOpt = document.getElementById('halfDayStartOpt');
        var halfDayEndOpt = document.getElementById('halfDayEndOpt');
        var halfDayStartWrap = document.getElementById('halfDayStartWrap');
        var halfDayEndWrap = document.getElementById('halfDayEndWrap');
        var endDateWrap = document.getElementById('endDateWrap');
        var endDateLabel = endDateWrap.querySelector('label');
        var totalDaysWrap = document.getElementById('totalDaysWrap');
        var totalDays = document.getElementById('totalDays');
        var totalDaysHidden = document.getElementById('totalDaysHidden');
        var leaveReasonSelect = document.getElementById('leaveReasonSelect');
        var countsAsWorkDisplay = document.getElementById('countsAsWorkDisplay');
        var startTimeLabel = startTimeWrap.querySelector('label');
        var endTimeLabel = endTimeWrap.querySelector('label');

        function updateFormByRequestType(type) {
            startTimeLabel.textContent = 'Gi\u1edd b\u1eaft \u0111\u1ea7u';
            endTimeLabel.textContent = 'Gi\u1edd k\u1ebft th\u00fac';
            halfDayStartWrap.style.display = '';
            halfDayEndWrap.style.display = '';
            endDateWrap.style.display = '';
            startTimeWrap.style.display = 'none';
            endTimeWrap.style.display = 'none';
            totalDaysWrap.style.display = '';
            checkInOutType.style.display = 'none';

            if (type === 1) {
                startDateLabel.innerHTML = 'Ng\u00e0y checkin/out <span class="text-danger">*</span>';
                endDateWrap.style.display = 'none';
                halfDayStartWrap.style.display = 'none';
                halfDayEndWrap.style.display = 'none';
                totalDaysWrap.style.display = 'none';
                checkInOutType.style.display = '';
                updateCheckInOutTimeFields();
                endDate.value = startDate.value;
            } else if (type === 2) {
                startDateLabel.innerHTML = 'Ng\u00e0y v\u1eafng <span class="text-danger">*</span>';
                endDateWrap.style.display = 'none';
                startTimeWrap.style.display = '';
                endTimeWrap.style.display = '';
                halfDayStartWrap.style.display = 'none';
                halfDayEndWrap.style.display = 'none';
                totalDaysWrap.style.display = 'none';
                endDate.value = startDate.value;
            } else if (type === 3) {
                startDateLabel.innerHTML = 'Ng\u00e0y l\u00e0m \u1edf nh\u00e0 <span class="text-danger">*</span>';
                endDateWrap.style.display = 'none';
                halfDayEndWrap.style.display = 'none';
                endDate.value = startDate.value;
            } else {
                startDateLabel.innerHTML = 'T\u1eeb ng\u00e0y <span class="text-danger">*</span>';
                endDateLabel.innerHTML = '\u0110\u1ebfn ng\u00e0y <span class="text-danger">*</span>';
            }

            syncTimeFieldRequirements(type);
        }

        function updateCheckInOutTimeFields() {
            var checkInOutTypeValue = parseInt(checkInOutType.value || '0');
            if (checkInOutTypeValue === 0 || checkInOutTypeValue === 2) {
                startTimeWrap.style.display = '';
                endTimeWrap.style.display = 'none';
            } else {
                startTimeWrap.style.display = 'none';
                endTimeWrap.style.display = '';
            }

            syncTimeFieldRequirements(parseInt(requestTypeSelect.value));
        }

        function syncTimeFieldRequirements(type) {
            startTimeInput.required = false;
            endTimeInput.required = false;

            if (type === 2) {
                startTimeInput.required = true;
                endTimeInput.required = true;
                return;
            }

            if (type === 1) {
                var checkInOutTypeValue = parseInt(checkInOutType.value || '0');
                startTimeInput.required = checkInOutTypeValue === 0 || checkInOutTypeValue === 2;
                endTimeInput.required = checkInOutTypeValue === 1 || checkInOutTypeValue === 3;
            }
        }

        async function calcDays() {
            var type = parseInt(requestTypeSelect.value);
            var s = startDate.value, e = endDate.value;

            if (!s || !e) {
                totalDays.value = '';
                totalDaysHidden.value = '';
                return;
            }

            if (type === 1 || type === 2 || type === 3) {
                endDate.value = s;
                e = s;
            }

            halfDayEndWrap.style.display = (s === e && type === 0) ? 'none' : halfDayEndWrap.style.display;

            if (type === 0) {
                const isHalfDayStart = parseInt(halfDayStartOpt.value) > 0;
                const isHalfDayEnd = parseInt(halfDayEndOpt.value) > 0;

                try {
                    const response = await fetch(`/Request/GetLeaveBalance?startDate=${s}&endDate=${e}&isHalfDayStart=${isHalfDayStart}&isHalfDayEnd=${isHalfDayEnd}`);
                    const data = await response.json();

                    if (response.ok) {
                        totalDays.value = data.totalDays ?? '';
                        totalDaysHidden.value = data.totalDays ?? '';
                    } else {
                        totalDays.value = '';
                        totalDaysHidden.value = '';
                    }
                } catch (error) {
                    console.error('Error calculating leave days:', error);
                    totalDays.value = '';
                    totalDaysHidden.value = '';
                }

                return;
            }

            var diff = (new Date(e) - new Date(s)) / (1000 * 60 * 60 * 24) + 1;
            if (type === 3) {
                var startOpt = parseInt(halfDayStartOpt.value);
                var endOpt = parseInt(halfDayEndOpt.value);
                if (diff === 1) {
                    if (startOpt > 0) diff = 0.5;
                } else {
                    if (startOpt > 0) diff -= 0.5;
                    if (endOpt > 0) diff -= 0.5;
                }
            }

            if (diff <= 0) {
                totalDays.value = '';
                totalDaysHidden.value = '';
                return;
            }

            totalDays.value = diff;
            totalDaysHidden.value = diff;
        }

        startDate.addEventListener('change', calcDays);
        endDate.addEventListener('change', calcDays);
        halfDayStartOpt.addEventListener('change', calcDays);
        halfDayEndOpt.addEventListener('change', calcDays);

        function loadReasons(type, selectedValue) {
            fetch('/Request/GetReasons?type=' + type)
                .then(r => r.json())
                .then(data => {
                    leaveReasonSelect.innerHTML = '<option value="">-- Chọn lý do --</option>';
                    data.forEach(function(r) {
                        var opt = document.createElement('option');
                        opt.value = r.value;
                        opt.dataset.countsAsWork = r.countsAsWork;
                        opt.dataset.deductsLeave = r.deductsLeave;
                        opt.textContent = r.text + ' \u2192 ' + (r.countsAsWork ? 'Tính công' : 'Không tính công');
                        opt.textContent = r.statusText ? (r.text + ' -> ' + r.statusText) : opt.textContent;
                        if (selectedValue !== undefined && r.value == selectedValue) opt.selected = true;
                        leaveReasonSelect.appendChild(opt);
                    });
                    // Update display for currently selected
                    if (leaveReasonSelect.value) {
                        var selText = leaveReasonSelect.options[leaveReasonSelect.selectedIndex]?.textContent ?? '';
                        updateCountsAsWork(!selText.includes('Không tính công'));
                    }
                });
        }

        function updateCountsAsWork(v) {
            countsAsWorkDisplay.innerHTML = v
                ? '<i class="bi bi-check-circle text-success me-2"></i> Tính công'
                : '<i class="bi bi-x-circle text-danger me-2"></i> Không tính công';
        }

        requestTypeSelect.addEventListener('change', function() {
            updateFormByRequestType(parseInt(this.value));
            loadReasons(parseInt(this.value));
            calcDays();
        });

        checkInOutType.addEventListener('change', function() {
            updateCheckInOutTimeFields();
            calcDays();
        });

        leaveReasonSelect.addEventListener('change', function() {
            if (this.value) {
                var text = this.options[this.selectedIndex].textContent;
                updateCountsAsWork(!text.includes('Không tính công'));
            }
        });

        // Init on page load with existing values
        var initType = parseInt(requestTypeSelect.value);
        var initReason = '@((int?)Model.LeaveReason)';
        updateFormByRequestType(initType);
        loadReasons(initType, initReason !== '' ? initReason : undefined);
        calcDays();
    </script>
}
