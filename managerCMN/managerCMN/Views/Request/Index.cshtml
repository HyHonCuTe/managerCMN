@model IEnumerable<Request>
@{
    ViewData["Title"] = "Đơn từ";
    var leaveSummary = ViewBag.LeaveSummary as LeaveBalanceSummaryViewModel;
    var leaveRequests = ViewBag.LeaveRequests as List<LeaveRequest> ?? new List<LeaveRequest>();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-send"></i> Đơn từ của tôi</h4>
    <div>
        <a asp-controller="Leave" asp-action="Create" class="btn btn-success me-1"><i class="bi bi-calendar-plus"></i> Tạo đơn nghỉ phép</a>
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Tạo đơn mới</a>
    </div>
</div>

@* Leave Balance Summary *@
@if (leaveSummary != null)
{
    <div class="row g-3 mb-3">
        <div class="col-md-3"><div class="card stat-card primary"><div class="card-body"><div class="stat-label">Phép năm đã cấp</div><div class="stat-value text-primary">@leaveSummary.CurrentYearAllocated</div></div></div></div>
        <div class="col-md-3"><div class="card stat-card success"><div class="card-body"><div class="stat-label">Đã dùng có lương</div><div class="stat-value text-success">@leaveSummary.PaidLeaveTaken</div></div></div></div>
        <div class="col-md-3"><div class="card stat-card info"><div class="card-body"><div class="stat-label">Còn lại</div><div class="stat-value text-info">@leaveSummary.TotalRemaining</div></div></div></div>
        <div class="col-md-3"><div class="card stat-card warning"><div class="card-body"><div class="stat-label">Bảo lưu năm trước</div><div class="stat-value text-warning">@leaveSummary.CarryForwardRemaining</div></div></div></div>
    </div>

    <div class="alert alert-light border mb-3">
        Đã cấp @leaveSummary.GrantedQuarters/4 đợt phép cho năm @leaveSummary.Year. Phần phép bảo lưu còn lại chỉ dùng đến hết ngày @leaveSummary.CarryForwardExpiryDate?.ToString("dd/MM/yyyy"). Nếu hết phép của đợt hiện tại thì đơn mới sẽ tự chuyển thành nghỉ không phép.
    </div>
}

@* Tabs *@
<ul class="nav nav-tabs mb-0" role="tablist">
    <li class="nav-item">
        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tabRequests" type="button">
            <i class="bi bi-send me-1"></i> Đơn từ <span class="badge bg-secondary ms-1">@Model.Count()</span>
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabLeave" type="button">
            <i class="bi bi-calendar-check me-1"></i> Nghỉ phép <span class="badge bg-secondary ms-1">@leaveRequests.Count</span>
        </button>
    </li>
</ul>

<div class="tab-content">
    @* General Requests Tab *@
    <div class="tab-pane fade show active" id="tabRequests" role="tabpanel">
        <div class="card border-top-0 rounded-top-0">
            <div class="card-body">
                <table class="table table-hover data-table">
                    <thead class="table-light">
                        <tr><th>Loại</th><th>Thời gian</th><th>Lý do</th><th>Trạng thái</th><th>Thao tác</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var req in Model)
                        {
                        <tr>
                            <td>
                                @switch (req.RequestType)
                                {
                                    case RequestType.Leave: <span class="badge bg-info">Nghỉ phép</span> break;
                                    case RequestType.CheckInOut: <span class="badge bg-primary">Chấm công</span> break;
                                    case RequestType.Absence: <span class="badge bg-warning">Vắng mặt</span> break;
                                    case RequestType.WorkFromHome: <span class="badge bg-success">WFH</span> break;
                                }
                            </td>
                            <td>@req.StartTime.ToString("dd/MM HH:mm") - @req.EndTime.ToString("dd/MM HH:mm")</td>
                            <td>@req.Reason</td>
                            <td>
                                @switch (req.Status)
                                {
                                    case RequestStatus.Pending: <span class="badge bg-warning">Chờ duyệt</span> break;
                                    case RequestStatus.ManagerApproved: <span class="badge bg-info">Manager đã duyệt</span> break;
                                    case RequestStatus.HRApproved: <span class="badge bg-success">Đã duyệt</span> break;
                                    case RequestStatus.Rejected: <span class="badge bg-danger">Từ chối</span> break;
                                }
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@req.RequestId" class="btn btn-sm btn-outline-info"><i class="bi bi-eye"></i></a>
                            </td>
                        </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @* Leave Requests Tab *@
    <div class="tab-pane fade" id="tabLeave" role="tabpanel">
        <div class="card border-top-0 rounded-top-0">
            <div class="card-body">
                <table class="table table-hover data-table">
                    <thead class="table-light">
                        <tr><th>Từ ngày</th><th>Đến ngày</th><th>Số ngày</th><th>Lý do</th><th>Loại</th><th>Trạng thái</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var req in leaveRequests)
                        {
                        <tr>
                            <td>@req.StartDate.ToString("dd/MM/yyyy")</td>
                            <td>@req.EndDate.ToString("dd/MM/yyyy")</td>
                            <td>@req.TotalDays</td>
                            <td>@req.Reason</td>
                            <td><span class="badge bg-@(req.PayType == LeavePayType.Paid ? "success" : "secondary")">@(req.PayType == LeavePayType.Paid ? "Có lương" : "Không lương")</span></td>
                            <td>
                                @switch (req.Status)
                                {
                                    case RequestStatus.Pending: <span class="badge bg-warning">Chờ duyệt</span> break;
                                    case RequestStatus.HRApproved: <span class="badge bg-success">Đã duyệt</span> break;
                                    case RequestStatus.Rejected: <span class="badge bg-danger">Từ chối</span> break;
                                    default: <span class="badge bg-secondary">@req.Status</span> break;
                                }
                            </td>
                        </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
