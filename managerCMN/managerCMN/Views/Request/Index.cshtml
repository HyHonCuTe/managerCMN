@model IEnumerable<Request>
@using managerCMN.Models.Enums
@using managerCMN.Helpers
@using Microsoft.AspNetCore.Html
@{
    ViewData["Title"] = "Đơn từ";
    var leaveSummary = ViewBag.LeaveSummary as LeaveBalanceSummaryViewModel;
    var allRequests = Model.ToList();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h4 class="mb-0"><i class="bi bi-send"></i> @(ViewBag.IsPrivileged == true ? "Tất cả đơn từ" : "Đơn từ của tôi")</h4>
        <small class="text-muted">@(ViewBag.IsPrivileged == true ? "Xem toàn bộ đơn từ của hệ thống" : "Quản lý tất cả đơn từ và theo dõi trạng thái")</small>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Tạo đơn mới
    </a>
</div>

@if (leaveSummary != null)
{
    <div class="row g-3 mb-3">
        <div class="col-md-3">
            <div class="card stat-card primary">
                <div class="card-body py-2">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="stat-label">Phép năm đã cấp</div>
                            <div class="stat-value text-primary">@leaveSummary.CurrentYearAllocated</div>
                        </div>
                        <i class="bi bi-calendar-plus fs-2 text-primary opacity-25"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stat-card success">
                <div class="card-body py-2">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="stat-label">Đã dùng có lương</div>
                            <div class="stat-value text-success">@leaveSummary.PaidLeaveTaken</div>
                        </div>
                        <i class="bi bi-check2-circle fs-2 text-success opacity-25"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stat-card info">
                <div class="card-body py-2">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="stat-label">Còn lại</div>
                            <div class="stat-value text-info">@leaveSummary.TotalRemaining</div>
                        </div>
                        <i class="bi bi-hourglass-split fs-2 text-info opacity-25"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stat-card warning">
                <div class="card-body py-2">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="stat-label">Bảo lưu năm trước</div>
                            <div class="stat-value text-warning">@leaveSummary.CarryForwardRemaining</div>
                        </div>
                        <i class="bi bi-arrow-repeat fs-2 text-warning opacity-25"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<ul class="nav nav-tabs mb-0" role="tablist">
    <li class="nav-item">
        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tabAll" type="button">
            <i class="bi bi-list-ul me-1"></i> Tất cả <span class="badge bg-secondary ms-1">@allRequests.Count</span>
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabLeave" type="button">
            <i class="bi bi-calendar-check me-1"></i> Nghỉ phép <span class="badge bg-info ms-1">@allRequests.Count(r => r.RequestType == RequestType.Leave)</span>
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabCheckInOut" type="button">
            <i class="bi bi-clock me-1"></i> Checkin/out <span class="badge bg-primary ms-1">@allRequests.Count(r => r.RequestType == RequestType.CheckInOut)</span>
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabAbsence" type="button">
            <i class="bi bi-person-dash me-1"></i> Vắng mặt <span class="badge bg-warning ms-1">@allRequests.Count(r => r.RequestType == RequestType.Absence)</span>
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabWFH" type="button">
            <i class="bi bi-house me-1"></i> WFH <span class="badge bg-success ms-1">@allRequests.Count(r => r.RequestType == RequestType.WorkFromHome)</span>
        </button>
    </li>
</ul>

<div class="tab-content">
    @{ await RenderTab("tabAll", allRequests, true); }
    @{ await RenderTab("tabLeave", allRequests.Where(r => r.RequestType == RequestType.Leave).ToList(), false); }
    @{ await RenderTab("tabCheckInOut", allRequests.Where(r => r.RequestType == RequestType.CheckInOut).ToList(), false); }
    @{ await RenderTab("tabAbsence", allRequests.Where(r => r.RequestType == RequestType.Absence).ToList(), false); }
    @{ await RenderTab("tabWFH", allRequests.Where(r => r.RequestType == RequestType.WorkFromHome).ToList(), false); }
</div>

@functions {
    async Task RenderTab(string tabId, List<Request> requests, bool isActive)
    {
        <div class="tab-pane fade @(isActive ? "show active" : "")" id="@tabId" role="tabpanel">
            <div class="card border-top-0 rounded-top-0">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0 request-tab-table">
                            <thead class="table-light">
                                <tr>
                                    @if (ViewBag.IsPrivileged == true)
                                    {
                                        <th style="min-width:160px">Nhân viên</th>
                                    }
                                    <th style="min-width:200px">Tiêu đề</th>
                                    <th>Loại</th>
                                    <th>Thời gian</th>
                                    <th class="text-center">Ngày</th>
                                    <th>Lý do</th>
                                    <th class="text-center">Tính công</th>
                                    <th class="text-center">Trạng thái</th>
                                    <th style="min-width:150px">Người duyệt</th>
                                    <th class="text-center">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var req in requests)
                                {
                                    <tr>
                                        @if (ViewBag.IsPrivileged == true)
                                        {
                                            <td>
                                                <div class="fw-semibold small">@req.Employee?.FullName</div>
                                                <small class="text-muted">@req.Employee?.EmployeeCode</small>
                                            </td>
                                        }
                                        <td>
                                            <a asp-action="Details" asp-route-id="@req.RequestId" class="text-decoration-none fw-semibold">
                                                @req.Title
                                            </a>
                                            <div class="small text-muted">@req.CreatedDate.ToVietnamTime().ToString("dd/MM/yyyy HH:mm")</div>
                                        </td>
                                        <td>@RenderTypeBadge(req.RequestType)</td>
                                        <td class="text-nowrap small">
                                            @req.StartTime.ToString("dd/MM/yyyy")<br />
                                            <span class="text-muted">~ @req.EndTime.ToString("dd/MM/yyyy")</span>
                                        </td>
                                        <td class="text-center">@req.TotalDays</td>
                                        <td><small>@(req.Reason ?? "-")</small></td>
                                        <td class="text-center">
                                            @if (req.CountsAsWork)
                                            {
                                                @(Html.Raw("<span class='badge bg-success-subtle text-success'>Có</span>"))
                                            }
                                            else
                                            {
                                                @(Html.Raw("<span class='badge bg-secondary-subtle text-secondary'>Không</span>"))
                                            }
                                        </td>
                                        <td class="text-center">@RenderStatusBadge(req.Status)</td>
                                        <td>@RenderApprovers(req)</td>
                                        <td class="text-center">
                                            <div class="btn-group btn-group-sm">
                                                <a asp-action="Details" asp-route-id="@req.RequestId" class="btn btn-outline-info" title="Chi tiết"><i class="bi bi-eye"></i></a>
                                                @if (req.Status == RequestStatus.Pending)
                                                {
                                                    <a asp-action="Edit" asp-route-id="@req.RequestId" class="btn btn-outline-warning" title="Sửa đơn"><i class="bi bi-pencil"></i></a>
                                                    <form asp-action="Cancel" asp-route-id="@req.RequestId" method="post" class="d-inline" onsubmit="return confirm('Bạn chắc chắn muốn hủy đơn này?')">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit" class="btn btn-outline-danger" title="Hủy đơn"><i class="bi bi-x-lg"></i></button>
                                                    </form>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                                @if (!requests.Any())
                                {
                                    <tr>
                                        <td colspan="@(ViewBag.IsPrivileged == true ? 10 : 9)" class="text-center py-5 text-muted">
                                            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                            Chưa có đơn từ nào. <a asp-action="Create" class="text-decoration-none">Tạo đơn mới</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }

    IHtmlContent RenderTypeBadge(RequestType type) => type switch
    {
        RequestType.Leave => Html.Raw("<span class='badge bg-info'><i class='bi bi-calendar-check'></i> Nghỉ phép</span>"),
        RequestType.CheckInOut => Html.Raw("<span class='badge bg-primary'><i class='bi bi-clock'></i> Checkin/out</span>"),
        RequestType.Absence => Html.Raw("<span class='badge bg-warning text-dark'><i class='bi bi-person-dash'></i> Vắng mặt</span>"),
        RequestType.WorkFromHome => Html.Raw("<span class='badge bg-success'><i class='bi bi-house'></i> WFH</span>"),
        _ => Html.Raw("<span class='badge bg-secondary'>Khác</span>")
    };

    IHtmlContent RenderStatusBadge(RequestStatus status) => status switch
    {
        RequestStatus.Pending => Html.Raw("<span class='badge bg-warning text-dark'><i class='bi bi-hourglass-split'></i> Chờ duyệt</span>"),
        RequestStatus.Approver1Approved => Html.Raw("<span class='badge bg-info'><i class='bi bi-check'></i> ND1 duyệt</span>"),
        RequestStatus.Approver2Approved => Html.Raw("<span class='badge bg-info'><i class='bi bi-check'></i> ND2 duyệt</span>"),
        RequestStatus.FullyApproved => Html.Raw("<span class='badge bg-success'><i class='bi bi-check-all'></i> Đã duyệt</span>"),
        RequestStatus.Rejected => Html.Raw("<span class='badge bg-danger'><i class='bi bi-x-lg'></i> Từ chối</span>"),
        RequestStatus.Cancelled => Html.Raw("<span class='badge bg-secondary'><i class='bi bi-dash'></i> Đã hủy</span>"),
        _ => Html.Raw($"<span class='badge bg-secondary'>{status}</span>")
    };

    IHtmlContent RenderApprovers(Request req)
    {
        var approvals = req.Approvals?.OrderBy(a => a.ApproverOrder).ToList() ?? new();
        if (!approvals.Any()) return Html.Raw("<span class='text-muted'>-</span>");

        var html = "";
        foreach (var a in approvals)
        {
            var icon = a.Status switch
            {
                ApprovalStatus.Approved => "bi-check-circle-fill text-success",
                ApprovalStatus.Rejected => "bi-x-circle-fill text-danger",
                _ => "bi-clock-fill text-warning"
            };
            html += $"<div class='small'><i class='bi {icon}'></i> <span class='text-muted'>ND{a.ApproverOrder}:</span> {a.Approver?.FullName ?? "?"}</div>";
        }
        return Html.Raw(html);
    }
}

@section Scripts {
<script>
    $(document).ready(function () {
        var dtOpts = {
            language: { url: '//cdn.datatables.net/plug-ins/1.13.11/i18n/vi.json' },
            paging: false, scrollY: '520px', scrollCollapse: true, order: []
        };
        // Init the active (visible) tab's table
        $('#tabAll .request-tab-table').DataTable(dtOpts);
        // Init hidden tab tables when they become visible
        $('button[data-bs-toggle="tab"]').on('shown.bs.tab', function (e) {
            var target = $(e.target).attr('data-bs-target');
            var table = $(target).find('.request-tab-table');
            if (!$.fn.DataTable.isDataTable(table)) {
                table.DataTable(dtOpts);
            }
        });
    });
</script>
}
