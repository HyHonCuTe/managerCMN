@model IEnumerable<Request>
@{
    ViewData["Title"] = "Đơn từ của tôi";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-send"></i> Đơn từ của tôi</h4>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Tạo đơn mới</a>
</div>

<div class="card">
    <div class="card-body">
        <table class="table table-hover data-table">
            <thead class="table-light">
                <tr><th>Loại</th><th>Thời gian</th><th>Lý do</th><th>Trạng thái</th><th>Thao tác</th></tr>
            </thead>
            <tbody>
                @foreach (var req in Model)
                {
                <tr>
                    <td>
                        @switch (req.RequestType)
                        {
                            case RequestType.Leave: <span class="badge bg-info">Nghỉ phép</span> break;
                            case RequestType.CheckInOut: <span class="badge bg-primary">Chấm công</span> break;
                            case RequestType.Absence: <span class="badge bg-warning">Vắng mặt</span> break;
                            case RequestType.WorkFromHome: <span class="badge bg-success">WFH</span> break;
                        }
                    </td>
                    <td>@req.StartTime.ToString("dd/MM HH:mm") - @req.EndTime.ToString("dd/MM HH:mm")</td>
                    <td>@req.Reason</td>
                    <td>
                        @switch (req.Status)
                        {
                            case RequestStatus.Pending: <span class="badge bg-warning">Chờ duyệt</span> break;
                            case RequestStatus.ManagerApproved: <span class="badge bg-info">Manager đã duyệt</span> break;
                            case RequestStatus.HRApproved: <span class="badge bg-success">Đã duyệt</span> break;
                            case RequestStatus.Rejected: <span class="badge bg-danger">Từ chối</span> break;
                        }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@req.RequestId" class="btn btn-sm btn-outline-info"><i class="bi bi-eye"></i></a>
                    </td>
                </tr>
                }
            </tbody>
        </table>
    </div>
</div>
