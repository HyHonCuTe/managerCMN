                </div>
                <div class="mb-3">
                    <label class="form-label">Lý do</label>
                    <textarea name="reason" class="form-control" rows="3" placeholder="VD: Công tác ngoài, cách ly,..." maxlength="500">@fa.Reason</textarea>
                    <small class="text-muted">Tối đa 500 ký tự</small>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Lưu</button>
            </div>
        </form>
    </div>
</div>
}
}

<script>
$(document).ready(function() {
    // Load permissions when role is selected
    $('#roleSelector').change(function() {
        const roleId = $(this).val();
        if (!roleId) {
            $('.permission-check').prop('checked', false).prop('disabled', true);
            $('#savePermissions').prop('disabled', true);
            return;
        }

        // Enable checkboxes and save button
        $('.permission-check').prop('disabled', false);
        $('#savePermissions').prop('disabled', false);

        // Get current permissions for role
        $.get('/Settings/GetRolePermissions?roleId=' + roleId, function(data) {
            // Uncheck all
            $('.permission-check').prop('checked', false);

            // Check permissions for this role
            data.forEach(function(permId) {
                $('[data-permission-id="' + permId + '"]').prop('checked', true);
            });
        });
    });

    // Save permissions
    $('#savePermissions').click(function() {
        const roleId = $('#roleSelector').val();
        if (!roleId) {
            alert('Vui lòng chọn vai trò');
            return;
        }

        const selectedPermissions = $('.permission-check:checked')
            .map(function() { return $(this).data('permission-id'); })
            .get();

        $.ajax({
            url: '/Settings/UpdateRolePermissions',
            method: 'POST',
            data: {
                roleId: roleId,
                permissionIds: selectedPermissions,
                __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
            },
            success: function(response) {
                if (response.success) {
                    alert(response.message);
                } else {
                    alert(response.message || 'Có lỗi xảy ra!');
                }
            },
            error: function() {
                alert('Có lỗi xảy ra khi lưu phân quyền!');
            }
        });
    });
});
</script>
