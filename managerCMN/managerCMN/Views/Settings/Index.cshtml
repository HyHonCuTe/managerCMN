        </div>
    </div>

    <div class="col-lg-6">
        <div class="card">
            <div class="card-header bg-white fw-semibold">
                <i class="bi bi-shield-lock text-primary"></i> Phân quyền cho vai trò
            </div>
            <div class="card-body">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label fw-semibold">Chọn vai trò</label>
                    <select id="roleSelector" class="form-select">
                        <option value="">-- Chọn vai trò --</option>
                        @foreach (var role in roles)
                        {
                            <option value="@role.RoleId">@role.RoleName - @role.Description</option>
                        }
                    </select>
                </div>

                <div id="permissionsContainer" style="max-height: 350px; overflow-y: auto;">
                    @foreach (var category in permissionsByCategory)
                    {
                        <div class="mb-3 border-bottom pb-2">
                            <h6 class="fw-bold text-primary mb-2">
                                <i class="bi bi-folder"></i> @category.Key
                            </h6>
                            @foreach (var perm in category.Value)
                            {
                                <div class="form-check ms-3">
                                    <input type="checkbox"
                                           class="form-check-input permission-check"
                                           data-permission-id="@perm.PermissionId"
                                           id="perm_@perm.PermissionId"
                                           disabled>
                                    <label class="form-check-label" for="perm_@perm.PermissionId">
                                        @perm.PermissionName
                                        @if (perm.PermissionKey == "System.ALL")
                                        {
                                            <span class="badge bg-danger ms-1">TOÀN QUYỀN</span>
                                        }
                                    </label>
                                    @if (!string.IsNullOrEmpty(perm.Description))
                                    {
                                        <small class="text-muted d-block ms-4">@perm.Description</small>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>

                <button id="savePermissions" class="btn btn-primary w-100 mt-3" disabled>
                    <i class="bi bi-check-lg"></i> Lưu phân quyền
                </button>
            </div>
        </div>

        <div class="card border-0 bg-light mt-3">
            <div class="card-body">
                <h6 class="fw-semibold"><i class="bi bi-info-circle text-primary"></i> Hướng dẫn</h6>
                <ul class="small text-muted mb-0">
                    <li class="mb-1"><strong>Admin</strong>: Quản trị viên hệ thống, có hầu hết các quyền.</li>
                    <li class="mb-1"><strong>Manager</strong>: Quản lý phòng ban, có quyền duyệt đơn và xem nhân viên.</li>
                    <li class="mb-1"><strong>User</strong>: Nhân viên thường, có quyền tạo đơn và xem chấm công cơ bản.</li>
                    <li><strong class="text-danger">TOÀN QUYỀN</strong>: Quyền cao nhất, bypass mọi kiểm tra phân quyền.</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@* Edit User Role Modals *@
@foreach (var user in users)
{
<div class="modal fade" id="editUserRoleModal-@user.UserId" tabindex="-1">
    <div class="modal-dialog">
        <form asp-action="UpdateUserRoles" method="post" class="modal-content">
            @Html.AntiForgeryToken()
            <input type="hidden" name="userId" value="@user.UserId" />
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-person-gear"></i> Sửa vai trò: @(user.Employee?.FullName ?? user.Email)</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Chọn vai trò</label>
                    @foreach (var role in roles)
                    {
                        <div class="form-check">
                            <input type="checkbox" name="roleIds" value="@role.RoleId" class="form-check-input"
                                   id="role_@(user.UserId)_@role.RoleId"
                                   @(user.UserRoles.Any(ur => ur.RoleId == role.RoleId) ? "checked" : "") />
                            <label class="form-check-label" for="role_@(user.UserId)_@role.RoleId">
                                <span class="badge bg-@(role.RoleName == "Admin" ? "danger" : role.RoleName == "Manager" ? "warning" : "secondary")">@role.RoleName</span>
                                <small class="text-muted ms-1">@role.Description</small>
                            </label>
                        </div>
                    }
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Lưu</button>
            </div>
        </form>
    </div>
</div>
}

}

@* ========== FULL ATTENDANCE SETTINGS TAB (Chấm công đầy đủ tự động) ========== *@
@if (activeTab == "fullattendance")
{
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-check-circle"></i> Danh sách chấm công đầy đủ tự động</span>
        <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addFullAttendanceModal">
            <i class="bi bi-plus-lg"></i> Thêm nhân viên
        </button>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Mã NV</th>
                    <th>Họ tên</th>
                    <th>Phòng ban</th>
                    <th>Lý do</th>
                    <th>Ngày thêm</th>
                    <th style="width:120px">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var fa in fullAttendanceEmployees)
                {
                <tr>
                    <td><code>@fa.Employee.EmployeeCode</code></td>
                    <td><strong>@fa.Employee.FullName</strong></td>
                    <td><small class="text-muted">@fa.Employee.Department?.DepartmentName</small></td>
                    <td><small>@(string.IsNullOrEmpty(fa.Reason) ? "---" : fa.Reason)</small></td>
                    <td><small class="text-muted">@fa.CreatedDate.ToString("dd/MM/yyyy")</small></td>
                    <td>
                        <button class="btn btn-sm btn-outline-warning" data-bs-toggle="modal" data-bs-target="#editFullAttendanceModal-@fa.Id">
                            <i class="bi bi-pencil"></i>
                        </button>
                        <form asp-action="DeleteFullAttendanceEmployee" asp-route-id="@fa.Id" method="post" class="d-inline" onsubmit="return confirm('Xóa nhân viên này khỏi danh sách?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                        </form>
                    </td>
                </tr>
                }
                @if (!fullAttendanceEmployees.Any())
                {
                <tr><td colspan="6" class="text-center text-muted py-3">Chưa có nhân viên nào trong danh sách.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@* Add Full Attendance Modal *@
<div class="modal fade" id="addFullAttendanceModal" tabindex="-1">
    <div class="modal-dialog">
        <form asp-action="AddFullAttendanceEmployee" method="post" class="modal-content">
            @Html.AntiForgeryToken()
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-plus-lg"></i> Thêm nhân viên chấm công đầy đủ</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Chọn nhân viên <span class="text-danger">*</span></label>
                    <select name="employeeId" class="form-select" required>
