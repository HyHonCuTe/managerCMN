                                <td><small class="text-muted">@emp.Email</small></td>
                                <td class="text-center">
                                    <form asp-action="RemoveApprover" method="post" class="d-inline" onsubmit="return confirm('Xóa người duyệt này khỏi danh sách?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="employeeId" value="@emp.EmployeeId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa khỏi danh sách">
                                            <i class="bi bi-person-dash"></i>
                                        </button>
                                    </form>
