@{
    ViewData["Title"] = "Cài đặt danh mục";
    var activeTab = ViewBag.ActiveTab as string ?? "departments";
    var departments = ViewBag.Departments as IEnumerable<Department> ?? Enumerable.Empty<Department>();
    var positions = ViewBag.Positions as IEnumerable<Position> ?? Enumerable.Empty<Position>();
    var jobTitles = ViewBag.JobTitles as IEnumerable<JobTitle> ?? Enumerable.Empty<JobTitle>();
    var employeeList = ViewBag.EmployeeList as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    var assetCategories = ViewBag.AssetCategories as IEnumerable<AssetCategory> ?? Enumerable.Empty<AssetCategory>();
    var brands = ViewBag.Brands as IEnumerable<Brand> ?? Enumerable.Empty<Brand>();
    var suppliers = ViewBag.Suppliers as IEnumerable<Supplier> ?? Enumerable.Empty<Supplier>();
    var holidays = ViewBag.Holidays as IEnumerable<Holiday> ?? Enumerable.Empty<Holiday>();
    var approvers = ViewBag.Approvers as List<Employee> ?? new List<Employee>();
    var nonApprovers = ViewBag.NonApprovers as List<Employee> ?? new List<Employee>();
    var fullAttendanceEmployees = ViewBag.FullAttendanceEmployees as IEnumerable<FullAttendanceEmployee> ?? Enumerable.Empty<FullAttendanceEmployee>();
    var availableEmployeesForFullAttendance = ViewBag.AvailableEmployeesForFullAttendance as List<Employee> ?? new List<Employee>();
    var users = ViewBag.Users as IEnumerable<User> ?? Enumerable.Empty<User>();
    var roles = ViewBag.Roles as IEnumerable<Role> ?? Enumerable.Empty<Role>();
    var permissionsByCategory = ViewBag.PermissionsByCategory as Dictionary<string, List<Permission>> ?? new Dictionary<string, List<Permission>>();
}

<div class="mb-4">
    <h4 class="mb-0"><i class="bi bi-gear"></i> Cài đặt danh mục</h4>
    <small class="text-muted">Quản lý phòng ban, chức vụ và các danh mục hệ thống</small>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-circle"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<ul class="nav nav-tabs mb-3" role="tablist">
    <li class="nav-item">
        <a class="nav-link @(activeTab == "departments" ? "active" : "")" href="?tab=departments">
            <i class="bi bi-diagram-3"></i> Phòng ban
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(activeTab == "jobtitles" ? "active" : "")" href="?tab=jobtitles">
            <i class="bi bi-person-badge"></i> Chức vụ
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(activeTab == "positions" ? "active" : "")" href="?tab=positions">
            <i class="bi bi-briefcase"></i> Vị trí
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(activeTab == "categories" ? "active" : "")" href="?tab=categories">
            <i class="bi bi-tags"></i> Danh mục tài sản
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(activeTab == "brands" ? "active" : "")" href="?tab=brands">
            <i class="bi bi-building"></i> Hãng sản xuất
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(activeTab == "suppliers" ? "active" : "")" href="?tab=suppliers">
            <i class="bi bi-truck"></i> Nhà cung cấp
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(activeTab == "holidays" ? "active" : "")" href="?tab=holidays">
            <i class="bi bi-calendar-heart"></i> Ngày nghỉ lễ
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(activeTab == "approvers" ? "active" : "")" href="?tab=approvers">
            <i class="bi bi-person-check"></i> Người duyệt đơn
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(activeTab == "fullattendance" ? "active" : "")" href="?tab=fullattendance">
            <i class="bi bi-check-circle"></i> Chấm công đầy đủ
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(activeTab == "permissions" ? "active" : "")" href="?tab=permissions">
            <i class="bi bi-shield-lock"></i> Phân quyền
        </a>
    </li>
</ul>

@* ========== DEPARTMENTS TAB ========== *@
@if (activeTab == "departments")
{
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-diagram-3"></i> Danh sách phòng ban</span>
        <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addDeptModal">
            <i class="bi bi-plus-lg"></i> Thêm phòng ban
        </button>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Tên phòng ban</th>
                    <th>Trưởng phòng</th>
                    <th>Mô tả</th>
                    <th style="width:120px">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var dept in departments)
                {
                <tr>
                    <td><strong>@dept.DepartmentName</strong></td>
                    <td>@dept.Manager?.FullName</td>
                    <td class="text-muted">@dept.Description</td>
                    <td>
                        <button class="btn btn-sm btn-outline-warning" data-bs-toggle="modal" data-bs-target="#editDeptModal-@dept.DepartmentId">
                            <i class="bi bi-pencil"></i>
                        </button>
                        <form asp-action="DeleteDepartment" asp-route-id="@dept.DepartmentId" method="post" class="d-inline" onsubmit="return confirm('Xóa phòng ban này?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                        </form>
                    </td>
                </tr>
                }
                @if (!departments.Any())
                {
                <tr><td colspan="4" class="text-center text-muted py-3">Chưa có phòng ban nào.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@* Add Department Modal *@
<div class="modal fade" id="addDeptModal" tabindex="-1">
    <div class="modal-dialog">
        <form asp-action="CreateDepartment" method="post" class="modal-content">
            @Html.AntiForgeryToken()
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-plus-lg"></i> Thêm phòng ban</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Tên phòng ban <span class="text-danger">*</span></label>
                    <input name="departmentName" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Trưởng phòng</label>
                    <select name="managerId" class="form-select">
                        <option value="">-- Chọn --</option>
                        @if (employeeList != null)
                        {
                            @foreach (var item in employeeList)
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Mô tả</label>
                    <textarea name="description" class="form-control" rows="2"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Thêm</button>
            </div>
        </form>
    </div>
</div>

@* Edit Department Modals *@
@foreach (var dept in departments)
{
<div class="modal fade" id="editDeptModal-@dept.DepartmentId" tabindex="-1">
    <div class="modal-dialog">
        <form asp-action="EditDepartment" method="post" class="modal-content">
            @Html.AntiForgeryToken()
            <input type="hidden" name="departmentId" value="@dept.DepartmentId" />
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-pencil"></i> Sửa phòng ban</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Tên phòng ban <span class="text-danger">*</span></label>
                    <input name="departmentName" class="form-control" value="@dept.DepartmentName" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Trưởng phòng</label>
                    <select name="managerId" class="form-select">
                        <option value="">-- Chọn --</option>
                        @if (employeeList != null)
                        {
                            @foreach (var item in employeeList)
                            {
                                if (item.Value == dept.ManagerId?.ToString())
                                {
                                    <option value="@item.Value" selected>@item.Text</option>
                                }
                                else
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            }
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Mô tả</label>
                    <textarea name="description" class="form-control" rows="2">@dept.Description</textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Lưu</button>
            </div>
        </form>
    </div>
</div>
}
}

