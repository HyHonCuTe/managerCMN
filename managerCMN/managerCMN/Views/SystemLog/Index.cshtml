@model IEnumerable<SystemLog>
@{
    ViewData["Title"] = "Nhật ký Hệ thống";
    var currentPage = ViewBag.CurrentPage;
    var totalPages = ViewBag.TotalPages;
    var totalCount = ViewBag.TotalCount;
    var pageSize = ViewBag.PageSize;
}

<h4 class="mb-3">
    <i class="bi bi-journal-text"></i> Nhật ký Hệ thống
    @if (totalCount != null)
    {
        <small class="text-muted">(@totalCount bản ghi)</small>
    }
</h4>

<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end" id="logFilterForm">
            <input type="hidden" name="page" value="1" />
            <div class="col-auto">
                <label class="form-label">Module</label>
                <input name="module" id="moduleFilter" class="form-control" value="@ViewBag.Module" placeholder="VD: Employee, Leave..." />
            </div>
            <div class="col-auto">
                <label class="form-label">Từ</label>
                <input name="from" type="date" class="form-control" value="@(ViewBag.From != null ? ((DateTime)ViewBag.From).ToString("yyyy-MM-dd") : "")" />
            </div>
            <div class="col-auto">
                <label class="form-label">Đến</label>
                <input name="to" type="date" class="form-control" value="@(ViewBag.To != null ? ((DateTime)ViewBag.To).ToString("yyyy-MM-dd") : "")" />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-funnel me-1"></i> Lọc
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <table class="table table-hover data-table">
            <thead class="table-light">
                <tr><th>Thời gian</th><th>Người dùng</th><th>Module</th><th>Hành động</th><th>Chi tiết</th><th>IP</th></tr>
            </thead>
            <tbody>
                @foreach (var log in Model)
                {
                <tr>
                    <td>@log.CreatedDate.ToString("dd/MM/yyyy HH:mm:ss")</td>
                    <td>@log.UserId</td>
                    <td><span class="badge bg-secondary">@log.Module</span></td>
                    <td>@log.Action</td>
                    <td><small>@log.DataAfter</small></td>
                    <td><small>@log.IPAddress</small></td>
                </tr>
                }
            </tbody>
        </table>

        @if (totalPages != null && totalPages > 1)
        {
            <nav class="mt-3">
                <ul class="pagination justify-content-center">
                    @if (currentPage > 1)
                    {
                        <li class="page-item">
                            <a asp-action="Index"
                               asp-route-module="@ViewBag.Module"
                               asp-route-from="@ViewBag.From"
                               asp-route-to="@ViewBag.To"
                               asp-route-page="@(currentPage - 1)"
                               class="page-link">Trước</a>
                        </li>
                    }

                    @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a asp-action="Index"
                               asp-route-module="@ViewBag.Module"
                               asp-route-from="@ViewBag.From"
                               asp-route-to="@ViewBag.To"
                               asp-route-page="@i"
                               class="page-link">@i</a>
                        </li>
                    }

                    @if (currentPage < totalPages)
                    {
                        <li class="page-item">
                            <a asp-action="Index"
                               asp-route-module="@ViewBag.Module"
                               asp-route-from="@ViewBag.From"
                               asp-route-to="@ViewBag.To"
                               asp-route-page="@(currentPage + 1)"
                               class="page-link">Sau</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    </div>
</div>

@section Scripts {
<script>
    const logForm = document.getElementById('logFilterForm');

    // Debounced auto-submit for module input
    let _logFilterTimer;
    document.getElementById('moduleFilter').addEventListener('input', function () {
        clearTimeout(_logFilterTimer);
        _logFilterTimer = setTimeout(() => logForm.submit(), 600);
    });

    // Auto-submit for date inputs
    document.querySelectorAll('input[type="date"]').forEach(dateInput => {
        dateInput.addEventListener('change', () => logForm.submit());
    });
</script>
}
