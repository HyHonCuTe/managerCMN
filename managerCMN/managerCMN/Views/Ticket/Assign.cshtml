@model Ticket
@{
    ViewData["Title"] = "Gán Ticket";
}

<div class="card">
    <div class="card-header"><i class="bi bi-person-plus"></i> Gán ticket: @Model.Title</div>
    <div class="card-body">
        <form asp-action="Assign" asp-route-id="@Model.TicketId" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label">Người xử lý <span class="text-danger">*</span></label>
                <select name="assigneeId" class="form-select" asp-items="@ViewBag.Employees">
                    <option value="">-- Chọn --</option>
                </select>
            </div>
            <button type="submit" class="btn btn-success"><i class="bi bi-check-lg"></i> Gán</button>
            <a asp-action="Index" class="btn btn-secondary">Hủy</a>
        </form>
    </div>
</div>
