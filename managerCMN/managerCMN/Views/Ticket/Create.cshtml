@model TicketCreateViewModel
@using System.Linq
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    var groupedRecipients = (Model.AvailableRecipients ?? new List<SelectListItem>())
        .GroupBy(item => string.IsNullOrWhiteSpace(item.Group?.Name) ? "Chưa phân phòng ban" : item.Group!.Name)
        .OrderBy(group => group.Key)
        .ToList();
    var selectedRecipientIds = new HashSet<string>((Model.RecipientIds ?? new List<int>()).Select(id => id.ToString()));
    ViewData["Title"] = "Tạo Ticket";
}

<style>
    .recipient-selector {
        position: relative;
    }
    .recipient-dropdown {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        max-height: 300px;
        overflow-y: auto;
        background: white;
        border: 1px solid #dee2e6;
        border-radius: 0.375rem;
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
        z-index: 1050;
        display: none;
    }
    .recipient-dropdown.show {
        display: block;
    }
    .recipient-search {
        position: sticky;
        top: 0;
        background: white;
        padding: 0.5rem;
        border-bottom: 1px solid #dee2e6;
    }
    .recipient-list {
        padding: 0;
        margin: 0;
        list-style: none;
    }
    .recipient-item {
        padding: 0.5rem 1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        transition: background-color 0.15s;
    }
    .recipient-item:hover {
        background-color: #f8f9fa;
    }
    .recipient-item.selected {
        background-color: #e7f1ff;
    }
    .recipient-item input[type="checkbox"] {
        width: 1.1em;
        height: 1.1em;
        cursor: pointer;
    }
    .selected-recipients {
        display: flex;
        flex-wrap: wrap;
        gap: 0.25rem;
        min-height: 38px;
        padding: 0.375rem;
        border: 1px solid #dee2e6;
        border-radius: 0.375rem;
        cursor: pointer;
        background: white;
    }
    .selected-recipients:focus-within {
        border-color: #86b7fe;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
    }
    .selected-recipient-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.25rem 0.5rem;
        background: #0d6efd;
        color: white;
        border-radius: 0.25rem;
        font-size: 0.875rem;
    }
    .selected-recipient-badge .remove-btn {
        cursor: pointer;
        opacity: 0.7;
        font-weight: bold;
    }
    .selected-recipient-badge .remove-btn:hover {
        opacity: 1;
    }
    .recipient-placeholder {
        color: #6c757d;
        padding: 0.25rem;
    }
    .no-results {
        padding: 1rem;
        text-align: center;
        color: #6c757d;
    }
    .selected-recipients.is-open {
        border-color: #86b7fe;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15);
    }
    .recipient-dropdown {
        top: calc(100% + 0.5rem);
        max-height: 420px;
        overflow: hidden;
        border-radius: 0.75rem;
        box-shadow: 0 1rem 2rem rgba(0, 0, 0, 0.12);
    }
    .recipient-search {
        padding: 0.875rem;
        border-bottom: 1px solid #e9ecef;
        z-index: 1;
    }
    .recipient-toolbar {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto auto auto;
        gap: 0.5rem;
        margin-top: 0.75rem;
    }
    .recipient-groups {
        max-height: 300px;
        overflow-y: auto;
        padding: 0.5rem 0;
    }
    .recipient-group {
        padding: 0 0.75rem 0.75rem;
    }
    .recipient-group.hidden {
        display: none;
    }
    .recipient-group-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.75rem;
        padding: 0.4rem 0.25rem 0.5rem;
    }
    .recipient-group-title {
        font-weight: 700;
        color: #334155;
    }
    .recipient-group-meta {
        font-size: 0.8rem;
        color: #6c757d;
    }
    .recipient-group-banner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.75rem;
        padding: 0.5rem 0.75rem 0.35rem;
        margin-top: 0.5rem;
        color: #334155;
        font-weight: 700;
    }
    .recipient-group-banner:first-child {
        margin-top: 0;
    }
    .recipient-group-banner.hidden {
        display: none;
    }
    .recipient-group-banner .select-group-btn {
        font-size: 0.82rem;
        font-weight: 600;
        padding: 0;
    }
    .recipient-list {
        display: grid;
        gap: 0.35rem;
        max-height: 320px;
        overflow-y: auto;
        padding: 0.35rem 0.25rem 0.5rem;
        margin: 0;
        scrollbar-gutter: stable;
    }
    .recipient-item {
        padding: 0.65rem 0.75rem;
        align-items: flex-start;
        gap: 0.75rem;
        border: 1px solid #eef2f7;
        border-radius: 0.75rem;
        background: #fff;
    }
    .recipient-item:hover {
        border-color: #cfe2ff;
        background: #f8fbff;
    }
    .recipient-item.selected {
        border-color: #86b7fe;
        background: #e7f1ff;
    }
    .recipient-item input[type="checkbox"] {
        width: 1.1rem;
        height: 1.1rem;
        margin-top: 0.15rem;
    }
    .recipient-item-label {
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
        margin: 0;
        flex: 1;
        cursor: pointer;
    }
    .recipient-item-name {
        font-weight: 600;
        color: #1f2937;
    }
    .recipient-item-meta {
        font-size: 0.82rem;
        color: #6c757d;
    }
    .recipient-summary {
        margin-top: 0.5rem;
        font-size: 0.82rem;
        color: #6c757d;
    }
    .selected-recipient-badge {
        gap: 0.375rem;
        padding: 0.35rem 0.625rem;
        border-radius: 999px;
        line-height: 1.1;
    }
    .selected-recipient-badge .remove-btn {
        font-weight: 700;
    }
    @@media (max-width: 767.98px) {
        .recipient-toolbar {
            grid-template-columns: 1fr 1fr;
        }
    }
</style>

<div class="card">
    <div class="card-header bg-primary text-white">
        <i class="bi bi-envelope-plus"></i> Tạo ticket mới
    </div>
    <div class="card-body">
        <form asp-action="Create" method="post" enctype="multipart/form-data" id="ticketForm">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:none;"></div>

            <div class="row g-3">
                <!-- Title -->
                <div class="col-12">
                    <label asp-for="Title" class="form-label">Tiêu đề <span class="text-danger">*</span></label>
                    <input asp-for="Title" class="form-control" placeholder="Nhập tiêu đề ticket..." />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <!-- Recipients with custom multi-select -->
                <div class="col-12">
                    <label class="form-label">Người nhận <span class="text-danger">*</span></label>
                    <div class="recipient-selector" id="recipientSelector">
                        <div class="selected-recipients" id="selectedRecipients" tabindex="0">
                            <span class="recipient-placeholder" id="recipientPlaceholder">Nhấp để chọn người nhận...</span>
                        </div>
                        <div class="recipient-dropdown" id="recipientDropdown">
                            <div class="recipient-search">
                                <div class="recipient-toolbar">
                                    <select class="form-select form-select-sm" id="departmentSelector">
                                        <option value="">Chọn nhanh theo phòng ban...</option>
                                        @foreach (var group in groupedRecipients)
                                        {
                                            <option value="@group.Key">@group.Key</option>
                                        }
                                    </select>
                                    <button type="button" class="btn btn-outline-primary btn-sm" id="selectDepartmentBtn">Chọn phòng ban</button>
                                    <button type="button" class="btn btn-outline-primary btn-sm" id="selectAllRecipients">Chọn tất cả</button>
                                    <button type="button" class="btn btn-outline-secondary btn-sm" id="clearRecipients">Bỏ chọn</button>
                                </div>
                                <div class="recipient-summary" id="recipientSummary">
                                    Có thể chọn nhanh theo phòng ban hoặc chọn tất cả nhân viên đang hoạt động.
                                </div>
                                <input type="text" class="form-control form-control-sm" id="recipientSearch" placeholder="Tìm kiếm theo tên...">
                            </div>
                            <ul class="recipient-list" id="recipientList">
                                @foreach (var recipient in Model.AvailableRecipients ?? new List<SelectListItem>())
                                {
                                    <li class="recipient-item" data-id="@recipient.Value" data-name="@recipient.Text" data-department="@(recipient.Group?.Name ?? "Chưa phân phòng ban")">
                                        <input type="checkbox" id="recipient_@recipient.Value" @(selectedRecipientIds.Contains(recipient.Value ?? string.Empty) ? "checked" : null)>
                                        <label for="recipient_@recipient.Value" class="recipient-item-label">
                                            <span class="recipient-item-name">@recipient.Text</span>
                                            <span class="recipient-item-meta">@(recipient.Group?.Name ?? "Chưa phân phòng ban")</span>
                                        </label>
                                    </li>
                                }
                            </ul>
                            <div class="no-results" id="noResults" style="display: none;">
                                Không tìm thấy kết quả
                            </div>
                        </div>
                    </div>
                    <!-- Hidden inputs for selected recipients -->
                    <div id="recipientInputs"></div>
                    <span asp-validation-for="RecipientIds" class="text-danger"></span>
                    <small class="text-muted">Nhấp vào ô để mở danh sách, gõ để tìm kiếm, tick để chọn nhiều người</small>
                </div>

                <!-- Priority & Urgency -->
                <div class="col-md-4">
                    <label asp-for="Priority" class="form-label">Độ ưu tiên</label>
                    <select asp-for="Priority" class="form-select">
                        <option value="@((int)TicketPriority.Low)">Thấp</option>
                        <option value="@((int)TicketPriority.Medium)" selected>Trung bình</option>
                        <option value="@((int)TicketPriority.High)">Cao</option>
                        <option value="@((int)TicketPriority.Critical)">Khẩn cấp</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label asp-for="Urgency" class="form-label">Độ khẩn</label>
                    <select asp-for="Urgency" class="form-select">
                        <option value="@((int)TicketUrgency.Normal)" selected>Bình thường</option>
                        <option value="@((int)TicketUrgency.Urgent)">Gấp</option>
                        <option value="@((int)TicketUrgency.VeryUrgent)">Rất gấp</option>
                        <option value="@((int)TicketUrgency.Immediate)">Ngay lập tức</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label asp-for="Deadline" class="form-label">Deadline</label>
                    <input asp-for="Deadline" type="date" class="form-control" />
                </div>

                <!-- Description -->
                <div class="col-12">
                    <label asp-for="Description" class="form-label">Nội dung</label>
                    <textarea asp-for="Description" class="form-control" rows="6" placeholder="Nhập nội dung chi tiết..."></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <!-- Attachments -->
                <div class="col-12">
                    <label asp-for="Attachments" class="form-label">Tệp đính kèm</label>
                    <input asp-for="Attachments" class="form-control" type="file" multiple />
                    <small class="text-muted">Có thể chọn nhiều file. Định dạng cho phép: PDF, Word, Excel, hình ảnh</small>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-send"></i> Gửi ticket
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-x-lg"></i> Hủy
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const selector = document.getElementById('recipientSelector');
            const selectedArea = document.getElementById('selectedRecipients');
            const dropdown = document.getElementById('recipientDropdown');
            const searchInput = document.getElementById('recipientSearch');
            const recipientList = document.getElementById('recipientList');
            const recipientInputs = document.getElementById('recipientInputs');
            const placeholder = document.getElementById('recipientPlaceholder');
            const noResults = document.getElementById('noResults');

            let selectedRecipients = new Map();

            // Toggle dropdown
            selectedArea.addEventListener('click', function(e) {
                if (e.target.classList.contains('remove-btn')) return;
                dropdown.classList.toggle('show');
                if (dropdown.classList.contains('show')) {
                    searchInput.focus();
                }
            });

            // Close dropdown when clicking outside
            document.addEventListener('click', function(e) {
                if (!selector.contains(e.target)) {
                    dropdown.classList.remove('show');
                }
            });

            // Search functionality
            searchInput.addEventListener('input', function() {
                const query = this.value.toLowerCase().trim();
                const items = recipientList.querySelectorAll('.recipient-item');
                let hasVisible = false;

                items.forEach(function(item) {
                    const name = item.dataset.name.toLowerCase();
                    if (name.includes(query)) {
                        item.style.display = 'flex';
                        hasVisible = true;
                    } else {
                        item.style.display = 'none';
                    }
                });

                noResults.style.display = hasVisible ? 'none' : 'block';
            });

            // Handle checkbox changes
            recipientList.addEventListener('change', function(e) {
                if (e.target.type === 'checkbox') {
                    const item = e.target.closest('.recipient-item');
                    const id = item.dataset.id;
                    const name = item.dataset.name;

                    if (e.target.checked) {
                        selectedRecipients.set(id, name);
                        item.classList.add('selected');
                    } else {
                        selectedRecipients.delete(id);
                        item.classList.remove('selected');
                    }

                    updateSelectedDisplay();
                }
            });

            // Click on item to toggle checkbox
            recipientList.addEventListener('click', function(e) {
                const item = e.target.closest('.recipient-item');
                if (item && e.target.type !== 'checkbox') {
                    const checkbox = item.querySelector('input[type="checkbox"]');
                    checkbox.checked = !checkbox.checked;
                    checkbox.dispatchEvent(new Event('change', { bubbles: true }));
                }
            });

            function updateSelectedDisplay() {
                // Clear current display
                selectedArea.innerHTML = '';

                if (selectedRecipients.size === 0) {
                    selectedArea.innerHTML = '<span class="recipient-placeholder">Nhấp để chọn người nhận...</span>';
                } else {
                    selectedRecipients.forEach(function(name, id) {
                        const badge = document.createElement('span');
                        badge.className = 'selected-recipient-badge';
                        badge.innerHTML = `${name} <span class="remove-btn" data-id="${id}">&times;</span>`;
                        selectedArea.appendChild(badge);
                    });
                }

                // Update hidden inputs
                recipientInputs.innerHTML = '';
                selectedRecipients.forEach(function(name, id) {
                    const input = document.createElement('input');
                    input.type = 'hidden';
                    input.name = 'RecipientIds';
                    input.value = id;
                    recipientInputs.appendChild(input);
                });
            }

            // Remove badge
            selectedArea.addEventListener('click', function(e) {
                if (e.target.classList.contains('remove-btn')) {
                    const id = e.target.dataset.id;
                    selectedRecipients.delete(id);

                    // Uncheck the checkbox
                    const checkbox = recipientList.querySelector(`.recipient-item[data-id="${id}"] input[type="checkbox"]`);
                    if (checkbox) {
                        checkbox.checked = false;
                        checkbox.closest('.recipient-item').classList.remove('selected');
                    }

                    updateSelectedDisplay();
                    e.stopPropagation();
                }
            });

            // Form validation
            document.getElementById('ticketForm').addEventListener('submit', function(e) {
                if (selectedRecipients.size === 0) {
                    e.preventDefault();
                    alert('Vui lòng chọn ít nhất một người nhận!');
                    dropdown.classList.add('show');
                    searchInput.focus();
                }
            });

            // Keyboard navigation
            searchInput.addEventListener('keydown', function(e) {
                if (e.key === 'Escape') {
                    dropdown.classList.remove('show');
                }
            });
        });
    </script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const selector = document.getElementById('recipientSelector');
            const selectedArea = document.getElementById('selectedRecipients');
            const dropdown = document.getElementById('recipientDropdown');
            const searchInput = document.getElementById('recipientSearch');
            const recipientList = document.getElementById('recipientList');
            const recipientInputs = document.getElementById('recipientInputs');
            const noResults = document.getElementById('noResults');
            const recipientSummary = document.getElementById('recipientSummary');
            const departmentSelector = document.getElementById('departmentSelector');
            const selectDepartmentBtn = document.getElementById('selectDepartmentBtn');
            const selectAllBtn = document.getElementById('selectAllRecipients');
            const clearBtn = document.getElementById('clearRecipients');
            const form = document.getElementById('ticketForm');

            if (!selector || !recipientList) {
                return;
            }

            const recipientItems = Array.from(recipientList.querySelectorAll('.recipient-item'));
            const groupedItems = recipientItems.reduce(function (map, item) {
                const department = item.dataset.department || 'Chưa phân phòng ban';
                if (!map.has(department)) {
                    map.set(department, []);
                }

                map.get(department).push(item);
                return map;
            }, new Map());

            const orderedDepartments = Array.from(groupedItems.keys()).sort(function (a, b) {
                return a.localeCompare(b, 'vi');
            });

            recipientList.innerHTML = '';

            orderedDepartments.forEach(function (department) {
                const banner = document.createElement('li');
                banner.className = 'recipient-group-banner';
                banner.dataset.department = department;
                banner.innerHTML = `
                    <span>${department}</span>
                    <button type="button" class="btn btn-link btn-sm select-group-btn" data-department="${department}">Chọn cả phòng ban</button>
                `;
                recipientList.appendChild(banner);

                groupedItems.get(department).forEach(function (item) {
                    recipientList.appendChild(item);
                });
            });

            const allRecipientItems = Array.from(recipientList.querySelectorAll('.recipient-item'));
            const allGroupBanners = Array.from(recipientList.querySelectorAll('.recipient-group-banner'));

            function normalize(value) {
                return (value || '').toLowerCase().trim();
            }

            function openDropdown() {
                dropdown.classList.add('show');
                selectedArea.classList.add('is-open');
            }

            function syncSelectedDisplay() {
                const checkedItems = allRecipientItems.filter(function (item) {
                    return item.querySelector('input[type="checkbox"]').checked;
                });

                allRecipientItems.forEach(function (item) {
                    item.classList.toggle('selected', item.querySelector('input[type="checkbox"]').checked);
                });

                selectedArea.innerHTML = '';
                recipientInputs.innerHTML = '';

                if (checkedItems.length === 0) {
                    selectedArea.innerHTML = '<span class="recipient-placeholder">Nhấp để chọn người nhận...</span>';
                } else {
                    checkedItems.forEach(function (item) {
                        const badge = document.createElement('span');
                        badge.className = 'selected-recipient-badge';
                        badge.innerHTML = `${item.dataset.name}<span class="remove-btn" data-id="${item.dataset.id}" title="Bỏ chọn">&times;</span>`;
                        selectedArea.appendChild(badge);

                        const input = document.createElement('input');
                        input.type = 'hidden';
                        input.name = 'RecipientIds';
                        input.value = item.dataset.id;
                        recipientInputs.appendChild(input);
                    });
                }

                if (recipientSummary) {
                    recipientSummary.textContent = checkedItems.length === 0
                        ? 'Có thể chọn nhanh theo phòng ban hoặc chọn tất cả nhân viên đang hoạt động.'
                        : `Đã chọn ${checkedItems.length} người nhận.`;
                }
            }

            function applyRecipientFilter() {
                const query = normalize(searchInput.value);
                let hasVisible = false;

                allRecipientItems.forEach(function (item) {
                    const matches = !query
                        || normalize(item.dataset.name).includes(query)
                        || normalize(item.dataset.department).includes(query);

                    item.style.display = matches ? 'flex' : 'none';
                    hasVisible = hasVisible || matches;
                });

                allGroupBanners.forEach(function (banner) {
                    const department = banner.dataset.department;
                    const hasVisibleItem = allRecipientItems.some(function (item) {
                        return item.dataset.department === department && item.style.display !== 'none';
                    });
                    banner.classList.toggle('hidden', !hasVisibleItem);
                });

                noResults.style.display = hasVisible ? 'none' : 'block';
            }

            function setDepartmentSelection(department) {
                if (!department) {
                    openDropdown();
                    searchInput.focus();
                    return;
                }

                allRecipientItems.forEach(function (item) {
                    if (item.dataset.department === department) {
                        const checkbox = item.querySelector('input[type="checkbox"]');
                        if (!checkbox.checked) {
                            checkbox.checked = true;
                            checkbox.dispatchEvent(new Event('change', { bubbles: true }));
                        }
                    }
                });

                syncSelectedDisplay();
                openDropdown();
                searchInput.focus();
            }

            allRecipientItems.forEach(function (item) {
                const checkbox = item.querySelector('input[type="checkbox"]');
                if (checkbox.checked) {
                    checkbox.dispatchEvent(new Event('change', { bubbles: true }));
                }
            });

            syncSelectedDisplay();
            applyRecipientFilter();

            searchInput.addEventListener('input', applyRecipientFilter);

            selectDepartmentBtn.addEventListener('click', function () {
                setDepartmentSelection(departmentSelector.value);
            });

            selectAllBtn.addEventListener('click', function () {
                allRecipientItems.forEach(function (item) {
                    const checkbox = item.querySelector('input[type="checkbox"]');
                    if (!checkbox.checked) {
                        checkbox.checked = true;
                        checkbox.dispatchEvent(new Event('change', { bubbles: true }));
                    }
                });

                syncSelectedDisplay();
                openDropdown();
                searchInput.focus();
            });

            clearBtn.addEventListener('click', function () {
                allRecipientItems.forEach(function (item) {
                    const checkbox = item.querySelector('input[type="checkbox"]');
                    if (checkbox.checked) {
                        checkbox.checked = false;
                        checkbox.dispatchEvent(new Event('change', { bubbles: true }));
                    }
                });

                syncSelectedDisplay();
                openDropdown();
                searchInput.focus();
            });

            recipientList.addEventListener('change', function (event) {
                if (event.target.type === 'checkbox') {
                    syncSelectedDisplay();
                }
            });

            recipientList.addEventListener('click', function (event) {
                const groupButton = event.target.closest('.select-group-btn');
                if (groupButton) {
                    event.preventDefault();
                    event.stopPropagation();
                    setDepartmentSelection(groupButton.dataset.department);
                }
            });

            selectedArea.addEventListener('click', function (event) {
                const removeButton = event.target.closest('.remove-btn');
                if (!removeButton) {
                    return;
                }

                const targetItem = recipientList.querySelector(`.recipient-item[data-id="${removeButton.dataset.id}"]`);
                if (targetItem) {
                    const checkbox = targetItem.querySelector('input[type="checkbox"]');
                    checkbox.checked = false;
                    checkbox.dispatchEvent(new Event('change', { bubbles: true }));
                }

                syncSelectedDisplay();
                event.stopPropagation();
            });

            form.addEventListener('submit', function () {
                syncSelectedDisplay();
            });
        });
    </script>
}
