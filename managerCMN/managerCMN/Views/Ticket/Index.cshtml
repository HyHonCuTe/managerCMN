@model TicketIndexViewModel
@using managerCMN.Helpers
@using managerCMN.Models.ViewModels
@{
    ViewData["Title"] = "Ticket";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h4 class="mb-0"><i class="bi bi-envelope"></i> Yêu cầu</h4>
        <small class="text-muted">Quản lý các yêu cầu công việc</small>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Tạo yêu cầu mới
    </a>
</div>

@section Scripts {
    <script>
        $(function () {
            const antiForgeryToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
            const toggleUrl = '@Url.Action("ToggleStar", "Ticket")';

            function setButtonState(button, isStarred) {
                const icon = button.querySelector('i');
                button.classList.toggle('is-starred', isStarred);
                button.setAttribute('aria-pressed', isStarred ? 'true' : 'false');
                button.setAttribute('title', isStarred ? 'Bo danh dau sao' : 'Danh dau sao');

                if (icon) {
                    icon.className = isStarred ? 'bi bi-star-fill' : 'bi bi-star';
                }
            }

            function setTicketStarState(ticketId, isStarred) {
                document.querySelectorAll(`tr[data-ticket-id="${ticketId}"]`).forEach(row => {
                    row.classList.toggle('ticket-row-starred', isStarred);

                    const button = row.querySelector('.ticket-star-toggle');
                    if (button) {
                        setButtonState(button, isStarred);
                    }
                });
            }

            document.addEventListener('click', async function (event) {
                const starButton = event.target.closest('.ticket-star-toggle');
                if (!starButton) {
                    return;
                }

                event.preventDefault();
                event.stopPropagation();

                const ticketId = Number.parseInt(starButton.dataset.ticketId, 10);
                if (!Number.isInteger(ticketId)) {
                    return;
                }

                const relatedButtons = document.querySelectorAll(`.ticket-star-toggle[data-ticket-id="${ticketId}"]`);
                relatedButtons.forEach(button => button.disabled = true);

                try {
                    const payload = new URLSearchParams();
                    payload.append('ticketId', ticketId.toString());
                    if (antiForgeryToken) {
                        payload.append('__RequestVerificationToken', antiForgeryToken);
                    }

                    const response = await fetch(toggleUrl, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: payload.toString()
                    });

                    if (!response.ok) {
                        throw new Error(`Toggle star failed with status ${response.status}`);
                    }

                    const result = await response.json();
                    if (result?.success === true && typeof result.isStarred === 'boolean') {
                        setTicketStarState(ticketId, result.isStarred);
                    }
                } catch (error) {
                    console.error(error);
                    showNotification('Không thể cập nhật đánh dấu lúc này.', 'danger');
                } finally {
                    relatedButtons.forEach(button => button.disabled = false);
                }
            });

            // DataTables inside hidden tabs need a manual resize after tab activation.
            $('button[data-bs-toggle="tab"]').on('shown.bs.tab', function () {
                $.fn.dataTable.tables({ visible: true, api: true }).columns.adjust();
            });

            $.fn.dataTable.tables({ visible: true, api: true }).columns.adjust();
        });
    </script>
}

@Html.AntiForgeryToken()

<div class="card">
    <div class="card-header p-0">
        <ul class="nav nav-tabs card-header-tabs" role="tablist">
            <li class="nav-item">
                <button class="nav-link @(Model.ActiveTab == "received" ? "active" : "")"
                        data-bs-toggle="tab" data-bs-target="#tabReceived" type="button">
                    <i class="bi bi-inbox me-1"></i> Nhận được
                    <span class="badge bg-info ms-1">@Model.ReceivedTickets.Count()</span>
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(Model.ActiveTab == "sent" ? "active" : "")"
                        data-bs-toggle="tab" data-bs-target="#tabSent" type="button">
                    <i class="bi bi-send me-1"></i> Gửi đi
                    <span class="badge bg-primary ms-1">@Model.SentTickets.Count()</span>
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(Model.ActiveTab == "expired" ? "active" : "")"
                        data-bs-toggle="tab" data-bs-target="#tabExpired" type="button">
                    <i class="bi bi-exclamation-triangle me-1"></i> Hết hạn
                    <span class="badge bg-danger ms-1">@Model.ExpiredTickets.Count()</span>
                </button>
            </li>
            @if (Model.IsAdmin)
            {
                <li class="nav-item">
                    <button class="nav-link @(Model.ActiveTab == "all" ? "active" : "")"
                            data-bs-toggle="tab" data-bs-target="#tabAll" type="button">
                        <i class="bi bi-list-ul me-1"></i> Tất cả
                        <span class="badge bg-secondary ms-1">@Model.AllTickets.Count()</span>
                    </button>
                </li>
            }
        </ul>
    </div>
    <div class="card-body">
        <div class="tab-content">
            <div class="tab-pane fade @(Model.ActiveTab == "received" ? "show active" : "")" id="tabReceived" role="tabpanel">
                @await Html.PartialAsync("_TicketTable", new TicketTableViewModel { Tickets = Model.ReceivedTickets, StarredTicketIds = Model.StarredTicketIds })
            </div>
            <div class="tab-pane fade @(Model.ActiveTab == "sent" ? "show active" : "")" id="tabSent" role="tabpanel">
                @await Html.PartialAsync("_TicketTable", new TicketTableViewModel { Tickets = Model.SentTickets, StarredTicketIds = Model.StarredTicketIds })
            </div>
            <div class="tab-pane fade @(Model.ActiveTab == "expired" ? "show active" : "")" id="tabExpired" role="tabpanel">
                @await Html.PartialAsync("_TicketTable", new TicketTableViewModel { Tickets = Model.ExpiredTickets, StarredTicketIds = Model.StarredTicketIds })
            </div>
            @if (Model.IsAdmin)
            {
                <div class="tab-pane fade @(Model.ActiveTab == "all" ? "show active" : "")" id="tabAll" role="tabpanel">
                    @await Html.PartialAsync("_TicketTable", new TicketTableViewModel { Tickets = Model.AllTickets, StarredTicketIds = Model.StarredTicketIds })
                </div>
            }
        </div>
    </div>
</div>
