@model IEnumerable<Ticket>
@{
    ViewData["Title"] = "Quản lý Ticket";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-ticket-detailed"></i> Danh sách Ticket</h4>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Tạo ticket</a>
</div>

<div class="card">
    <div class="card-body">
        <table class="table table-hover data-table">
            <thead class="table-light">
                <tr><th>ID</th><th>Tiêu đề</th><th>Độ ưu tiên</th><th>Người tạo</th><th>Người xử lý</th><th>Trạng thái</th><th>Thao tác</th></tr>
            </thead>
            <tbody>
                @foreach (var ticket in Model)
                {
                <tr>
                    <td>#@ticket.TicketId</td>
                    <td>@ticket.Title</td>
                    <td>
                        @switch (ticket.Priority)
                        {
                            case TicketPriority.Low: <span class="badge bg-secondary">Thấp</span> break;
                            case TicketPriority.Medium: <span class="badge bg-info">Trung bình</span> break;
                            case TicketPriority.High: <span class="badge bg-warning">Cao</span> break;
                            case TicketPriority.Critical: <span class="badge bg-danger">Khẩn cấp</span> break;
                        }
                    </td>
                    <td>@ticket.Creator?.FullName</td>
                    <td>@ticket.Assignee?.FullName</td>
                    <td>
                        @switch (ticket.Status)
                        {
                            case TicketStatus.Open: <span class="badge bg-primary">Mở</span> break;
                            case TicketStatus.InProgress: <span class="badge bg-info">Đang xử lý</span> break;
                            case TicketStatus.Resolved: <span class="badge bg-success">Đã giải quyết</span> break;
                            case TicketStatus.Closed: <span class="badge bg-secondary">Đóng</span> break;
                        }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@ticket.TicketId" class="btn btn-sm btn-outline-info"><i class="bi bi-eye"></i></a>
                        @if (User.IsInRole("Admin") && ticket.Status == TicketStatus.Open)
                        {
                            <a asp-action="Assign" asp-route-id="@ticket.TicketId" class="btn btn-sm btn-outline-success"><i class="bi bi-person-plus"></i></a>
                        }
                    </td>
                </tr>
                }
            </tbody>
        </table>
    </div>
</div>
