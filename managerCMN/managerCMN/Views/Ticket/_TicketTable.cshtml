@model IEnumerable<Ticket>
@using managerCMN.Helpers

@if (!Model.Any())
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-inbox fs-1"></i>
        <p class="mt-2">Không có ticket nào</p>
    </div>
}
else
{
    <style>
        .ticket-table {
            table-layout: fixed;
            width: 100% !important;
        }

        .ticket-table th,
        .ticket-table td {
            vertical-align: middle;
        }

        .ticket-table .ticket-title,
        .ticket-table .ticket-sender,
        .ticket-table .ticket-recipient {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
    </style>

    <div class="table-responsive">
        <table class="table table-hover data-table ticket-table mb-0">
            <colgroup>
                <col style="width: 6%;" />
                <col style="width: 25%;" />
                <col style="width: 9%;" />
                <col style="width: 10%;" />
                <col style="width: 13%;" />
                <col style="width: 14%;" />
                <col style="width: 10%;" />
                <col style="width: 10%;" />
                <col style="width: 3%;" />
            </colgroup>
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Tiêu đề</th>
                    <th class="text-center">Ưu tiên</th>
                    <th class="text-center">Độ khẩn</th>
                    <th>Người gửi</th>
                    <th>Người nhận</th>
                    <th class="text-center">Deadline</th>
                    <th class="text-center">Trạng thái</th>
                    <th class="text-center"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ticket in Model)
                {
                    var isOverdue = ticket.Deadline.HasValue && ticket.Deadline.Value < DateTime.UtcNow && ticket.Status != TicketStatus.Closed;
                    var isNearDeadline = ticket.Deadline.HasValue && ticket.Deadline.Value < DateTime.UtcNow.AddDays(2) && ticket.Deadline.Value >= DateTime.UtcNow;
                    <tr class="@(isOverdue ? "table-danger" : isNearDeadline ? "table-warning" : "")">
                        <td class="text-muted">#@ticket.TicketId</td>
                        <td class="ticket-title">
                            <a asp-action="Details" asp-route-id="@ticket.TicketId" class="text-decoration-none fw-semibold text-primary">
                                @ticket.Title
                            </a>
                            @if (ticket.Attachments.Any())
                            {
                                <i class="bi bi-paperclip text-muted ms-1" title="Có file đính kèm"></i>
                            }
                        </td>
                        <td class="text-center">
                            @switch (ticket.Priority)
                            {
                                case TicketPriority.Low:
                                    <span class="badge bg-secondary">Thấp</span>
                                    break;
                                case TicketPriority.Medium:
                                    <span class="badge bg-info">TB</span>
                                    break;
                                case TicketPriority.High:
                                    <span class="badge bg-warning text-dark">Cao</span>
                                    break;
                                case TicketPriority.Critical:
                                    <span class="badge bg-danger">Khẩn</span>
                                    break;
                            }
                        </td>
                        <td class="text-center">
                            @switch (ticket.Urgency)
                            {
                                case TicketUrgency.Normal:
                                    <span class="badge bg-light text-dark border">Bình thường</span>
                                    break;
                                case TicketUrgency.Urgent:
                                    <span class="badge bg-warning text-dark">Gấp</span>
                                    break;
                                case TicketUrgency.VeryUrgent:
                                    <span class="badge text-white" style="background-color: #fd7e14;">Rất gấp</span>
                                    break;
                                case TicketUrgency.Immediate:
                                    <span class="badge bg-danger">Ngay!</span>
                                    break;
                            }
                        </td>
                        <td class="ticket-sender" title="@ticket.Creator?.FullName">
                            @ticket.Creator?.FullName
                        </td>
                        <td class="ticket-recipient">
                            @if (ticket.Recipients.Any())
                            {
                                var firstRecipient = ticket.Recipients.First();
                                <span title="@firstRecipient.Employee?.FullName">@firstRecipient.Employee?.FullName</span>
                                @if (ticket.Recipients.Count > 1)
                                {
                                    <span class="badge bg-secondary ms-1" title="@string.Join(", ", ticket.Recipients.Skip(1).Select(r => r.Employee?.FullName))">+@(ticket.Recipients.Count - 1)</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td class="text-center text-nowrap">
                            @if (ticket.Deadline.HasValue)
                            {
                                if (isOverdue)
                                {
                                    <span class="text-danger fw-bold" title="Quá hạn">
                                        <i class="bi bi-exclamation-triangle-fill"></i>
                                        @ticket.Deadline.Value.ToVietnamTime().ToString("dd/MM")
                                    </span>
                                }
                                else if (isNearDeadline)
                                {
                                    <span class="text-warning fw-bold" title="Sắp đến hạn">
                                        <i class="bi bi-clock-fill"></i>
                                        @ticket.Deadline.Value.ToVietnamTime().ToString("dd/MM")
                                    </span>
                                }
                                else
                                {
                                    <span>@ticket.Deadline.Value.ToVietnamTime().ToString("dd/MM/yy")</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td class="text-center">
                            @switch (ticket.Status)
                            {
                                case TicketStatus.Open:
                                    <span class="badge bg-primary">Mở</span>
                                    break;
                                case TicketStatus.InProgress:
                                    <span class="badge bg-info">Đang xử lý</span>
                                    break;
                                case TicketStatus.Resolved:
                                    <span class="badge bg-success">Đã xong</span>
                                    break;
                                case TicketStatus.Closed:
                                    <span class="badge bg-secondary">Đóng</span>
                                    break;
                                case TicketStatus.Forwarded:
                                    <span class="badge bg-warning text-dark">Chuyển tiếp</span>
                                    break;
                                case TicketStatus.OnHold:
                                    <span class="badge bg-dark">Tạm dừng</span>
                                    break;
                                case TicketStatus.Cancelled:
                                    <span class="badge bg-danger">Đã hủy</span>
                                    break;
                            }
                        </td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@ticket.TicketId" class="btn btn-sm btn-outline-primary" title="Xem chi tiết">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
